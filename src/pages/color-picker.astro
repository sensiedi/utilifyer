---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Color Picker & Converter"
  description="Pick any color and instantly get HEX, RGB, HSL, and HSB values. Convert between color formats with one click."
  slug="color-picker"
  category="Design"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Color Picker & Converter</h1>
  <p class="text-gray-500 mb-8">Pick a color and get HEX, RGB, HSL, and HSB values instantly.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-6">

    <!-- Color picker + preview -->
    <div class="flex flex-col sm:flex-row gap-5 items-start">
      <div class="flex-shrink-0">
        <label class="label">Color Picker</label>
        <input id="color-input" type="color" value="#6366f1" class="w-32 h-32 rounded-2xl border border-gray-300 cursor-pointer p-1" />
      </div>
      <div class="flex-1 space-y-3 w-full">
        <div>
          <label class="label">HEX</label>
          <div class="flex gap-2">
            <input id="hex-input" type="text" value="#6366f1" placeholder="#000000" class="input-field font-mono" />
            <button class="copy-val btn-secondary flex-shrink-0 px-3" data-target="hex-input">Copy</button>
          </div>
        </div>
        <div>
          <label class="label">RGB</label>
          <div class="flex gap-2">
            <input id="rgb-input" type="text" value="rgb(99, 102, 241)" class="input-field font-mono" readonly />
            <button class="copy-val btn-secondary flex-shrink-0 px-3" data-target="rgb-input">Copy</button>
          </div>
        </div>
        <div>
          <label class="label">HSL</label>
          <div class="flex gap-2">
            <input id="hsl-input" type="text" value="hsl(239, 84%, 67%)" class="input-field font-mono" readonly />
            <button class="copy-val btn-secondary flex-shrink-0 px-3" data-target="hsl-input">Copy</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Hex manual entry -->
    <div>
      <label class="label">Enter a HEX code manually</label>
      <div class="flex gap-2">
        <input id="manual-hex" type="text" placeholder="#ff6b6b" class="input-field font-mono" maxlength="7" />
        <button id="apply-hex" class="btn-primary flex-shrink-0">Apply</button>
      </div>
    </div>

    <!-- Color preview band -->
    <div>
      <label class="label">Tints & Shades</label>
      <div id="tints-shades" class="flex rounded-xl overflow-hidden h-12 cursor-pointer"></div>
      <p class="text-xs text-gray-400 mt-1">Click any swatch to select it</p>
    </div>

    <!-- Contrast checker -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-3">
      <p class="text-sm font-semibold text-gray-700">Contrast Checker (WCAG)</p>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="label text-xs">Text Color</label>
          <input id="text-color" type="color" value="#ffffff" class="w-full h-10 rounded-lg border border-gray-300 cursor-pointer" />
        </div>
        <div>
          <label class="label text-xs">Background Color</label>
          <input id="bg-color-check" type="color" value="#6366f1" class="w-full h-10 rounded-lg border border-gray-300 cursor-pointer" />
        </div>
      </div>
      <div id="contrast-preview" class="rounded-lg p-4 text-center font-medium">Sample text on background</div>
      <div class="flex gap-3 text-sm">
        <div class="flex-1 text-center bg-white border border-gray-200 rounded-lg p-2">
          <p id="contrast-ratio" class="text-lg font-bold text-gray-800">—</p>
          <p class="text-xs text-gray-500">Contrast Ratio</p>
        </div>
        <div class="flex-1 text-center bg-white border border-gray-200 rounded-lg p-2">
          <p id="wcag-aa" class="text-lg font-bold">—</p>
          <p class="text-xs text-gray-500">WCAG AA</p>
        </div>
        <div class="flex-1 text-center bg-white border border-gray-200 rounded-lg p-2">
          <p id="wcag-aaa" class="text-lg font-bold">—</p>
          <p class="text-xs text-gray-500">WCAG AAA</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is a HEX color code?", a: "A HEX color code is a 6-digit hexadecimal representation of a color, prefixed with #. The first two digits represent red, the next two green, and the last two blue (e.g. #FF0000 is pure red)." },
        { q: "What is the difference between RGB and HSL?", a: "RGB describes color as amounts of Red, Green, and Blue (0–255 each). HSL describes color as Hue (0–360°), Saturation (0–100%), and Lightness (0–100%). HSL is more intuitive for humans when adjusting colors." },
        { q: "What is WCAG contrast ratio?", a: "WCAG (Web Content Accessibility Guidelines) defines minimum contrast ratios for text on backgrounds. AA requires 4.5:1 for normal text, AAA requires 7:1. Use the contrast checker above to verify your color combinations." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  function hexToRgb(hex: string) {
    const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return { r, g, b };
  }
  function rgbToHsl(r: number, g: number, b: number) {
    r /= 255; g /= 255; b /= 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0, l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
        case g: h = ((b - r) / d + 2) / 6; break;
        case b: h = ((r - g) / d + 4) / 6; break;
      }
    }
    return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
  }
  function hslToHex(h: number, s: number, l: number): string {
    s /= 100; l /= 100;
    const a = s * Math.min(l, 1 - l);
    const f = (n: number) => {
      const k = (n + h / 30) % 12;
      const color = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
      return Math.round(255 * color).toString(16).padStart(2, '0');
    };
    return `#${f(0)}${f(8)}${f(4)}`;
  }
  function luminance(r: number, g: number, b: number): number {
    const [rs, gs, bs] = [r, g, b].map(c => { c /= 255; return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4); });
    return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
  }

  const colorInput = document.getElementById('color-input') as HTMLInputElement;
  const hexInput = document.getElementById('hex-input') as HTMLInputElement;
  const rgbInput = document.getElementById('rgb-input') as HTMLInputElement;
  const hslInput = document.getElementById('hsl-input') as HTMLInputElement;

  function updateFromHex(hex: string) {
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;
    colorInput.value = hex;
    hexInput.value = hex;
    const { r, g, b } = hexToRgb(hex);
    rgbInput.value = `rgb(${r}, ${g}, ${b})`;
    const { h, s, l } = rgbToHsl(r, g, b);
    hslInput.value = `hsl(${h}, ${s}%, ${l}%)`;
    updateTints(h, s, l);
    updateContrast();
    document.getElementById('bg-color-check')!.style.setProperty('', hex);
    (document.getElementById('bg-color-check') as HTMLInputElement).value = hex;
    updateContrast();
  }

  function updateTints(h: number, s: number, l: number) {
    const container = document.getElementById('tints-shades')!;
    const steps = [10, 20, 30, 40, 50, 60, 70, 80, 90];
    container.innerHTML = steps.map(lightness => {
      const hex = hslToHex(h, s, lightness);
      return `<div class="flex-1 cursor-pointer hover:scale-y-110 transition-transform" style="background:${hex}" title="${hex}" data-hex="${hex}"></div>`;
    }).join('');
    container.querySelectorAll<HTMLElement>('[data-hex]').forEach(el => {
      el.addEventListener('click', () => updateFromHex(el.dataset.hex!));
    });
  }

  function updateContrast() {
    const textHex = (document.getElementById('text-color') as HTMLInputElement).value;
    const bgHex = (document.getElementById('bg-color-check') as HTMLInputElement).value;
    const { r: tr, g: tg, b: tb } = hexToRgb(textHex);
    const { r: br, g: bg, b: bb } = hexToRgb(bgHex);
    const l1 = luminance(tr, tg, tb), l2 = luminance(br, bg, bb);
    const ratio = (Math.max(l1, l2) + 0.05) / (Math.min(l1, l2) + 0.05);
    document.getElementById('contrast-preview')!.style.color = textHex;
    document.getElementById('contrast-preview')!.style.backgroundColor = bgHex;
    document.getElementById('contrast-ratio')!.textContent = ratio.toFixed(2) + ':1';
    const aa = ratio >= 4.5;
    const aaa = ratio >= 7;
    const aaEl = document.getElementById('wcag-aa')!;
    const aaaEl = document.getElementById('wcag-aaa')!;
    aaEl.textContent = aa ? '✅ Pass' : '❌ Fail';
    aaEl.className = `text-lg font-bold ${aa ? 'text-green-600' : 'text-red-500'}`;
    aaaEl.textContent = aaa ? '✅ Pass' : '❌ Fail';
    aaaEl.className = `text-lg font-bold ${aaa ? 'text-green-600' : 'text-red-500'}`;
  }

  colorInput.addEventListener('input', () => updateFromHex(colorInput.value));
  document.getElementById('apply-hex')?.addEventListener('click', () => {
    let hex = (document.getElementById('manual-hex') as HTMLInputElement).value.trim();
    if (!hex.startsWith('#')) hex = '#' + hex;
    updateFromHex(hex);
  });
  document.getElementById('text-color')?.addEventListener('input', updateContrast);
  document.getElementById('bg-color-check')?.addEventListener('input', updateContrast);
  document.querySelectorAll<HTMLButtonElement>('.copy-val').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = (document.getElementById(btn.dataset.target!) as HTMLInputElement).value;
      navigator.clipboard.writeText(val).then(() => { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500); });
    });
  });

  updateFromHex('#6366f1');
  updateContrast();
</script>
