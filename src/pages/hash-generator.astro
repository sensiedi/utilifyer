---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Hash Generator"
  description="Generate MD5, SHA-1, SHA-256, and SHA-512 cryptographic hashes from any text. Runs entirely in your browser — nothing is sent to a server."
  slug="hash-generator"
  category="Developer"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Hash Generator</h1>
  <p class="text-gray-500 mb-8">Generate cryptographic hashes from text — MD5, SHA-1, SHA-256, SHA-512.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div>
      <div class="flex justify-between mb-1">
        <label class="label">Input Text</label>
        <span id="input-len" class="text-xs text-gray-400"></span>
      </div>
      <textarea id="hash-input" rows={5} placeholder="Type or paste any text here…" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y text-sm font-mono"></textarea>
    </div>

    <div class="flex flex-wrap gap-2 items-center">
      <button id="btn-hash" class="btn-primary">Generate Hashes</button>
      <button id="btn-clear" class="btn-secondary">Clear</button>
      <label class="flex items-center gap-2 text-sm text-gray-600 ml-auto cursor-pointer">
        <input type="checkbox" id="uppercase" class="accent-indigo-600" />
        Uppercase output
      </label>
    </div>

    <div id="results" class="space-y-3 hidden">
      {['MD5', 'SHA-1', 'SHA-256', 'SHA-512'].map(algo => (
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-3">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">{algo}</span>
            <button data-copy-algo={algo} class="text-xs text-indigo-600 hover:text-indigo-800">Copy</button>
          </div>
          <div id={`hash-${algo.toLowerCase().replace('-','')}`} class="font-mono text-sm text-gray-800 break-all select-all"></div>
        </div>
      ))}
    </div>

    <div id="live-note" class="text-xs text-gray-400">Hashes update automatically as you type.</div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is a cryptographic hash?", a: "A hash function takes any input and produces a fixed-length string (the hash or digest). The same input always produces the same hash, and even a tiny input change produces a completely different hash. Hashes are one-way — you cannot reverse a hash to get the original text." },
        { q: "What is the difference between MD5, SHA-1, and SHA-256?", a: "MD5 produces a 128-bit (32 hex char) hash. SHA-1 produces 160-bit (40 chars). SHA-256 produces 256-bit (64 chars). SHA-512 produces 512-bit (128 chars). Longer hashes are harder to crack. MD5 and SHA-1 are considered cryptographically broken for security use, but are still used for checksums and file verification." },
        { q: "Can I use these hashes for storing passwords?", a: "No. MD5, SHA-1, SHA-256, and SHA-512 are fast by design — attackers can compute billions per second. For passwords, use a slow, salted algorithm like bcrypt, scrypt, or Argon2. These tools are for data integrity, not password storage." },
        { q: "Is my input sent to a server?", a: "No. All hashing happens entirely in your browser using the Web Crypto API (SHA algorithms) and a pure-JavaScript MD5 implementation. Your text never leaves your device." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  /* MD5 — pure JS implementation (no crypto API needed) */
  function md5(input: string): string {
    function safeAdd(x: number, y: number) { const lsw = (x & 0xffff) + (y & 0xffff); return (((x >> 16) + (y >> 16) + (lsw >> 16)) << 16) | (lsw & 0xffff); }
    function bitRotateLeft(num: number, cnt: number) { return (num << cnt) | (num >>> (32 - cnt)); }
    function md5cmn(q: number, a: number, b: number, x: number, s: number, t: number) { return safeAdd(bitRotateLeft(safeAdd(safeAdd(a, q), safeAdd(x, t)), s), b); }
    function md5ff(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return md5cmn((b & c) | (~b & d), a, b, x, s, t); }
    function md5gg(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return md5cmn((b & d) | (c & ~d), a, b, x, s, t); }
    function md5hh(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return md5cmn(b ^ c ^ d, a, b, x, s, t); }
    function md5ii(a: number, b: number, c: number, d: number, x: number, s: number, t: number) { return md5cmn(c ^ (b | ~d), a, b, x, s, t); }

    const str8 = unescape(encodeURIComponent(input));
    const len8 = str8.length;
    const nblks = ((len8 + 8) >> 6) + 1;
    const blks: number[] = new Array(nblks * 16).fill(0);
    for (let i = 0; i < len8; i++) blks[i >> 2] |= str8.charCodeAt(i) << ((i % 4) * 8);
    blks[len8 >> 2] |= 0x80 << ((len8 % 4) * 8);
    blks[nblks * 16 - 2] = len8 * 8;

    let a = 1732584193, b = -271733879, c = -1732584194, d = 271733878;
    for (let i = 0; i < blks.length; i += 16) {
      const [oa, ob, oc, od] = [a, b, c, d];
      a = md5ff(a,b,c,d,blks[i+0],7,-680876936); d = md5ff(d,a,b,c,blks[i+1],12,-389564586); c = md5ff(c,d,a,b,blks[i+2],17,606105819); b = md5ff(b,c,d,a,blks[i+3],22,-1044525330);
      a = md5ff(a,b,c,d,blks[i+4],7,-176418897); d = md5ff(d,a,b,c,blks[i+5],12,1200080426); c = md5ff(c,d,a,b,blks[i+6],17,-1473231341); b = md5ff(b,c,d,a,blks[i+7],22,-45705983);
      a = md5ff(a,b,c,d,blks[i+8],7,1770035416); d = md5ff(d,a,b,c,blks[i+9],12,-1958414417); c = md5ff(c,d,a,b,blks[i+10],17,-42063); b = md5ff(b,c,d,a,blks[i+11],22,-1990404162);
      a = md5ff(a,b,c,d,blks[i+12],7,1804603682); d = md5ff(d,a,b,c,blks[i+13],12,-40341101); c = md5ff(c,d,a,b,blks[i+14],17,-1502002290); b = md5ff(b,c,d,a,blks[i+15],22,1236535329);
      a = md5gg(a,b,c,d,blks[i+1],5,-165796510); d = md5gg(d,a,b,c,blks[i+6],9,-1069501632); c = md5gg(c,d,a,b,blks[i+11],14,643717713); b = md5gg(b,c,d,a,blks[i+0],20,-373897302);
      a = md5gg(a,b,c,d,blks[i+5],5,-701558691); d = md5gg(d,a,b,c,blks[i+10],9,38016083); c = md5gg(c,d,a,b,blks[i+15],14,-660478335); b = md5gg(b,c,d,a,blks[i+4],20,-405537848);
      a = md5gg(a,b,c,d,blks[i+9],5,568446438); d = md5gg(d,a,b,c,blks[i+14],9,-1019803690); c = md5gg(c,d,a,b,blks[i+3],14,-187363961); b = md5gg(b,c,d,a,blks[i+8],20,1163531501);
      a = md5gg(a,b,c,d,blks[i+13],5,-1444681467); d = md5gg(d,a,b,c,blks[i+2],9,-51403784); c = md5gg(c,d,a,b,blks[i+7],14,1735328473); b = md5gg(b,c,d,a,blks[i+12],20,-1926607734);
      a = md5hh(a,b,c,d,blks[i+5],4,-378558); d = md5hh(d,a,b,c,blks[i+8],11,-2022574463); c = md5hh(c,d,a,b,blks[i+11],16,1839030562); b = md5hh(b,c,d,a,blks[i+14],23,-35309556);
      a = md5hh(a,b,c,d,blks[i+1],4,-1530992060); d = md5hh(d,a,b,c,blks[i+4],11,1272893353); c = md5hh(c,d,a,b,blks[i+7],16,-155497632); b = md5hh(b,c,d,a,blks[i+10],23,-1094730640);
      a = md5hh(a,b,c,d,blks[i+13],4,681279174); d = md5hh(d,a,b,c,blks[i+0],11,-358537222); c = md5hh(c,d,a,b,blks[i+3],16,-722521979); b = md5hh(b,c,d,a,blks[i+6],23,76029189);
      a = md5hh(a,b,c,d,blks[i+9],4,-640364487); d = md5hh(d,a,b,c,blks[i+12],11,-421815835); c = md5hh(c,d,a,b,blks[i+15],16,530742520); b = md5hh(b,c,d,a,blks[i+2],23,-995338651);
      a = md5ii(a,b,c,d,blks[i+0],6,-198630844); d = md5ii(d,a,b,c,blks[i+7],10,1126891415); c = md5ii(c,d,a,b,blks[i+14],15,-1416354905); b = md5ii(b,c,d,a,blks[i+5],21,-57434055);
      a = md5ii(a,b,c,d,blks[i+12],6,1700485571); d = md5ii(d,a,b,c,blks[i+3],10,-1894986606); c = md5ii(c,d,a,b,blks[i+10],15,-1051523); b = md5ii(b,c,d,a,blks[i+1],21,-2054922799);
      a = md5ii(a,b,c,d,blks[i+8],6,1873313359); d = md5ii(d,a,b,c,blks[i+15],10,-30611744); c = md5ii(c,d,a,b,blks[i+6],15,-1560198380); b = md5ii(b,c,d,a,blks[i+13],21,1309151649);
      a = md5ii(a,b,c,d,blks[i+4],6,-145523070); d = md5ii(d,a,b,c,blks[i+11],10,-1120210379); c = md5ii(c,d,a,b,blks[i+2],15,718787259); b = md5ii(b,c,d,a,blks[i+9],21,-343485551);
      a = safeAdd(a, oa); b = safeAdd(b, ob); c = safeAdd(c, oc); d = safeAdd(d, od);
    }
    return [a, b, c, d].map(n => {
      let s = '';
      for (let j = 0; j < 4; j++) s += ('0' + ((n >> (j * 8)) & 0xff).toString(16)).slice(-2);
      return s;
    }).join('');
  }

  async function shaHash(algo: string, text: string): Promise<string> {
    const enc = new TextEncoder().encode(text);
    const buf = await crypto.subtle.digest(algo, enc);
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const algoMap: Record<string, string> = { 'SHA-1': 'sha1', 'SHA-256': 'sha256', 'SHA-512': 'sha512' };

  async function runHashes() {
    const text = (document.getElementById('hash-input') as HTMLTextAreaElement).value;
    const upper = (document.getElementById('uppercase') as HTMLInputElement).checked;
    document.getElementById('results')!.classList.toggle('hidden', !text);
    if (!text) return;

    const fmt = (h: string) => upper ? h.toUpperCase() : h;
    document.getElementById('hashmd5')!.textContent = fmt(md5(text));
    for (const [algo, id] of Object.entries(algoMap)) {
      document.getElementById(`hash${id}`)!.textContent = fmt(await shaHash(algo, text));
    }
  }

  document.getElementById('hash-input')?.addEventListener('input', () => {
    const len = (document.getElementById('hash-input') as HTMLTextAreaElement).value.length;
    document.getElementById('input-len')!.textContent = len ? `${len} chars` : '';
    runHashes();
  });
  document.getElementById('uppercase')?.addEventListener('change', runHashes);
  document.getElementById('btn-hash')?.addEventListener('click', runHashes);
  document.getElementById('btn-clear')?.addEventListener('click', () => {
    (document.getElementById('hash-input') as HTMLTextAreaElement).value = '';
    document.getElementById('input-len')!.textContent = '';
    document.getElementById('results')!.classList.add('hidden');
  });

  document.querySelectorAll('[data-copy-algo]').forEach(btn => {
    btn.addEventListener('click', () => {
      const algo = (btn as HTMLElement).dataset.copyAlgo!;
      const id = 'hash' + algo.toLowerCase().replace('-', '');
      const text = document.getElementById(id)!.textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      });
    });
  });
</script>
