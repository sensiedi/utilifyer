---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Scientific Calculator"
  description="Full-featured scientific calculator with trig functions, logarithms, powers, roots, factorial, constants (π, e), and history."
  slug="scientific-calculator"
  category="Math"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Scientific Calculator</h1>
  <p class="text-gray-500 mb-8">Full scientific calculator with trig, log, powers, and calculation history.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-4">

    <!-- Display -->
    <div class="bg-gray-900 rounded-2xl p-4">
      <div id="calc-expr" class="text-gray-400 text-sm font-mono min-h-[20px] text-right truncate"></div>
      <div id="calc-display" class="text-white text-3xl font-mono font-bold text-right mt-1 break-all">0</div>
    </div>

    <!-- Mode toggle -->
    <div class="flex gap-2 text-xs">
      <button id="mode-deg" class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white font-semibold">DEG</button>
      <button id="mode-rad" class="px-3 py-1.5 rounded-lg bg-gray-100 text-gray-600 font-semibold">RAD</button>
      <button id="btn-history" class="px-3 py-1.5 rounded-lg bg-gray-100 text-gray-600 ml-auto">History</button>
    </div>

    <!-- Buttons -->
    <div class="grid grid-cols-5 gap-1.5 text-sm">
      {[
        // Row 1 - functions
        ['sin','sin('],['cos','cos('],['tan','tan('],['log','log('],['ln','ln('],
        // Row 2
        ['sin⁻¹','asin('],['cos⁻¹','acos('],['tan⁻¹','atan('],['√','sqrt('],['x²','**2'],
        // Row 3
        ['xʸ','**'],['eˣ','exp('],['10ˣ','10**('],['|x|','abs('],['n!','!'],
        // Row 4 - numbers + ops
        ['(',  '('],[')', ')'],['%','%'],['÷','/'],['π','Math.PI'],
        ['7','7'],['8','8'],['9','9'],['×','*'],['e','Math.E'],
        ['4','4'],['5','5'],['6','6'],['−','-'],['C','C'],
        ['1','1'],['2','2'],['3','3'],['+','+'],['=','='],
        ['0','0'],['.','.'],['+/-','neg'],['←','back'],
      ].map(([label, val]) => {
        const isOp = ['+','-','×','÷','**','%'].includes(label);
        const isEq = label === '=';
        const isClear = label === 'C';
        const isDark = ['sin','cos','tan','log','ln','sin⁻¹','cos⁻¹','tan⁻¹','√','x²','xʸ','eˣ','10ˣ','|x|','n!'].includes(label);
        const cls = isEq ? 'bg-indigo-600 text-white hover:bg-indigo-700'
          : isClear ? 'bg-red-100 text-red-700 hover:bg-red-200'
          : isDark ? 'bg-gray-100 text-gray-700 hover:bg-gray-200'
          : isOp ? 'bg-indigo-50 text-indigo-700 hover:bg-indigo-100'
          : 'bg-white border border-gray-200 text-gray-800 hover:bg-gray-50';
        return (
          <button data-val={val} class={`${cls} rounded-xl py-3 font-medium transition-colors`}>{label}</button>
        );
      })}
    </div>

    <!-- History panel -->
    <div id="history-panel" class="hidden border-t border-gray-100 pt-3">
      <div class="flex justify-between items-center mb-2">
        <p class="text-sm font-semibold text-gray-700">History</p>
        <button id="clear-history" class="text-xs text-gray-400 hover:text-red-500">Clear</button>
      </div>
      <div id="history-list" class="space-y-1 max-h-40 overflow-y-auto text-sm font-mono text-gray-600"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is the difference between DEG and RAD mode?", a: "In DEG mode, angles are in degrees (full circle = 360°). In RAD mode, angles are in radians (full circle = 2π ≈ 6.28). Scientific and programming contexts typically use radians; everyday use typically uses degrees." },
        { q: "What is a logarithm?", a: "A logarithm answers: 'what power do I raise the base to, to get this number?' log₁₀(1000) = 3 because 10³ = 1000. The natural log (ln) uses base e ≈ 2.718 and is fundamental in calculus and growth models." },
        { q: "What is Euler's number (e)?", a: "e ≈ 2.71828 is a mathematical constant that is the base of the natural logarithm. It appears naturally in compound interest, population growth, radioactive decay, and probability distributions (the bell curve). Like π, it is irrational and transcendental." },
        { q: "What is factorial (n!)?", a: "Factorial n! = n × (n−1) × (n−2) × ... × 1. For example, 5! = 120. It counts the number of ways to arrange n items. 0! = 1 by definition. Factorials grow extremely fast: 20! ≈ 2.4 × 10¹⁸." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  let expr = '';
  let isDeg = true;
  const history: string[] = [];

  const display = document.getElementById('calc-display')!;
  const exprEl = document.getElementById('calc-expr')!;

  function updateDisplay() {
    display.textContent = expr || '0';
    exprEl.textContent = '';
  }

  function toRad(x: number) { return isDeg ? x * Math.PI / 180 : x; }
  function fromRad(x: number) { return isDeg ? x * 180 / Math.PI : x; }

  function factorial(n: number): number {
    if (n < 0 || !Number.isInteger(n)) return NaN;
    if (n === 0 || n === 1) return 1;
    let r = 1;
    for (let i = 2; i <= n; i++) r *= i;
    return r;
  }

  function safeEval(e: string): number {
    e = e
      .replace(/sin\(/g, isDeg ? `Math.sin(Math.PI/180*` : `Math.sin(`)
      .replace(/cos\(/g, isDeg ? `Math.cos(Math.PI/180*` : `Math.cos(`)
      .replace(/tan\(/g, isDeg ? `Math.tan(Math.PI/180*` : `Math.tan(`)
      .replace(/asin\(/g, isDeg ? `(180/Math.PI*Math.asin(` : `Math.asin(`)
      .replace(/acos\(/g, isDeg ? `(180/Math.PI*Math.acos(` : `Math.acos(`)
      .replace(/atan\(/g, isDeg ? `(180/Math.PI*Math.atan(` : `Math.atan(`)
      .replace(/sqrt\(/g, 'Math.sqrt(')
      .replace(/log\(/g, 'Math.log10(')
      .replace(/ln\(/g, 'Math.log(')
      .replace(/exp\(/g, 'Math.exp(')
      .replace(/abs\(/g, 'Math.abs(')
      .replace(/(\d+(\.\d+)?)\s*!/g, (_, n) => factorial(parseFloat(n)).toString());

    if (isDeg) {
      e = e.replace(/asin\((.*?)\)\)/g, '(180/Math.PI*Math.asin($1))')
           .replace(/acos\((.*?)\)\)/g, '(180/Math.PI*Math.acos($1))')
           .replace(/atan\((.*?)\)\)/g, '(180/Math.PI*Math.atan($1))');
    }

    // eslint-disable-next-line no-new-func
    return Function(`"use strict"; return (${e})`)();
  }

  document.querySelectorAll('[data-val]').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = (btn as HTMLElement).dataset.val!;

      if (val === 'C') { expr = ''; updateDisplay(); return; }
      if (val === 'back') { expr = expr.slice(0, -1); updateDisplay(); return; }
      if (val === 'neg') {
        if (expr && !isNaN(parseFloat(expr))) { expr = String(-parseFloat(expr)); updateDisplay(); return; }
        return;
      }
      if (val === '=') {
        try {
          const result = safeEval(expr);
          const resultStr = isFinite(result) ? parseFloat(result.toPrecision(12)).toString() : 'Error';
          history.unshift(`${expr} = ${resultStr}`);
          exprEl.textContent = expr + ' =';
          expr = resultStr;
          display.textContent = resultStr;
          renderHistory();
        } catch { display.textContent = 'Error'; expr = ''; }
        return;
      }

      expr += val;
      updateDisplay();
    });
  });

  document.getElementById('mode-deg')?.addEventListener('click', () => {
    isDeg = true;
    document.getElementById('mode-deg')!.className = 'px-3 py-1.5 rounded-lg bg-indigo-600 text-white font-semibold';
    document.getElementById('mode-rad')!.className = 'px-3 py-1.5 rounded-lg bg-gray-100 text-gray-600 font-semibold';
  });
  document.getElementById('mode-rad')?.addEventListener('click', () => {
    isDeg = false;
    document.getElementById('mode-rad')!.className = 'px-3 py-1.5 rounded-lg bg-indigo-600 text-white font-semibold';
    document.getElementById('mode-deg')!.className = 'px-3 py-1.5 rounded-lg bg-gray-100 text-gray-600 font-semibold';
  });

  document.getElementById('btn-history')?.addEventListener('click', () => {
    document.getElementById('history-panel')!.classList.toggle('hidden');
  });

  document.getElementById('clear-history')?.addEventListener('click', () => {
    history.length = 0; renderHistory();
  });

  function renderHistory() {
    document.getElementById('history-list')!.innerHTML = history.length
      ? history.map(h => `<div class="bg-gray-50 rounded px-2 py-1 text-xs">${h}</div>`).join('')
      : '<div class="text-gray-400 text-xs">No history yet</div>';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key >= '0' && e.key <= '9' || ['+','-','*','/','.','^','(',')'].includes(e.key)) {
      expr += e.key;
    } else if (e.key === 'Enter' || e.key === '=') {
      document.querySelector('[data-val="="]')?.dispatchEvent(new Event('click'));
      return;
    } else if (e.key === 'Backspace') { expr = expr.slice(0, -1); }
    else if (e.key === 'Escape') { expr = ''; }
    else return;
    updateDisplay();
  });
</script>
