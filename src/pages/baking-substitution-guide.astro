---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Baking Substitution Guide"
  description="Find substitutes for common baking ingredients. Missing buttermilk, eggs, or baking powder? Get exact substitution ratios instantly."
  slug="baking-substitution-guide"
  category="Food & Cooking"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Baking Substitution Guide</h1>
  <p class="text-gray-500 mb-8">Find substitutes for any baking ingredient — with exact ratios and notes on how it affects results.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div>
      <label class="label">Search Ingredient</label>
      <input id="bs-search" type="text" placeholder="e.g. buttermilk, eggs, butter, baking powder…" class="input-field" />
    </div>

    <div id="bs-results" class="space-y-4"></div>
    <div id="bs-empty" class="text-center py-6 text-gray-400 text-sm">Search for an ingredient above, or browse the full guide below.</div>

    <!-- Full guide -->
    <div id="bs-all" class="space-y-4"></div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "Can I substitute baking soda for baking powder?", a: "Yes — but use 1/4 the amount. 1 tsp baking powder = ¼ tsp baking soda + ½ tsp cream of tartar (to add the acid baking soda needs). Without cream of tartar, you also need an acidic ingredient (buttermilk, lemon juice, yogurt) in the recipe, otherwise the soda won't activate." },
        { q: "What can replace eggs in baking?", a: "For binding: 1 egg = 1 tbsp ground flaxseed + 3 tbsp water (let sit 5 min). For leavening: 1 egg = ¼ cup whipped aquafaba (chickpea liquid). For moisture: 1 egg = ¼ cup unsweetened applesauce or mashed banana. The best substitute depends on the egg's role in the recipe." },
        { q: "Can I substitute oil for butter?", a: "Yes — use ¾ the amount. 1 cup butter = ¾ cup neutral oil. Butter has ~20% water; oil is 100% fat, so slightly less is needed. Cakes made with oil are often more moist since oil stays liquid at room temperature. Texture may be slightly denser and flavor will be more neutral." },
        { q: "What can I use instead of buttermilk?", a: "Add 1 tbsp lemon juice or white vinegar to 1 cup milk, stir, and let sit for 5–10 minutes until it curdles slightly. Or use 1 cup plain yogurt thinned with ¼ cup milk. Sour cream + milk also works. The key is having an acidic dairy that reacts with baking soda." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  interface Sub { for_: string; substitute: string; ratio: string; notes: string; vegan?: boolean; }

  const SUBS: Sub[] = [
    // Leavening
    { for_: 'Baking Powder (1 tsp)', substitute: 'Baking soda + cream of tartar', ratio: '¼ tsp soda + ½ tsp cream of tartar', notes: 'Best substitute. Preserves rise and texture.' },
    { for_: 'Baking Powder (1 tsp)', substitute: 'Baking soda + lemon juice', ratio: '¼ tsp soda + ½ tsp lemon juice', notes: 'Slight citrus flavor. Add extra moisture if needed.', vegan: true },
    { for_: 'Baking Soda (1 tsp)', substitute: 'Baking powder', ratio: '3 tsp baking powder', notes: 'Use 3× as much. Results may be slightly soapier.', vegan: true },
    // Dairy
    { for_: 'Buttermilk (1 cup)', substitute: 'Milk + white vinegar', ratio: '1 cup milk + 1 tbsp vinegar (let sit 5 min)', notes: 'Most reliable substitute. Same acidity for leavening.', vegan: false },
    { for_: 'Buttermilk (1 cup)', substitute: 'Plain yogurt thinned', ratio: '¾ cup yogurt + ¼ cup milk', notes: 'Slightly thicker but great results.', vegan: false },
    { for_: 'Buttermilk (1 cup)', substitute: 'Oat milk + vinegar', ratio: '1 cup oat milk + 1 tbsp lemon juice', notes: 'Vegan option. Works well in pancakes and cakes.', vegan: true },
    { for_: 'Whole Milk (1 cup)', substitute: 'Non-dairy milk', ratio: '1 cup almond/oat/soy milk', notes: 'Works in most recipes. Soy milk most similar protein content.', vegan: true },
    { for_: 'Heavy Cream (1 cup)', substitute: 'Full-fat coconut cream', ratio: '1 cup (chill overnight, use solid part)', notes: 'Vegan. Different flavor but similar fat content.', vegan: true },
    { for_: 'Sour Cream (1 cup)', substitute: 'Plain Greek yogurt', ratio: '1 cup full-fat Greek yogurt', notes: 'Same tanginess and moisture. Slightly less fat.', vegan: false },
    { for_: 'Cream Cheese (1 cup)', substitute: 'Thick Greek yogurt (strained)', ratio: '1 cup strained yogurt', notes: 'Lower fat; tangier. Good for frosting and cheesecake.', vegan: false },
    // Eggs
    { for_: 'Egg (1 whole, binding)', substitute: 'Flax egg', ratio: '1 tbsp ground flax + 3 tbsp water (rest 5 min)', notes: 'Best for dense baked goods: brownies, muffins. Slight nuttiness.', vegan: true },
    { for_: 'Egg (1 whole, binding)', substitute: 'Chia egg', ratio: '1 tbsp chia seeds + 3 tbsp water (rest 5 min)', notes: 'Similar to flax. Neutral flavor.', vegan: true },
    { for_: 'Egg (1 whole, moisture)', substitute: 'Unsweetened applesauce', ratio: '¼ cup (60g) per egg', notes: 'Adds slight sweetness. Best for muffins, quick breads.', vegan: true },
    { for_: 'Egg (1 whole, moisture)', substitute: 'Mashed banana', ratio: '¼ cup (60g) per egg', notes: 'Noticeable banana flavor. Works in pancakes, muffins.', vegan: true },
    { for_: 'Egg (1 whole, leavening)', substitute: 'Aquafaba', ratio: '3 tbsp (45 ml) per egg', notes: 'Chickpea liquid. Great for meringues, angel cake, macarons.', vegan: true },
    { for_: 'Egg White (1)', substitute: 'Aquafaba', ratio: '2 tbsp per egg white', notes: 'Best egg white substitute for whipping. Vegan meringue.', vegan: true },
    // Fat
    { for_: 'Butter (1 cup)', substitute: 'Neutral oil', ratio: '¾ cup (180ml) oil', notes: 'Moister texture, no buttery flavor. Good for cakes.', vegan: true },
    { for_: 'Butter (1 cup)', substitute: 'Coconut oil (solid)', ratio: '1 cup solid coconut oil', notes: '1:1 for cookies; slight coconut flavor. Works well.', vegan: true },
    { for_: 'Butter (1 cup)', substitute: 'Vegan butter sticks', ratio: '1 cup', notes: 'Best 1:1 substitute. Nearly identical results.', vegan: true },
    { for_: 'Vegetable Oil (1 cup)', substitute: 'Melted butter', ratio: '1 cup melted butter', notes: 'Richer flavor. Slightly more solid when cooled.', vegan: false },
    // Sugar
    { for_: 'White Sugar (1 cup)', substitute: 'Brown sugar', ratio: '1 cup packed', notes: 'Adds molasses flavor and moisture. Denser texture.', vegan: true },
    { for_: 'White Sugar (1 cup)', substitute: 'Honey', ratio: '¾ cup honey (reduce liquid by 3 tbsp, add ¼ tsp baking soda)', notes: 'Sweeter and moister. Reduce oven temp 25°F.', vegan: false },
    { for_: 'White Sugar (1 cup)', substitute: 'Maple syrup', ratio: '¾ cup maple syrup (reduce liquid by 3 tbsp)', notes: 'Adds maple flavor. Works in muffins, pancakes, cakes.', vegan: true },
    { for_: 'Brown Sugar (1 cup)', substitute: 'White sugar + molasses', ratio: '1 cup white sugar + 1 tbsp molasses', notes: 'Perfect substitute — this is literally how brown sugar is made.', vegan: true },
    // Flour
    { for_: 'All-Purpose Flour (1 cup)', substitute: 'Bread flour', ratio: '1 cup (may be chewier)', notes: 'Higher protein. Cookies may spread less; cakes slightly chewier.', vegan: true },
    { for_: 'All-Purpose Flour (1 cup)', substitute: 'Cake flour', ratio: '1 cup + 2 tbsp', notes: 'Lower protein. More tender, delicate crumb. Best for cakes.', vegan: true },
    { for_: 'All-Purpose Flour (1 cup)', substitute: 'Whole wheat flour (partial)', ratio: '½ cup AP + ½ cup whole wheat', notes: 'Denser, nuttier. Replace up to 50% for best texture.', vegan: true },
    { for_: 'Cake Flour (1 cup)', substitute: 'AP flour + cornstarch', ratio: '¾ cup + 2 tbsp AP + 2 tbsp cornstarch', notes: 'Best substitute. Cornstarch lowers protein content.', vegan: true },
    // Misc
    { for_: 'Cream of Tartar (½ tsp)', substitute: 'White vinegar or lemon juice', ratio: '1½ tsp', notes: 'For stabilizing egg whites. Lemon adds slight flavor.', vegan: true },
    { for_: 'Vanilla Extract (1 tsp)', substitute: 'Vanilla bean paste', ratio: '1 tsp', notes: '1:1. More intense flavor with visible bean specks.', vegan: true },
    { for_: 'Vanilla Extract (1 tsp)', substitute: 'Almond extract', ratio: '½ tsp', notes: 'Stronger — use half. Distinct almond flavor; pairs well with cherries, almonds.', vegan: true },
    { for_: 'Cornstarch (1 tbsp, thickener)', substitute: 'All-purpose flour', ratio: '2 tbsp flour', notes: 'Less clear; use for opaque sauces and stews.', vegan: true },
    { for_: 'Cornstarch (1 tbsp, thickener)', substitute: 'Arrowroot powder', ratio: '1 tbsp', notes: 'Clearer results. Gluten-free. Doesn\'t hold up to long cooking.', vegan: true },
  ];

  function renderSubs(items: Sub[]) {
    if (items.length === 0) return '<p class="text-gray-400 text-sm text-center py-4">No matching ingredients found.</p>';
    return items.map(s => `
      <div class="border border-gray-200 rounded-xl p-4 space-y-2">
        <div class="flex items-start justify-between gap-2">
          <div class="font-semibold text-gray-800">${s.for_}</div>
          ${s.vegan ? '<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full flex-shrink-0">🌱 Vegan</span>' : ''}
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span class="text-gray-400 w-6">→</span>
          <span class="font-semibold text-indigo-700">${s.substitute}</span>
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span class="text-gray-400 w-6">=</span>
          <span class="font-mono text-gray-700 bg-gray-50 rounded px-2 py-0.5">${s.ratio}</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">${s.notes}</p>
      </div>
    `).join('');
  }

  function search() {
    const q = (document.getElementById('bs-search') as HTMLInputElement).value.trim().toLowerCase();
    const emptyEl = document.getElementById('bs-empty')!;
    const resultsEl = document.getElementById('bs-results')!;
    const allEl = document.getElementById('bs-all')!;

    if (!q) {
      resultsEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
      allEl.innerHTML = renderSubs(SUBS);
      return;
    }

    emptyEl.classList.add('hidden');
    allEl.innerHTML = '';
    const matches = SUBS.filter(s => s.for_.toLowerCase().includes(q) || s.substitute.toLowerCase().includes(q));
    resultsEl.innerHTML = matches.length ? renderSubs(matches) : '<p class="text-gray-400 text-sm text-center py-4">No matches found. Try a different ingredient name.</p>';
  }

  document.getElementById('bs-search')?.addEventListener('input', search);

  // Show all on load
  document.getElementById('bs-all')!.innerHTML = renderSubs(SUBS);
</script>
