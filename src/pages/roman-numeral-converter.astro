---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Roman Numeral Converter"
  description="Convert between Arabic numbers and Roman numerals instantly. Supports numbers 1–3,999. Learn the rules for reading and writing Roman numerals."
  slug="roman-numeral-converter"
  category="Converters"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Roman Numeral Converter</h1>
  <p class="text-gray-500 mb-8">Convert between Arabic numbers and Roman numerals (1–3,999).</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label class="label">Arabic Number → Roman</label>
        <div class="flex gap-2">
          <input id="arabic-input" type="number" min="1" max="3999" placeholder="e.g. 2024" class="input-field flex-1" />
        </div>
        <div id="roman-output" class="mt-3 bg-indigo-50 border border-indigo-200 rounded-xl px-4 py-3 font-mono text-2xl font-bold text-indigo-800 min-h-[56px] tracking-wider select-all"></div>
      </div>
      <div>
        <label class="label">Roman Numeral → Arabic</label>
        <input id="roman-input" type="text" placeholder="e.g. MMXXIV" class="input-field uppercase font-mono" />
        <div id="arabic-output" class="mt-3 bg-indigo-50 border border-indigo-200 rounded-xl px-4 py-3 font-mono text-2xl font-bold text-indigo-800 min-h-[56px] select-all"></div>
        <div id="roman-error" class="mt-1 text-xs text-red-600 hidden">Invalid Roman numeral</div>
      </div>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Roman Numeral Reference</p>
      <div class="grid grid-cols-3 sm:grid-cols-7 gap-2 text-sm text-center">
        {[['I','1'],['V','5'],['X','10'],['L','50'],['C','100'],['D','500'],['M','1000']].map(([r,a]) => (
          <div class="bg-white border border-gray-200 rounded-xl py-3">
            <div class="text-xl font-bold text-indigo-700 font-mono">{r}</div>
            <div class="text-xs text-gray-500 mt-0.5">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What are the basic Roman numeral symbols?", a: "There are 7 symbols: I (1), V (5), X (10), L (50), C (100), D (500), M (1000). All other numbers are formed by combining these — for example, VIII = 5+3 = 8, and IX = 10−1 = 9." },
        { q: "What is the subtractive notation rule?", a: "When a smaller numeral appears before a larger one, it is subtracted. Only six forms are valid: IV (4), IX (9), XL (40), XC (90), CD (400), CM (900). For example, 1999 = MCMXCIX = 1000 + (1000−100) + (100−10) + (10−1)." },
        { q: "Why can't you write numbers above 3,999 in standard Roman numerals?", a: "Standard Roman numerals have no symbol larger than M (1,000), so the largest without extension is MMMCMXCIX (3,999). Historical extensions used a bar over a numeral to multiply by 1,000, but these are non-standard today." },
        { q: "What year is MMXXIV?", a: "MMXXIV = 2000 + 20 + 4 = 2024. MM = 2000, XX = 20, IV = 4." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const VAL: [string, number][] = [
    ['M',1000],['CM',900],['D',500],['CD',400],
    ['C',100],['XC',90],['L',50],['XL',40],
    ['X',10],['IX',9],['V',5],['IV',4],['I',1],
  ];

  function toRoman(n: number): string {
    if (n < 1 || n > 3999 || !Number.isInteger(n)) return '';
    let result = '';
    for (const [sym, val] of VAL) { while (n >= val) { result += sym; n -= val; } }
    return result;
  }

  function fromRoman(s: string): number | null {
    s = s.toUpperCase().trim();
    if (!s) return null;
    const map: Record<string,number> = {I:1,V:5,X:10,L:50,C:100,D:500,M:1000};
    let result = 0;
    for (let i = 0; i < s.length; i++) {
      const curr = map[s[i]];
      if (!curr) return null;
      const next = map[s[i+1]];
      if (next && next > curr) { result += next - curr; i++; }
      else result += curr;
    }
    const verify = toRoman(result);
    return verify === s ? result : null;
  }

  document.getElementById('arabic-input')?.addEventListener('input', () => {
    const val = parseInt((document.getElementById('arabic-input') as HTMLInputElement).value);
    document.getElementById('roman-output')!.textContent = toRoman(val);
  });

  document.getElementById('roman-input')?.addEventListener('input', () => {
    const s = (document.getElementById('roman-input') as HTMLInputElement).value;
    const n = fromRoman(s);
    const errEl = document.getElementById('roman-error')!;
    if (s && n === null) {
      document.getElementById('arabic-output')!.textContent = '';
      errEl.classList.remove('hidden');
    } else {
      errEl.classList.add('hidden');
      document.getElementById('arabic-output')!.textContent = n !== null ? String(n) : '';
    }
  });
</script>
