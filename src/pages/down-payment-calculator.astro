---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Down Payment Calculator"
  description="Calculate how much down payment you need for a home and how long it will take to save. See the impact of 3%, 5%, 10%, and 20% down."
  slug="down-payment-calculator"
  category="Real Estate"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Down Payment Calculator</h1>
  <p class="text-gray-500 mb-8">Find out how much you need to save and how long it will take.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Target Home Price</label>
        <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
        <input id="dp-price" type="number" value="350000" class="input-field pl-7" /></div>
      </div>
      <div>
        <label class="label">Current Savings</label>
        <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
        <input id="dp-saved" type="number" value="15000" class="input-field pl-7" /></div>
      </div>
      <div>
        <label class="label">Monthly Savings</label>
        <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
        <input id="dp-monthly" type="number" value="1000" class="input-field pl-7" /></div>
      </div>
      <div>
        <label class="label">Savings Account APY (%)</label>
        <div class="relative">
        <input id="dp-apy" type="number" value="4.5" step="0.1" class="input-field pr-7" />
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
      </div>
    </div>

    <div id="dp-results" class="hidden space-y-4">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-gray-500 border-b border-gray-200 text-xs uppercase tracking-wide">
              <th class="text-left pb-2 pr-3">Down Payment</th>
              <th class="text-right pb-2 pr-3">Amount Needed</th>
              <th class="text-right pb-2 pr-3">Still Need</th>
              <th class="text-right pb-2 pr-3">Time to Save</th>
              <th class="text-right pb-2">Avoids PMI</th>
            </tr>
          </thead>
          <tbody id="dp-table" class="font-mono text-gray-800"></tbody>
        </table>
      </div>

      <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4">
        <p class="text-sm font-semibold text-indigo-700 mb-2">Savings Progress</p>
        <div id="dp-progress" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How much down payment do I need to avoid PMI?", a: "You need at least 20% down to avoid private mortgage insurance (PMI). PMI protects the lender if you default and typically costs 0.5–1.5% of the loan per year — $100–300/month on a $300K loan. Once you reach 20% equity, you can request PMI cancellation." },
        { q: "What is the minimum down payment for a home?", a: "Conventional loans require as little as 3% down (Fannie Mae HomeReady/HomePossible). FHA loans require 3.5% (credit score 580+) or 10% (credit score 500–579). VA loans (veterans) and USDA loans (rural areas) can have 0% down." },
        { q: "Should I put 20% down or invest the difference?", a: "Putting less than 20% down and investing the difference can outperform in bull markets, but comes with PMI costs and higher mortgage payments. The right answer depends on your risk tolerance, investment returns, mortgage rate, and how long you plan to stay." },
        { q: "Where should I save my down payment?", a: "High-yield savings accounts (HYSA) currently pay 4–5% APY and are FDIC insured — ideal for a 1–3 year timeline. For 3–5 year timelines, I-bonds or short-term CDs are options. Avoid stocks for money you need within 3 years due to volatility." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

  function monthsToSave(needed: number, saved: number, monthly: number, apy: number): number {
    if (saved >= needed) return 0;
    if (monthly <= 0) return Infinity;
    const r = apy / 100 / 12;
    let balance = saved;
    for (let m = 1; m <= 600; m++) {
      balance = balance * (1 + r) + monthly;
      if (balance >= needed) return m;
    }
    return Infinity;
  }

  function fmtMonths(m: number): string {
    if (m === 0) return 'Now ✓';
    if (!isFinite(m)) return 'N/A';
    const yr = Math.floor(m / 12);
    const mo = m % 12;
    return yr > 0 ? `${yr}y ${mo}m` : `${mo} mo`;
  }

  function calculate() {
    const price = parseFloat((document.getElementById('dp-price') as HTMLInputElement).value) || 0;
    const saved = parseFloat((document.getElementById('dp-saved') as HTMLInputElement).value) || 0;
    const monthly = parseFloat((document.getElementById('dp-monthly') as HTMLInputElement).value) || 0;
    const apy = parseFloat((document.getElementById('dp-apy') as HTMLInputElement).value) || 0;

    const tiers = [
      { label: '3.5% (FHA)', pct: 0.035, pmi: true },
      { label: '5%', pct: 0.05, pmi: true },
      { label: '10%', pct: 0.10, pmi: true },
      { label: '20% (No PMI)', pct: 0.20, pmi: false },
    ];

    document.getElementById('dp-table')!.innerHTML = tiers.map(({ label, pct, pmi }) => {
      const needed = price * pct;
      const stillNeed = Math.max(0, needed - saved);
      const months = monthsToSave(needed, saved, monthly, apy);
      const isReady = saved >= needed;
      return `<tr class="border-b border-gray-100 ${isReady ? 'bg-green-50' : ''}">
        <td class="py-2.5 pr-3 font-sans text-gray-700">${label}</td>
        <td class="py-2.5 pr-3 text-right">${fmt(needed)}</td>
        <td class="py-2.5 pr-3 text-right ${stillNeed === 0 ? 'text-green-700 font-bold' : ''}">${stillNeed === 0 ? '—' : fmt(stillNeed)}</td>
        <td class="py-2.5 pr-3 text-right ${isReady ? 'text-green-700 font-bold' : ''}">${fmtMonths(months)}</td>
        <td class="py-2.5 text-right">${pmi ? '<span class="text-red-500 text-xs">+PMI</span>' : '<span class="text-green-600 text-xs font-bold">✓</span>'}</td>
      </tr>`;
    }).join('');

    document.getElementById('dp-progress')!.innerHTML = tiers.map(({ label, pct }) => {
      const needed = price * pct;
      const pctSaved = Math.min((saved / needed) * 100, 100);
      const color = pctSaved >= 100 ? 'bg-green-500' : pctSaved >= 50 ? 'bg-indigo-500' : 'bg-gray-300';
      return `<div>
        <div class="flex justify-between text-xs text-gray-600 mb-0.5">
          <span>${label} (${fmt(needed)})</span>
          <span>${pctSaved.toFixed(0)}% saved</span>
        </div>
        <div class="h-2 bg-gray-200 rounded-full">
          <div class="${color} h-2 rounded-full transition-all" style="width:${pctSaved}%"></div>
        </div>
      </div>`;
    }).join('');

    document.getElementById('dp-results')!.classList.remove('hidden');
  }

  ['dp-price','dp-saved','dp-monthly','dp-apy'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', calculate)
  );
  calculate();
</script>
