---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Rental Yield Calculator"
  description="Calculate gross and net rental yield, cash-on-cash return, and cap rate for any investment property. Evaluate rental property ROI."
  slug="rental-yield-calculator"
  category="Real Estate"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Rental Yield Calculator</h1>
  <p class="text-gray-500 mb-8">Calculate rental yield, cap rate, and cash-on-cash return for investment properties.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="space-y-3">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Property & Income</h2>
        <div>
          <label class="label">Purchase Price</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-price" type="number" value="300000" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Monthly Rent</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-rent" type="number" value="2000" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Vacancy Rate (%)</label>
          <div class="relative">
          <input id="ry-vacancy" type="number" value="5" step="1" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
      </div>
      <div class="space-y-3">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Annual Expenses</h2>
        <div>
          <label class="label">Property Tax / year</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-tax" type="number" value="3300" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Insurance / year</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-insurance" type="number" value="1200" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Maintenance / year</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-maint" type="number" value="2000" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Property Management (% of rent)</label>
          <div class="relative">
          <input id="ry-mgmt" type="number" value="10" step="1" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Down Payment (%)</label>
          <div class="relative">
          <input id="ry-down" type="number" value="25" step="5" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Annual Mortgage Payment</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="ry-mortgage" type="number" value="15600" class="input-field pl-7" /></div>
        </div>
      </div>
    </div>

    <div id="ry-results" class="hidden space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-center">
          <div class="text-xs text-indigo-500 mb-1">Gross Yield</div>
          <div id="gross-yield" class="text-2xl font-bold text-indigo-800 font-mono"></div>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
          <div class="text-xs text-green-600 mb-1">Net Yield</div>
          <div id="net-yield" class="text-2xl font-bold text-green-800 font-mono"></div>
        </div>
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 text-center">
          <div class="text-xs text-gray-500 mb-1">Cap Rate</div>
          <div id="cap-rate" class="text-2xl font-bold text-gray-900 font-mono"></div>
        </div>
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 text-center">
          <div class="text-xs text-gray-500 mb-1">Cash-on-Cash Return</div>
          <div id="coc" class="text-2xl font-bold text-gray-900 font-mono"></div>
        </div>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase mb-1">Annual Income</p>
            <div class="flex justify-between py-0.5"><span class="text-gray-600">Gross rent</span><span id="gross-rent" class="font-mono"></span></div>
            <div class="flex justify-between py-0.5"><span class="text-gray-600">Vacancy loss</span><span id="vacancy-loss" class="font-mono text-red-500"></span></div>
            <div class="flex justify-between py-0.5 font-bold border-t border-gray-200 mt-1 pt-1"><span>Net rent income</span><span id="net-rent" class="font-mono"></span></div>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase mb-1">Annual Expenses</p>
            <div class="flex justify-between py-0.5"><span class="text-gray-600">Tax + Insurance + Maint</span><span id="opex" class="font-mono text-red-500"></span></div>
            <div class="flex justify-between py-0.5"><span class="text-gray-600">Management</span><span id="mgmt-cost" class="font-mono text-red-500"></span></div>
            <div class="flex justify-between py-0.5 font-bold border-t border-gray-200 mt-1 pt-1"><span>Net Operating Income</span><span id="noi" class="font-mono"></span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is a good rental yield?", a: "Gross yield of 6–10% is generally considered good for residential rentals. Net yield of 4–6% after expenses is healthy. Below 4% net and you may be cash-flow negative. Markets with lower yields often have higher appreciation potential as a trade-off." },
        { q: "What is the difference between gross and net yield?", a: "Gross yield = (Annual Rent ÷ Property Price) × 100. It ignores all costs. Net yield subtracts vacancy, property taxes, insurance, maintenance, and management fees. Net yield is a much more accurate picture of actual returns." },
        { q: "What is cap rate?", a: "Cap rate (capitalization rate) = Net Operating Income ÷ Property Value × 100. It measures return assuming no mortgage. A 5% cap rate means the property generates 5% of its value in NOI per year. Used to compare properties regardless of financing." },
        { q: "What is cash-on-cash return?", a: "Cash-on-cash = Annual Cash Flow ÷ Cash Invested × 100. It measures return on your actual cash invested (down payment + closing costs), accounting for mortgage payments. A 6–10% cash-on-cash return is generally considered a solid investment." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

  function calculate() {
    const price = parseFloat((document.getElementById('ry-price') as HTMLInputElement).value) || 0;
    const rent = parseFloat((document.getElementById('ry-rent') as HTMLInputElement).value) || 0;
    const vacancy = parseFloat((document.getElementById('ry-vacancy') as HTMLInputElement).value) / 100;
    const tax = parseFloat((document.getElementById('ry-tax') as HTMLInputElement).value) || 0;
    const insurance = parseFloat((document.getElementById('ry-insurance') as HTMLInputElement).value) || 0;
    const maint = parseFloat((document.getElementById('ry-maint') as HTMLInputElement).value) || 0;
    const mgmtPct = parseFloat((document.getElementById('ry-mgmt') as HTMLInputElement).value) / 100;
    const downPct = parseFloat((document.getElementById('ry-down') as HTMLInputElement).value) / 100;
    const mortgage = parseFloat((document.getElementById('ry-mortgage') as HTMLInputElement).value) || 0;

    const annualRent = rent * 12;
    const vacancyLoss = annualRent * vacancy;
    const netRent = annualRent - vacancyLoss;
    const mgmtCost = annualRent * mgmtPct;
    const opex = tax + insurance + maint;
    const noi = netRent - opex - mgmtCost;
    const cashFlow = noi - mortgage;
    const cashInvested = price * downPct;

    const grossYield = price > 0 ? (annualRent / price) * 100 : 0;
    const netYield = price > 0 ? (noi / price) * 100 : 0;
    const capRate = price > 0 ? (noi / price) * 100 : 0;
    const coc = cashInvested > 0 ? (cashFlow / cashInvested) * 100 : 0;

    document.getElementById('gross-yield')!.textContent = grossYield.toFixed(2) + '%';
    document.getElementById('net-yield')!.textContent = netYield.toFixed(2) + '%';
    document.getElementById('cap-rate')!.textContent = capRate.toFixed(2) + '%';
    document.getElementById('coc')!.textContent = coc.toFixed(2) + '%';
    document.getElementById('gross-rent')!.textContent = fmt(annualRent);
    document.getElementById('vacancy-loss')!.textContent = '−' + fmt(vacancyLoss);
    document.getElementById('net-rent')!.textContent = fmt(netRent);
    document.getElementById('opex')!.textContent = '−' + fmt(opex);
    document.getElementById('mgmt-cost')!.textContent = '−' + fmt(mgmtCost);
    document.getElementById('noi')!.textContent = fmt(noi);
    document.getElementById('ry-results')!.classList.remove('hidden');
  }

  ['ry-price','ry-rent','ry-vacancy','ry-tax','ry-insurance','ry-maint','ry-mgmt','ry-down','ry-mortgage'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', calculate)
  );
  calculate();
</script>
