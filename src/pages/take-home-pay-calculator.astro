---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Take-Home Pay Calculator"
  description="Estimate your net take-home pay after federal income tax, Social Security, Medicare, and state tax. Works for any US salary."
  slug="take-home-pay-calculator"
  category="Finance"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Take-Home Pay Calculator</h1>
  <p class="text-gray-500 mb-8">Estimate your net pay after federal taxes, FICA, and state income tax.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Annual Gross Salary ($)</label>
        <input id="salary" type="number" placeholder="e.g. 75000" class="input-field" />
      </div>
      <div>
        <label class="label">Filing Status</label>
        <select id="filing" class="input-field">
          <option value="single">Single</option>
          <option value="married">Married Filing Jointly</option>
          <option value="hoh">Head of Household</option>
        </select>
      </div>
      <div>
        <label class="label">State Income Tax Rate (%)</label>
        <div class="flex gap-2">
          <input id="state-rate" type="number" step="0.1" value="5" class="input-field" />
          <select id="state-preset" class="input-field w-auto flex-shrink-0 text-sm">
            <option value="">State</option>
            <option value="0">No tax (TX/FL/WA)</option>
            <option value="3.07">PA (3.07%)</option>
            <option value="4.95">IL (4.95%)</option>
            <option value="5">MA (5%)</option>
            <option value="5.75">VA (5.75%)</option>
            <option value="6">GA (6%)</option>
            <option value="9.3">CA (9.3%)</option>
            <option value="10.3">OR (10.3%)</option>
          </select>
        </div>
      </div>
      <div>
        <label class="label">Pre-tax Deductions (401k, HSA, etc.) ($)</label>
        <input id="pretax" type="number" value="0" placeholder="e.g. 6000" class="input-field" />
      </div>
    </div>

    <button id="calc-btn" class="btn-primary w-full">Calculate</button>

    <div id="result" class="hidden space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
        <div class="result-box"><p id="r-annual" class="text-2xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Annual Take-Home</p></div>
        <div class="result-box"><p id="r-monthly" class="text-2xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Monthly</p></div>
        <div class="result-box"><p id="r-biweekly" class="text-2xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Bi-Weekly</p></div>
        <div class="result-box"><p id="r-effective" class="text-2xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Effective Tax Rate</p></div>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl overflow-hidden text-sm">
        <div class="px-4 py-2 bg-gray-100 text-xs font-semibold text-gray-500 uppercase">Deduction Breakdown (Annual)</div>
        <table class="w-full">
          <tbody id="deduct-table" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is the difference between gross and net pay?", a: "Gross pay is your salary before any deductions. Net pay (take-home pay) is what you receive after federal income tax, state income tax, Social Security (6.2%), and Medicare (1.45%) are withheld." },
        { q: "What is FICA tax?", a: "FICA stands for Federal Insurance Contributions Act. It includes Social Security tax (6.2% on wages up to $176,100 in 2025) and Medicare tax (1.45% on all wages, plus 0.9% on wages over $200,000 for single filers)." },
        { q: "How do pre-tax deductions reduce my taxes?", a: "Contributions to 401(k), HSA, FSA, and health insurance premiums are deducted from your gross salary before federal income tax is calculated. This lowers your taxable income, reducing your federal and state tax bill." },
        { q: "Is this calculator accurate?", a: "This provides an estimate using 2024 federal tax brackets. It does not account for itemized deductions, tax credits, additional Medicare tax, or all state-specific rules. For precise figures, use official IRS withholding tables or a tax professional." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // 2024 federal tax brackets
  const BRACKETS: Record<string, [number, number][]> = {
    single: [[11600,0.10],[47150,0.12],[100525,0.22],[191950,0.24],[243725,0.32],[609350,0.35],[Infinity,0.37]],
    married: [[23200,0.10],[94300,0.12],[201050,0.22],[383900,0.24],[487450,0.32],[731200,0.35],[Infinity,0.37]],
    hoh: [[16550,0.10],[63100,0.12],[100500,0.22],[191950,0.24],[243700,0.32],[609350,0.35],[Infinity,0.37]],
  };
  const STD_DEDUCT: Record<string, number> = { single: 14600, married: 29200, hoh: 21900 };

  function federalTax(taxable: number, status: string): number {
    const brackets = BRACKETS[status];
    let tax = 0, prev = 0;
    for (const [limit, rate] of brackets) {
      if (taxable <= prev) break;
      tax += (Math.min(taxable, limit) - prev) * rate;
      prev = limit;
    }
    return tax;
  }

  document.getElementById('state-preset')?.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    if (val !== '') (document.getElementById('state-rate') as HTMLInputElement).value = val;
  });

  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const gross = parseFloat((document.getElementById('salary') as HTMLInputElement).value);
    const filing = (document.getElementById('filing') as HTMLSelectElement).value;
    const stateRate = parseFloat((document.getElementById('state-rate') as HTMLInputElement).value) || 0;
    const pretax = parseFloat((document.getElementById('pretax') as HTMLInputElement).value) || 0;
    if (isNaN(gross)) return;

    const agi = gross - pretax;
    const taxable = Math.max(agi - STD_DEDUCT[filing], 0);
    const fedTax = federalTax(taxable, filing);
    const ss = Math.min(gross, 176100) * 0.062;
    const medicare = gross * 0.0145 + (gross > 200000 ? (gross - 200000) * 0.009 : 0);
    const stateTax = agi * (stateRate / 100);
    const totalTax = fedTax + ss + medicare + stateTax + pretax;
    const takeHome = gross - totalTax;
    const effectiveRate = (totalTax / gross) * 100;

    document.getElementById('r-annual')!.textContent = fmt(takeHome);
    document.getElementById('r-monthly')!.textContent = fmt(takeHome / 12);
    document.getElementById('r-biweekly')!.textContent = fmt(takeHome / 26);
    document.getElementById('r-effective')!.textContent = effectiveRate.toFixed(1) + '%';

    const rows = [
      ['Gross Salary', gross],
      ['Federal Income Tax', -fedTax],
      ['Social Security (6.2%)', -ss],
      ['Medicare (1.45%)', -medicare],
      [`State Income Tax (${stateRate}%)`, -stateTax],
      ['Pre-tax Deductions', -pretax],
      ['Net Take-Home Pay', takeHome],
    ];
    document.getElementById('deduct-table')!.innerHTML = rows.map(([label, val]) => {
      const isTotal = label === 'Net Take-Home Pay';
      return `<tr class="bg-white hover:bg-gray-50 ${isTotal ? 'font-semibold border-t-2 border-gray-300' : ''}">
        <td class="px-4 py-2.5 text-gray-700">${label}</td>
        <td class="px-4 py-2.5 text-right ${(val as number) < 0 ? 'text-red-600' : 'text-green-600'}">${(val as number) < 0 ? '-' + fmt(Math.abs(val as number)) : fmt(val as number)}</td>
      </tr>`;
    }).join('');

    document.getElementById('result')!.classList.remove('hidden');
  });
</script>
