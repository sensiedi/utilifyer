---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Pressure Converter"
  description="Convert between pascals, bar, PSI, atmospheres, mmHg (torr), kPa, MPa, and more pressure units instantly."
  slug="pressure-converter"
  category="Converters"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Pressure Converter</h1>
  <p class="text-gray-500 mb-8">Convert between Pa, bar, PSI, atm, mmHg, kPa, and more.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Value</label>
        <input id="prs-value" type="number" placeholder="Enter a value" class="input-field text-lg" />
      </div>
      <div>
        <label class="label">From Unit</label>
        <select id="prs-from" class="input-field">
          <option value="pa">Pascal (Pa)</option>
          <option value="kpa">Kilopascal (kPa)</option>
          <option value="mpa">Megapascal (MPa)</option>
          <option value="bar">Bar</option>
          <option value="mbar">Millibar (mbar)</option>
          <option value="psi">PSI (lb/in²)</option>
          <option value="atm">Atmosphere (atm)</option>
          <option value="mmhg">mmHg / Torr</option>
          <option value="inhg">inHg (inches of mercury)</option>
        </select>
      </div>
    </div>

    <div id="prs-results" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Common Pressure References</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-gray-600">
        {[
          ['1 atm (sea level)', '101,325 Pa / 14.696 PSI'],
          ['Car tire pressure', '30–35 PSI / 2.1–2.4 bar'],
          ['Blood pressure systolic', '≈ 120 mmHg (normal)'],
          ['Deep sea (1000m)', '≈ 100 atm / 1450 PSI'],
        ].map(([a, b]) => (
          <div class="flex justify-between bg-white border border-gray-100 rounded px-3 py-1.5">
            <span class="font-medium text-gray-700">{a}</span>
            <span class="text-gray-500">{b}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is 1 atmosphere in PSI?", a: "Standard atmospheric pressure (1 atm) equals 14.696 PSI (pounds per square inch) or 101,325 pascals or 1.01325 bar. This is the average air pressure at sea level." },
        { q: "What units are used for blood pressure?", a: "Blood pressure is measured in millimeters of mercury (mmHg). Normal blood pressure is 120/80 mmHg — systolic (pumping) over diastolic (resting). The mmHg unit comes from mercury manometers used historically." },
        { q: "What is the difference between PSI and bar?", a: "PSI (pounds per square inch) is common in the US; bar is common in Europe. 1 bar ≈ 14.504 PSI. For tire pressure: 30 PSI ≈ 2.07 bar. Bar is close to 1 atm (1 atm = 1.01325 bar)." },
        { q: "What is a pascal?", a: "The pascal (Pa) is the SI unit of pressure, equal to 1 newton per square meter (N/m²). It is very small — standard atmospheric pressure is 101,325 Pa, so kilopascal (kPa) and megapascal (MPa) are more commonly used." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const TO_PA: Record<string, number> = {
    pa: 1, kpa: 1000, mpa: 1e6,
    bar: 100000, mbar: 100, psi: 6894.757,
    atm: 101325, mmhg: 133.3224, inhg: 3386.389,
  };
  const LABELS: Record<string, string> = {
    pa: 'Pascal', kpa: 'Kilopascal', mpa: 'Megapascal',
    bar: 'Bar', mbar: 'Millibar', psi: 'PSI',
    atm: 'Atmosphere', mmhg: 'mmHg / Torr', inhg: 'inHg',
  };
  const UNITS: Record<string, string> = {
    pa: 'Pa', kpa: 'kPa', mpa: 'MPa',
    bar: 'bar', mbar: 'mbar', psi: 'PSI',
    atm: 'atm', mmhg: 'mmHg', inhg: 'inHg',
  };

  function fmt(n: number): string {
    if (n === 0) return '0';
    if (Math.abs(n) >= 1e9 || (Math.abs(n) < 1e-6 && n !== 0)) return n.toExponential(4);
    return parseFloat(n.toPrecision(8)).toString();
  }

  function convert() {
    const val = parseFloat((document.getElementById('prs-value') as HTMLInputElement).value);
    const from = (document.getElementById('prs-from') as HTMLSelectElement).value;
    const container = document.getElementById('prs-results')!;
    if (isNaN(val)) { container.innerHTML = ''; return; }
    const pa = val * TO_PA[from];
    container.innerHTML = Object.entries(TO_PA).map(([unit, factor]) => {
      const result = pa / factor;
      const active = unit === from ? 'border-indigo-300 bg-indigo-50' : 'border-gray-100 bg-gray-50';
      return `<div class="flex justify-between items-center border ${active} rounded-xl px-4 py-2.5">
        <span class="text-sm text-gray-500">${LABELS[unit]}</span>
        <span class="font-mono text-sm font-medium text-gray-800 select-all">${fmt(result)} ${UNITS[unit]}</span>
      </div>`;
    }).join('');
  }

  document.getElementById('prs-value')?.addEventListener('input', convert);
  document.getElementById('prs-from')?.addEventListener('change', convert);
</script>
