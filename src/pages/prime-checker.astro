---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Prime Number Checker"
  description="Check if any number is prime. Find all prime factors. Generate a list of prime numbers up to any limit. Instant results."
  slug="prime-checker"
  category="Math"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Prime Number Checker</h1>
  <p class="text-gray-500 mb-8">Check if a number is prime, find its factors, or generate a list of primes.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-6">

    <!-- Single check -->
    <div>
      <label class="label">Check a Number</label>
      <div class="flex gap-2">
        <input id="prime-input" type="number" min="1" placeholder="e.g. 97" class="input-field flex-1 text-lg font-mono" />
      </div>
      <div id="prime-result" class="mt-3 hidden"></div>
    </div>

    <!-- Prime sieve -->
    <div class="border-t border-gray-100 pt-5">
      <label class="label">List All Primes Up To</label>
      <div class="flex gap-2">
        <input id="sieve-limit" type="number" min="2" max="10000" value="100" class="input-field w-32" />
        <button id="sieve-btn" class="btn-secondary">Generate</button>
      </div>
      <div id="sieve-results" class="mt-3"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is a prime number?", a: "A prime number is a natural number greater than 1 that has no positive divisors other than 1 and itself. Examples: 2, 3, 5, 7, 11, 13... The number 1 is not prime by definition." },
        { q: "Why is 2 the only even prime?", a: "Every even number is divisible by 2. Since 2 is divisible only by 1 and itself, it qualifies as prime. Any other even number has at least three divisors (1, 2, and itself), so none can be prime." },
        { q: "How many prime numbers are there?", a: "There are infinitely many primes — proven by Euclid around 300 BC. His proof: assume a finite list, multiply them all together and add 1. That number is either prime itself, or divisible by a prime not in the list. Contradiction." },
        { q: "What is the Sieve of Eratosthenes?", a: "An ancient algorithm to find all primes up to a limit. Start with a list 2–N. Mark 2 as prime, cross out its multiples. Move to the next unmarked number, mark it prime, cross out multiples. Repeat until N. All unmarked numbers are prime." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  function isPrime(n: number): boolean {
    if (n < 2) return false;
    if (n === 2) return true;
    if (n % 2 === 0) return false;
    for (let i = 3; i <= Math.sqrt(n); i += 2) if (n % i === 0) return false;
    return true;
  }

  function primeFactors(n: number): number[] {
    const factors: number[] = [];
    let d = 2;
    while (d * d <= n) {
      while (n % d === 0) { factors.push(d); n = Math.floor(n / d); }
      d++;
    }
    if (n > 1) factors.push(n);
    return factors;
  }

  function sieve(limit: number): number[] {
    const composite = new Uint8Array(limit + 1);
    const primes: number[] = [];
    for (let i = 2; i <= limit; i++) {
      if (!composite[i]) {
        primes.push(i);
        for (let j = i * i; j <= limit; j += i) composite[j] = 1;
      }
    }
    return primes;
  }

  document.getElementById('prime-input')?.addEventListener('input', () => {
    const n = parseInt((document.getElementById('prime-input') as HTMLInputElement).value);
    const container = document.getElementById('prime-result')!;
    if (isNaN(n) || n < 1) { container.classList.add('hidden'); return; }

    const prime = isPrime(n);
    const factors = primeFactors(n);
    const factorStr = factors.length > 0 ? factors.join(' × ') : String(n);
    const color = prime ? 'indigo' : 'gray';
    const badge = prime
      ? `<span class="bg-indigo-100 text-indigo-800 font-bold px-3 py-1 rounded-full text-sm">PRIME ✓</span>`
      : `<span class="bg-gray-100 text-gray-700 font-bold px-3 py-1 rounded-full text-sm">NOT PRIME</span>`;

    container.innerHTML = `<div class="bg-${color}-50 border border-${color}-200 rounded-xl p-4 space-y-2">
      <div class="flex items-center gap-3">
        <span class="text-2xl font-mono font-bold text-${color}-800">${n}</span>
        ${badge}
      </div>
      ${!prime ? `<div class="text-sm text-gray-600"><span class="font-medium">Prime factors:</span> <span class="font-mono">${factorStr}</span></div>` : ''}
      ${!prime ? `<div class="text-sm text-gray-600"><span class="font-medium">Divisors:</span> <span class="font-mono">${Array.from({length: n}, (_,i) => i+1).filter(d => n % d === 0).join(', ')}</span></div>` : ''}
    </div>`;
    container.classList.remove('hidden');
  });

  document.getElementById('sieve-btn')?.addEventListener('click', () => {
    const limit = Math.min(parseInt((document.getElementById('sieve-limit') as HTMLInputElement).value) || 100, 10000);
    const primes = sieve(limit);
    const container = document.getElementById('sieve-results')!;
    container.innerHTML = `<p class="text-xs text-gray-500 mb-2">${primes.length} primes up to ${limit}</p>
      <div class="flex flex-wrap gap-1.5 max-h-64 overflow-y-auto">
        ${primes.map(p => `<span class="bg-indigo-50 border border-indigo-200 text-indigo-700 text-xs font-mono px-2 py-0.5 rounded">${p}</span>`).join('')}
      </div>`;
  });

  document.getElementById('sieve-btn')!.click();
</script>
