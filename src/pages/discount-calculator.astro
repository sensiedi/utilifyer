---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Discount Calculator"
  description="Calculate the sale price after a discount percentage. Find out how much you save and what the final price is."
  slug="discount-calculator"
  category="Finance"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Discount Calculator</h1>
  <p class="text-gray-500 mb-8">Find out the sale price and how much you save with any discount.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex border-b border-gray-200">
      <button data-tab="0" class="tab-btn flex-1 py-3 text-sm font-medium text-indigo-600 border-b-2 border-indigo-600 bg-indigo-50 transition-colors">% Off</button>
      <button data-tab="1" class="tab-btn flex-1 py-3 text-sm font-medium text-gray-500 hover:bg-gray-50 border-b-2 border-transparent transition-colors">Sale Price → Discount %</button>
      <button data-tab="2" class="tab-btn flex-1 py-3 text-sm font-medium text-gray-500 hover:bg-gray-50 border-b-2 border-transparent transition-colors">Stacked Discounts</button>
    </div>

    <div class="p-6">

      <!-- Panel 0: % off -->
      <div data-panel="0" class="tab-panel space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label">Original Price ($)</label>
            <input id="p0-price" type="number" placeholder="e.g. 120" class="input-field" />
          </div>
          <div>
            <label class="label">Discount (%)</label>
            <input id="p0-pct" type="number" placeholder="e.g. 25" min="0" max="100" class="input-field" />
          </div>
        </div>
        <!-- Quick % presets -->
        <div class="flex flex-wrap gap-2">
          {[5,10,15,20,25,30,40,50,60,70].map(p => (
            <button class="pct-preset px-3 py-1 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-indigo-400 hover:bg-indigo-50 hover:text-indigo-600 transition-colors" data-pct={p}>{p}%</button>
          ))}
        </div>
        <button id="p0-calc" class="btn-primary w-full">Calculate</button>
        <div id="p0-result" class="hidden">
          <div class="grid grid-cols-3 gap-3 text-center">
            <div class="result-box">
              <p class="text-xs text-indigo-600 font-medium mb-1">You Save</p>
              <p id="p0-save" class="text-2xl font-bold text-indigo-900"></p>
            </div>
            <div class="result-box">
              <p class="text-xs text-indigo-600 font-medium mb-1">Sale Price</p>
              <p id="p0-sale" class="text-2xl font-bold text-indigo-900"></p>
            </div>
            <div class="result-box">
              <p class="text-xs text-indigo-600 font-medium mb-1">Savings %</p>
              <p id="p0-savings-pct" class="text-2xl font-bold text-indigo-900"></p>
            </div>
          </div>
          <!-- Savings bar -->
          <div class="mt-4 bg-gray-100 rounded-full h-4 overflow-hidden">
            <div id="p0-bar" class="h-full bg-gradient-to-r from-indigo-500 to-green-500 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-xs text-gray-500 mt-1">
            <span>$0 saved</span>
            <span id="p0-bar-label"></span>
          </div>
        </div>
      </div>

      <!-- Panel 1: What % off? -->
      <div data-panel="1" class="tab-panel hidden space-y-4">
        <p class="text-sm text-gray-600">Find the discount percentage between the original and sale price.</p>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label">Original Price ($)</label>
            <input id="p1-original" type="number" placeholder="e.g. 80" class="input-field" />
          </div>
          <div>
            <label class="label">Sale Price ($)</label>
            <input id="p1-sale" type="number" placeholder="e.g. 60" class="input-field" />
          </div>
        </div>
        <button id="p1-calc" class="btn-primary w-full">Calculate</button>
        <div id="p1-result" class="hidden result-box">
          <p class="text-sm text-indigo-700 font-medium">Result</p>
          <p id="p1-answer" class="text-3xl font-bold text-indigo-900 mt-1"></p>
          <p id="p1-note" class="text-xs text-indigo-600 mt-2"></p>
        </div>
      </div>

      <!-- Panel 2: Stacked discounts -->
      <div data-panel="2" class="tab-panel hidden space-y-4">
        <p class="text-sm text-gray-600">Apply multiple discounts on top of each other (e.g. 20% off, then extra 10% off).</p>
        <div>
          <label class="label">Original Price ($)</label>
          <input id="p2-price" type="number" placeholder="e.g. 200" class="input-field" />
        </div>
        <div id="stack-discounts" class="space-y-2">
          <div class="flex gap-2 items-center stack-row">
            <input type="number" placeholder="Discount 1 (%)" class="input-field stack-input" min="0" max="100" />
            <button class="remove-stack text-gray-400 hover:text-red-500 transition-colors text-lg font-bold hidden">×</button>
          </div>
          <div class="flex gap-2 items-center stack-row">
            <input type="number" placeholder="Discount 2 (%)" class="input-field stack-input" min="0" max="100" />
            <button class="remove-stack text-gray-400 hover:text-red-500 transition-colors text-lg font-bold">×</button>
          </div>
        </div>
        <button id="add-stack" class="btn-secondary w-full text-sm">+ Add Another Discount</button>
        <button id="p2-calc" class="btn-primary w-full">Calculate Stacked Discount</button>
        <div id="p2-result" class="hidden result-box space-y-2">
          <p class="text-sm text-indigo-700 font-medium">Result</p>
          <div id="p2-steps" class="text-xs text-indigo-600 space-y-1 font-mono"></div>
          <p class="text-xs text-indigo-500 pt-1 border-t border-indigo-100">Total effective discount: <span id="p2-effective" class="font-bold"></span></p>
          <p class="text-indigo-900 font-bold text-2xl">Final price: <span id="p2-final"></span></p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How do I calculate 20% off a price?", a: "Multiply the original price by 0.20 to get the discount amount, then subtract it from the original price. For example, 20% off $150 = $150 × 0.20 = $30 saved. Sale price = $120." },
        { q: "Do stacked discounts add together?", a: "No — stacked discounts are applied sequentially, not added. A 20% discount followed by a 10% discount is NOT 30% off. It equals 28% off the original price." },
        { q: "How do I find what percent off a sale price is?", a: "Use the second tab. Enter the original and sale price and the calculator will tell you the discount percentage. Formula: ((original − sale) ÷ original) × 100." },
        { q: "What is 50% off?", a: "50% off means the item costs half of the original price. A $200 item at 50% off costs $100." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  // Tabs
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.dataset.tab);
      document.querySelectorAll('.tab-btn').forEach((b, i) => {
        b.classList.toggle('text-indigo-600', i === idx);
        b.classList.toggle('border-indigo-600', i === idx);
        b.classList.toggle('bg-indigo-50', i === idx);
        b.classList.toggle('text-gray-500', i !== idx);
        b.classList.toggle('border-transparent', i !== idx);
      });
      document.querySelectorAll('.tab-panel').forEach((p, i) => (p as HTMLElement).classList.toggle('hidden', i !== idx));
    });
  });

  // Quick pct presets
  document.querySelectorAll<HTMLButtonElement>('.pct-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('p0-pct') as HTMLInputElement).value = btn.dataset.pct!;
    });
  });

  const fmt = (n: number) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // Panel 0
  document.getElementById('p0-calc')?.addEventListener('click', () => {
    const price = parseFloat((document.getElementById('p0-price') as HTMLInputElement).value);
    const pct = parseFloat((document.getElementById('p0-pct') as HTMLInputElement).value);
    if (isNaN(price) || isNaN(pct)) return;
    const saved = price * pct / 100;
    const sale = price - saved;
    document.getElementById('p0-save')!.textContent = fmt(saved);
    document.getElementById('p0-sale')!.textContent = fmt(sale);
    document.getElementById('p0-savings-pct')!.textContent = pct + '%';
    document.getElementById('p0-bar')!.style.width = Math.min(pct, 100) + '%';
    document.getElementById('p0-bar-label')!.textContent = fmt(saved) + ' saved';
    document.getElementById('p0-result')!.classList.remove('hidden');
  });

  // Panel 1
  document.getElementById('p1-calc')?.addEventListener('click', () => {
    const orig = parseFloat((document.getElementById('p1-original') as HTMLInputElement).value);
    const sale = parseFloat((document.getElementById('p1-sale') as HTMLInputElement).value);
    if (isNaN(orig) || isNaN(sale) || orig <= 0) return;
    const pct = ((orig - sale) / orig) * 100;
    const saved = orig - sale;
    document.getElementById('p1-answer')!.textContent = pct.toFixed(2) + '% off';
    document.getElementById('p1-note')!.textContent = `You save ${fmt(saved)} off the original ${fmt(orig)}`;
    document.getElementById('p1-result')!.classList.remove('hidden');
  });

  // Panel 2 — stacked
  document.getElementById('add-stack')?.addEventListener('click', () => {
    const container = document.getElementById('stack-discounts')!;
    const count = container.querySelectorAll('.stack-row').length + 1;
    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center stack-row';
    row.innerHTML = `<input type="number" placeholder="Discount ${count} (%)" class="input-field stack-input" min="0" max="100" /><button class="remove-stack text-gray-400 hover:text-red-500 transition-colors text-lg font-bold">×</button>`;
    row.querySelector('.remove-stack')?.addEventListener('click', () => row.remove());
    container.appendChild(row);
  });

  document.querySelectorAll('.remove-stack').forEach(btn => {
    btn.addEventListener('click', () => (btn as HTMLElement).closest('.stack-row')?.remove());
  });

  document.getElementById('p2-calc')?.addEventListener('click', () => {
    const price = parseFloat((document.getElementById('p2-price') as HTMLInputElement).value);
    if (isNaN(price)) return;
    const inputs = document.querySelectorAll<HTMLInputElement>('.stack-input');
    let current = price;
    const steps: string[] = [];
    inputs.forEach((inp, i) => {
      const d = parseFloat(inp.value);
      if (!isNaN(d) && d > 0) {
        const saved = current * d / 100;
        current -= saved;
        steps.push(`Step ${i + 1}: ${fmt(current + saved)} − ${d}% = ${fmt(current)}`);
      }
    });
    const effective = ((price - current) / price) * 100;
    document.getElementById('p2-steps')!.innerHTML = steps.map(s => `<p>${s}</p>`).join('');
    document.getElementById('p2-effective')!.textContent = effective.toFixed(2) + '%';
    document.getElementById('p2-final')!.textContent = fmt(current);
    document.getElementById('p2-result')!.classList.remove('hidden');
  });
</script>
