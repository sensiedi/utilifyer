sense,serve,seven,shade,shake,shame,shape,share,sharp,shear,sheet,shelf,shiver,shoot,shore,short,shout,sight,single,sixth,sixty,sized,skate,skirt,skull,sky,slash,slate,slave,sleep,sleek,slide,slope,smart,smile,smoke,snare,sneak,solid,solve,south,space,speak,speed,spell,spend,spill,spite,split,spoke,spook,spray,squad,stake,stale,stamp,stand,stare,start,state,stave,stray,sting,stock,stone,stood,store,storm,story,stout,stove,strap,stray,style,sugar,suite,summon,super,surge,swear,swirl,sword,table,taint,taste,teach,theme,there,thick,tiger,tired,title,today,token,total,touch,tough,towel,tower,toxic,track,trade,trail,train,trait,tramp,trash,treat,tribe,tried,trust,truth,tulip,ultra,under,upper,upset,urban,usual,utter,valid,value,video,vigor,viral,visit,vital,vivid,vocal,voice,waist,water,weary,wedge,wheel,where,which,while,white,whole,whose,width,women,world,worth,would,wound,wrath,write,yield,young,yours,youth".split(',');

  function sortLetters(s: string): string {
    return s.toLowerCase().replace(/\s/g,'').split('').sort().join('');
  }

  function solve(input: string): string[] {
    const letters = sortLetters(input);
    if (letters.length < 2) return [];
    const results: string[] = [];
    const letterCount: Record<string, number> = {};
    for (const c of letters) letterCount[c] = (letterCount[c] || 0) + 1;

    for (const word of WORD_LIST) {
      if (word.length < 2 || word.length > letters.length) continue;
      const wCount: Record<string, number> = {};
      for (const c of word) wCount[c] = (wCount[c] || 0) + 1;
      const fits = Object.entries(wCount).every(([c, n]) => (letterCount[c] || 0) >= n);
      if (fits) results.push(word);
    }
    return [...new Set(results)];
  }

  let currentResults: string[] = [];
  let sortMode = 'length';

  function renderResults(words: string[], mode: string) {
    if (!words.length) {
      document.getElementById('ag-count')!.textContent = 'No words found';
      document.getElementById('ag-groups')!.innerHTML = '<p class="text-sm text-gray-500">Try different letters.</p>';
      document.getElementById('ag-result')!.classList.remove('hidden');
      return;
    }
    const sorted = [...words].sort(mode === 'length'
      ? (a, b) => b.length - a.length || a.localeCompare(b)
      : (a, b) => a.localeCompare(b)
    );
    document.getElementById('ag-count')!.textContent = `${words.length} word${words.length !== 1 ? 's' : ''} found`;

    if (mode === 'length') {
      const groups: Record<number, string[]> = {};
      sorted.forEach(w => { if (!groups[w.length]) groups[w.length] = []; groups[w.length].push(w); });
      document.getElementById('ag-groups')!.innerHTML = Object.entries(groups)
        .sort(([a],[b]) => +b - +a)
        .map(([len, ws]) =>
          `<div>
            <p class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1.5">${len}-letter words (${ws.length})</p>
            <div class="flex flex-wrap gap-1.5">${ws.map(w =>
              `<span class="bg-gray-50 border border-gray-200 rounded-lg px-3 py-1 font-mono text-sm text-gray-700 hover:border-indigo-300 cursor-pointer">${w}</span>`
            ).join('')}</div>
          </div>`
        ).join('');
    } else {
      document.getElementById('ag-groups')!.innerHTML =
        `<div class="flex flex-wrap gap-1.5">${sorted.map(w =>
          `<span class="bg-gray-50 border border-gray-200 rounded-lg px-3 py-1 font-mono text-sm text-gray-700 hover:border-indigo-300">${w}</span>`
        ).join('')}</div>`;
    }
    document.getElementById('ag-result')!.classList.remove('hidden');
  }

  function doSolve() {
    const input = (document.getElementById('ag-input') as HTMLInputElement).value.trim();
    if (!input) return;

    // Show letter tiles
    const letters = input.toLowerCase().replace(/\s/g,'').split('');
    document.getElementById('ag-tiles')!.innerHTML = letters.map(l =>
      `<span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-100 border-2 border-indigo-200 font-mono font-bold text-indigo-800 text-lg uppercase">${l}</span>`
    ).join('');

    currentResults = solve(input);
    renderResults(currentResults, sortMode);
  }

  document.getElementById('ag-solve')!.addEventListener('click', doSolve);
  document.getElementById('ag-input')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') doSolve();
  });
  (document.getElementById('ag-input') as HTMLInputElement).addEventListener('input', (e) => {
    (e.target as HTMLInputElement).value = (e.target as HTMLInputElement).value.toUpperCase();
  });

  document.querySelectorAll('.ag-sort').forEach(btn => {
    btn.addEventListener('click', () => {
      sortMode = (btn as HTMLElement).dataset.sort!;
      document.querySelectorAll('.ag-sort').forEach(b => {
        b.classList.toggle('border-indigo-400', (b as HTMLElement).dataset.sort === sortMode);
        b.classList.toggle('bg-indigo-50', (b as HTMLElement).dataset.sort === sortMode);
      });
      renderResults(currentResults, sortMode);
    });
  });

  // Pre-fill
  (document.getElementById('ag-input') as HTMLInputElement).value = 'LISTEN';
  doSolve();
</script>
