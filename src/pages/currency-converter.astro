---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Currency Converter"
  description="Convert between 30+ major world currencies using approximate exchange rates. Quick reference for travel, shopping, and international transactions."
  slug="currency-converter"
  category="Travel & Geography"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Currency Converter</h1>
  <p class="text-gray-500 mb-8">Convert between major world currencies. Note: rates are approximate — check your bank for exact rates.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-sm text-amber-800">
      ⚠️ Exchange rates shown are approximate mid-market rates for reference. For financial transactions, always use your bank or broker's live rates.
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
      <div>
        <label class="label">Amount</label>
        <input id="cc-amount" type="number" value="100" min="0" step="any" class="input-field font-mono text-xl" />
      </div>
      <div>
        <label class="label">From</label>
        <select id="cc-from" class="input-field"></select>
      </div>
      <div>
        <label class="label">To</label>
        <select id="cc-to" class="input-field"></select>
      </div>
    </div>

    <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 flex items-center justify-between">
      <div>
        <div class="text-xs text-indigo-500 mb-0.5">Result</div>
        <div id="cc-result" class="text-3xl font-bold font-mono text-indigo-900">—</div>
      </div>
      <button id="cc-swap" class="text-indigo-600 hover:text-indigo-800 text-2xl">⇄</button>
    </div>

    <!-- All rates vs selected -->
    <div>
      <p class="label mb-2">Convert <span id="cc-base-label">100 USD</span> to all major currencies</p>
      <div id="cc-all" class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm max-h-72 overflow-y-auto"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is the mid-market rate?", a: "The mid-market rate (also called interbank rate or spot rate) is the midpoint between buy and sell prices on the global currency market. It's the 'real' exchange rate. Banks, credit cards, and exchange services add a spread or fee on top of this rate — typically 1–5% for consumers." },
        { q: "What is the best way to exchange currency for travel?", a: "Generally: (1) Use a no-foreign-transaction-fee credit card — typically gets mid-market rate + 0–1%. (2) Withdraw local currency from ATMs abroad — usually better than airport kiosks. (3) Avoid airport and hotel exchange counters — worst rates. (4) Dynamic currency conversion (paying in your home currency abroad) always charges more — decline it." },
        { q: "Why do exchange rates change?", a: "Currency values fluctuate based on interest rates, inflation, trade balances, political stability, and market sentiment. Central bank decisions (like rate hikes by the Fed or ECB) can cause large movements. For major pairs like EUR/USD, the rate changes continuously during market hours." },
        { q: "What are the most traded currency pairs?", a: "EUR/USD is the most traded (accounting for ~28% of daily forex volume). Next: USD/JPY, GBP/USD, AUD/USD, USD/CHF, USD/CAD. These 'major pairs' all involve USD. Pairs not involving USD are called 'cross pairs': EUR/GBP, EUR/JPY, GBP/JPY. The daily global forex market trades ~$7.5 trillion." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  // Approximate rates vs USD (updated periodically — not live)
  const RATES: Record<string, { name: string; symbol: string; rate: number }> = {
    USD: { name: 'US Dollar', symbol: '$', rate: 1 },
    EUR: { name: 'Euro', symbol: '€', rate: 0.92 },
    GBP: { name: 'British Pound', symbol: '£', rate: 0.79 },
    JPY: { name: 'Japanese Yen', symbol: '¥', rate: 149.5 },
    CAD: { name: 'Canadian Dollar', symbol: 'CA$', rate: 1.36 },
    AUD: { name: 'Australian Dollar', symbol: 'A$', rate: 1.53 },
    NZD: { name: 'New Zealand Dollar', symbol: 'NZ$', rate: 1.63 },
    CHF: { name: 'Swiss Franc', symbol: 'CHF', rate: 0.88 },
    CNY: { name: 'Chinese Yuan', symbol: '¥', rate: 7.24 },
    HKD: { name: 'Hong Kong Dollar', symbol: 'HK$', rate: 7.82 },
    SGD: { name: 'Singapore Dollar', symbol: 'S$', rate: 1.34 },
    INR: { name: 'Indian Rupee', symbol: '₹', rate: 83.1 },
    KRW: { name: 'South Korean Won', symbol: '₩', rate: 1330 },
    MXN: { name: 'Mexican Peso', symbol: 'MX$', rate: 17.1 },
    BRL: { name: 'Brazilian Real', symbol: 'R$', rate: 4.97 },
    ZAR: { name: 'South African Rand', symbol: 'R', rate: 18.6 },
    NOK: { name: 'Norwegian Krone', symbol: 'kr', rate: 10.6 },
    SEK: { name: 'Swedish Krona', symbol: 'kr', rate: 10.4 },
    DKK: { name: 'Danish Krone', symbol: 'kr', rate: 6.89 },
    PLN: { name: 'Polish Zloty', symbol: 'zł', rate: 4.01 },
    CZK: { name: 'Czech Koruna', symbol: 'Kč', rate: 22.8 },
    HUF: { name: 'Hungarian Forint', symbol: 'Ft', rate: 355 },
    RON: { name: 'Romanian Leu', symbol: 'lei', rate: 4.59 },
    TRY: { name: 'Turkish Lira', symbol: '₺', rate: 30.4 },
    RUB: { name: 'Russian Ruble', symbol: '₽', rate: 89 },
    SAR: { name: 'Saudi Riyal', symbol: '﷼', rate: 3.75 },
    AED: { name: 'UAE Dirham', symbol: 'د.إ', rate: 3.67 },
    THB: { name: 'Thai Baht', symbol: '฿', rate: 35.1 },
    IDR: { name: 'Indonesian Rupiah', symbol: 'Rp', rate: 15600 },
    PHP: { name: 'Philippine Peso', symbol: '₱', rate: 56.2 },
  };

  const fromSel = document.getElementById('cc-from') as HTMLSelectElement;
  const toSel = document.getElementById('cc-to') as HTMLSelectElement;
  const opts = Object.entries(RATES).map(([k,v]) => `<option value="${k}">${k} — ${v.name}</option>`).join('');
  fromSel.innerHTML = toSel.innerHTML = opts;
  fromSel.value = 'USD';
  toSel.value = 'EUR';

  function convert() {
    const amount = parseFloat((document.getElementById('cc-amount') as HTMLInputElement).value) || 0;
    const from = fromSel.value;
    const to = toSel.value;
    const amountInUSD = amount / RATES[from].rate;
    const result = amountInUSD * RATES[to].rate;
    const fmt = result > 1000 ? result.toFixed(0) : result.toFixed(2);
    document.getElementById('cc-result')!.textContent = `${RATES[to].symbol}${parseFloat(fmt).toLocaleString()} ${to}`;
    document.getElementById('cc-base-label')!.textContent = `${amount.toLocaleString()} ${from}`;

    document.getElementById('cc-all')!.innerHTML = Object.entries(RATES)
      .filter(([k]) => k !== from)
      .map(([k, v]) => {
        const val = (amountInUSD * v.rate);
        const display = val >= 10000 ? Math.round(val).toLocaleString() : val < 1 ? val.toFixed(4) : val.toFixed(2);
        return `<div class="flex justify-between items-center bg-gray-50 border border-gray-100 rounded-lg px-3 py-2">
          <div>
            <span class="font-mono font-semibold text-gray-800">${k}</span>
            <span class="text-xs text-gray-400 ml-1">${v.name}</span>
          </div>
          <span class="font-mono text-gray-700">${v.symbol}${display}</span>
        </div>`;
      }).join('');
  }

  document.getElementById('cc-swap')?.addEventListener('click', () => {
    const t = fromSel.value;
    fromSel.value = toSel.value;
    toSel.value = t;
    convert();
  });

  ['cc-amount','cc-from','cc-to'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', convert)
  );

  convert();
</script>
