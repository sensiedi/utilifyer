---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Mortgage Payoff Calculator"
  description="Calculate how extra payments can help you pay off your mortgage faster and save thousands in interest. See your payoff date."
  slug="mortgage-payoff-calculator"
  category="Real Estate"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Mortgage Payoff Calculator</h1>
  <p class="text-gray-500 mb-8">See how extra payments save interest and accelerate your payoff date.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Loan Balance</label>
        <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
        <input id="mp-balance" type="number" value="280000" class="input-field pl-7" /></div>
      </div>
      <div>
        <label class="label">Interest Rate (%)</label>
        <div class="relative">
        <input id="mp-rate" type="number" value="6.5" step="0.1" class="input-field pr-7" />
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
      </div>
      <div>
        <label class="label">Remaining Term</label>
        <select id="mp-term" class="input-field">
          {[30,25,20,15,10].map(y => <option value={y} selected={y===30}>{y} years</option>)}
        </select>
      </div>
      <div>
        <label class="label">Extra Monthly Payment</label>
        <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
        <input id="mp-extra" type="number" value="200" class="input-field pl-7" /></div>
      </div>
    </div>

    <div id="mp-results" class="hidden space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 text-center">
          <div class="text-xs text-gray-500 mb-1">Regular Payment</div>
          <div id="reg-pmt" class="text-xl font-bold text-gray-900 font-mono"></div>
        </div>
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-center">
          <div class="text-xs text-indigo-500 mb-1">New Payment</div>
          <div id="new-pmt-mp" class="text-xl font-bold text-indigo-800 font-mono"></div>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
          <div class="text-xs text-green-600 mb-1">Interest Saved</div>
          <div id="interest-saved-mp" class="text-xl font-bold text-green-800 font-mono"></div>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
          <div class="text-xs text-green-600 mb-1">Time Saved</div>
          <div id="time-saved" class="text-xl font-bold text-green-800 font-mono"></div>
        </div>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-2 text-sm">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-gray-400 uppercase mb-1">Without Extra Payment</p>
            <div class="flex justify-between"><span class="text-gray-600">Payoff date</span><span id="orig-payoff" class="font-mono text-gray-900"></span></div>
            <div class="flex justify-between"><span class="text-gray-600">Total interest</span><span id="orig-interest" class="font-mono text-gray-900"></span></div>
            <div class="flex justify-between font-bold"><span>Total paid</span><span id="orig-total" class="font-mono"></span></div>
          </div>
          <div>
            <p class="text-xs text-gray-400 uppercase mb-1">With Extra Payment</p>
            <div class="flex justify-between"><span class="text-gray-600">Payoff date</span><span id="new-payoff" class="font-mono text-indigo-700 font-semibold"></span></div>
            <div class="flex justify-between"><span class="text-gray-600">Total interest</span><span id="new-interest" class="font-mono text-gray-900"></span></div>
            <div class="flex justify-between font-bold"><span>Total paid</span><span id="new-total" class="font-mono"></span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How much interest does an extra $100/month save?", a: "On a 30-year $300,000 mortgage at 6.5%, an extra $100/month saves roughly $30,000–50,000 in interest and cuts ~4–5 years off the loan. The earlier in the loan you start paying extra, the greater the savings because interest is front-loaded." },
        { q: "Should I pay extra on my mortgage or invest?", a: "If your mortgage rate is 6.5% and you can consistently earn 7–10% in the stock market, investing may come out ahead mathematically. However, paying off debt is risk-free and emotionally valuable. Many financial experts suggest doing both: invest enough to get any 401k match, then split extra cash between investments and mortgage." },
        { q: "How should I apply extra mortgage payments?", a: "Always specify to your lender that extra payments should apply to principal, not interest or future payments. Some servicers apply extra amounts to advance your next payment date, which doesn't reduce interest as efficiently as principal reduction." },
        { q: "What is a bi-weekly mortgage payment?", a: "Instead of 12 monthly payments, you make 26 bi-weekly half-payments — equivalent to 13 full payments per year. The extra payment reduces principal and can cut 4–6 years off a 30-year mortgage without feeling like a large sacrifice." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

  function amortize(balance: number, monthlyRate: number, extraMonthly: number): { months: number; totalInterest: number } {
    let bal = balance;
    let totalInterest = 0;
    let months = 0;
    while (bal > 0 && months < 1200) {
      const interest = bal * monthlyRate;
      totalInterest += interest;
      const principal = Math.min(bal, extraMonthly - interest);
      bal -= principal;
      months++;
    }
    return { months, totalInterest };
  }

  function payoffDate(months: number): string {
    const d = new Date();
    d.setMonth(d.getMonth() + months);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  }

  function fmtMonths(m: number): string {
    const yr = Math.floor(m / 12);
    const mo = m % 12;
    return yr > 0 ? `${yr}y ${mo}m` : `${mo}mo`;
  }

  function calculate() {
    const balance = parseFloat((document.getElementById('mp-balance') as HTMLInputElement).value) || 0;
    const rate = parseFloat((document.getElementById('mp-rate') as HTMLInputElement).value) / 100 / 12;
    const term = parseInt((document.getElementById('mp-term') as HTMLSelectElement).value) * 12;
    const extra = parseFloat((document.getElementById('mp-extra') as HTMLInputElement).value) || 0;

    const regPmt = rate > 0
      ? balance * (rate * Math.pow(1 + rate, term)) / (Math.pow(1 + rate, term) - 1)
      : balance / term;

    const orig = amortize(balance, rate, regPmt);
    const withExtra = amortize(balance, rate, regPmt + extra);
    const monthsSaved = orig.months - withExtra.months;
    const interestSaved = orig.totalInterest - withExtra.totalInterest;

    document.getElementById('reg-pmt')!.textContent = fmt(regPmt) + '/mo';
    document.getElementById('new-pmt-mp')!.textContent = fmt(regPmt + extra) + '/mo';
    document.getElementById('interest-saved-mp')!.textContent = fmt(interestSaved);
    document.getElementById('time-saved')!.textContent = fmtMonths(monthsSaved);

    document.getElementById('orig-payoff')!.textContent = payoffDate(orig.months);
    document.getElementById('orig-interest')!.textContent = fmt(orig.totalInterest);
    document.getElementById('orig-total')!.textContent = fmt(balance + orig.totalInterest);
    document.getElementById('new-payoff')!.textContent = payoffDate(withExtra.months);
    document.getElementById('new-interest')!.textContent = fmt(withExtra.totalInterest);
    document.getElementById('new-total')!.textContent = fmt(balance + withExtra.totalInterest);

    document.getElementById('mp-results')!.classList.remove('hidden');
  }

  ['mp-balance','mp-rate','mp-term','mp-extra'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', calculate)
  );
  calculate();
</script>
