  let activeRegion = 'All';

  function showCountry(c: Country) {
    document.getElementById('ci-flag')!.textContent = c.flag;
    document.getElementById('ci-name')!.textContent = c.name;
    document.getElementById('ci-region')!.textContent = c.region;
    document.getElementById('ci-facts')!.innerHTML = [
      { label: 'Capital', value: c.capital },
      { label: 'Population', value: c.population },
      { label: 'Area', value: c.area },
      { label: 'Currency', value: `${c.currency} (${c.currencyCode})` },
      { label: 'Calling Code', value: c.callingCode },
      { label: 'Languages', value: c.languages },
      { label: 'Timezone', value: c.timezone },
      { label: 'Internet Domain', value: c.domain },
    ].map(({ label, value }) =>
      `<div class="bg-white border border-gray-200 rounded-lg px-3 py-2">
        <div class="text-xs text-gray-400 mb-0.5">${label}</div>
        <div class="text-sm font-medium text-gray-800">${value}</div>
      </div>`
    ).join('');
    document.getElementById('ci-result')!.classList.remove('hidden');
    document.getElementById('ci-suggestions')!.classList.add('hidden');
  }

  function renderList(region: string) {
    const filtered = region === 'All' ? COUNTRIES : COUNTRIES.filter(c => c.region === region);
    document.getElementById('ci-list')!.innerHTML = filtered.map(c =>
      `<button class="ci-country-btn flex items-center gap-2 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50 transition-colors text-left" data-name="${c.name}">
        <span class="text-lg">${c.flag}</span>
        <span class="text-sm font-medium text-gray-800 truncate">${c.name}</span>
      </button>`
    ).join('');
    document.querySelectorAll('.ci-country-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const country = COUNTRIES.find(c => c.name === (btn as HTMLElement).dataset.name);
        if (country) showCountry(country);
      });
    });
  }

  document.querySelectorAll('.ci-region-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeRegion = (btn as HTMLElement).dataset.region || 'All';
      document.querySelectorAll('.ci-region-btn').forEach(b => {
        b.classList.toggle('bg-indigo-50', (b as HTMLElement).dataset.region === activeRegion);
        b.classList.toggle('border-indigo-300', (b as HTMLElement).dataset.region === activeRegion);
        b.classList.toggle('text-indigo-700', (b as HTMLElement).dataset.region === activeRegion);
      });
      renderList(activeRegion);
    });
  });

  const searchEl = document.getElementById('ci-search') as HTMLInputElement;
  const suggestEl = document.getElementById('ci-suggestions')!;

  searchEl.addEventListener('input', () => {
    const q = searchEl.value.toLowerCase().trim();
    if (!q) { suggestEl.classList.add('hidden'); return; }
    const matches = COUNTRIES.filter(c => c.name.toLowerCase().includes(q)).slice(0, 8);
    if (!matches.length) { suggestEl.classList.add('hidden'); return; }
    suggestEl.innerHTML = matches.map(c =>
      `<button class="ci-suggest w-full flex items-center gap-2 px-4 py-2 hover:bg-indigo-50 text-left" data-name="${c.name}">
        <span>${c.flag}</span><span class="text-sm text-gray-800">${c.name}</span>
      </button>`
    ).join('');
    suggestEl.classList.remove('hidden');
    suggestEl.querySelectorAll('.ci-suggest').forEach(btn => {
      btn.addEventListener('click', () => {
        const country = COUNTRIES.find(c => c.name === (btn as HTMLElement).dataset.name);
        if (country) { showCountry(country); searchEl.value = country.name; }
      });
    });
  });

  document.addEventListener('click', (e) => {
    if (!searchEl.contains(e.target as Node) && !suggestEl.contains(e.target as Node)) {
      suggestEl.classList.add('hidden');
    }
  });

  renderList('All');
  showCountry(COUNTRIES.find(c => c.name === 'United States')!);
</script>
