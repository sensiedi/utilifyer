---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Rent vs Buy Calculator"
  description="Compare the true cost of renting vs buying a home over time. Factors in appreciation, equity, opportunity cost, and all hidden costs."
  slug="rent-vs-buy-calculator"
  category="Real Estate"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Rent vs Buy Calculator</h1>
  <p class="text-gray-500 mb-8">Compare the true long-term cost of renting versus buying a home.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Buying -->
      <div class="space-y-3">
        <h2 class="text-base font-semibold text-indigo-700 border-b border-indigo-100 pb-2">Buying</h2>
        <div>
          <label class="label">Home Price</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="home-price" type="number" value="350000" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Down Payment (%)</label>
          <div class="relative">
          <input id="down-pct" type="number" value="20" step="1" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Mortgage Rate (%)</label>
          <div class="relative">
          <input id="mortgage-rate" type="number" value="6.5" step="0.1" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Annual Home Appreciation (%)</label>
          <div class="relative">
          <input id="appreciation" type="number" value="3" step="0.5" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Annual Property Tax (%)</label>
          <div class="relative">
          <input id="prop-tax" type="number" value="1.1" step="0.1" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Annual Maintenance (%)</label>
          <div class="relative">
          <input id="maintenance" type="number" value="1" step="0.25" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
      </div>

      <!-- Renting -->
      <div class="space-y-3">
        <h2 class="text-base font-semibold text-green-700 border-b border-green-100 pb-2">Renting</h2>
        <div>
          <label class="label">Monthly Rent</label>
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
          <input id="rent" type="number" value="1800" class="input-field pl-7" /></div>
        </div>
        <div>
          <label class="label">Annual Rent Increase (%)</label>
          <div class="relative">
          <input id="rent-increase" type="number" value="3" step="0.5" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Investment Return on Down Payment (%)</label>
          <div class="relative">
          <input id="invest-return" type="number" value="7" step="0.5" class="input-field pr-7" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">%</span></div>
        </div>
        <div>
          <label class="label">Time Horizon (years)</label>
          <select id="years" class="input-field">
            {[3,5,7,10,15,20,30].map(y => <option value={y} selected={y===10}>{y} years</option>)}
          </select>
        </div>
      </div>
    </div>

    <div id="rvb-results" class="hidden space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-indigo-50 border border-indigo-200 rounded-2xl p-5 text-center">
          <div class="text-xs text-indigo-600 uppercase tracking-wide mb-1">Total Cost to Buy</div>
          <div id="total-buy" class="text-2xl font-bold text-indigo-800 font-mono"></div>
          <div class="text-xs text-indigo-400 mt-0.5">net of equity gained</div>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-2xl p-5 text-center">
          <div class="text-xs text-green-600 uppercase tracking-wide mb-1">Total Cost to Rent</div>
          <div id="total-rent" class="text-2xl font-bold text-green-800 font-mono"></div>
          <div class="text-xs text-green-400 mt-0.5">net of investment gains</div>
        </div>
        <div id="verdict-box" class="rounded-2xl p-5 text-center">
          <div class="text-xs uppercase tracking-wide mb-1 font-semibold" id="verdict-label"></div>
          <div id="verdict" class="text-2xl font-bold font-mono"></div>
          <div class="text-xs mt-0.5" id="verdict-sub"></div>
        </div>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
        <p class="text-sm font-semibold text-gray-700 mb-3">Breakdown after <span id="years-label"></span></p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm" id="breakdown"></div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "Is buying always better than renting long-term?", a: "Not always. Buying builds equity and hedges against rent increases, but comes with high transaction costs (5–8% to buy and sell). If you stay fewer than 5–7 years, renting is often cheaper. The break-even point depends on your local market, interest rate, and how rent compares to mortgage costs." },
        { q: "What is opportunity cost in rent vs buy?", a: "If you buy, you tie up your down payment in a home. The opportunity cost is the investment returns you give up by not investing that money in stocks or bonds. This calculator estimates what your down payment would grow to if invested at your assumed return rate instead." },
        { q: "What hidden costs does buying have?", a: "Closing costs (2–5%), property taxes (0.5–2.5%/year), homeowner's insurance ($1,000–3,000/year), maintenance and repairs (1–2%/year), HOA fees, and eventual selling costs (5–6% agent commissions). These can add $10,000–30,000/year on a $400K home." },
        { q: "How does home appreciation affect the calculation?", a: "Home appreciation builds equity that offsets costs. Historically, US homes appreciate about 3–4% annually on average (roughly in line with inflation). However, appreciation varies enormously by location and time period. Never assume past appreciation will continue." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + Math.abs(Math.round(n)).toLocaleString();

  function calculate() {
    const price = parseFloat((document.getElementById('home-price') as HTMLInputElement).value) || 0;
    const downPct = parseFloat((document.getElementById('down-pct') as HTMLInputElement).value) / 100;
    const mortRate = parseFloat((document.getElementById('mortgage-rate') as HTMLInputElement).value) / 100;
    const appr = parseFloat((document.getElementById('appreciation') as HTMLInputElement).value) / 100;
    const propTax = parseFloat((document.getElementById('prop-tax') as HTMLInputElement).value) / 100;
    const maint = parseFloat((document.getElementById('maintenance') as HTMLInputElement).value) / 100;
    const rent = parseFloat((document.getElementById('rent') as HTMLInputElement).value) || 0;
    const rentInc = parseFloat((document.getElementById('rent-increase') as HTMLInputElement).value) / 100;
    const investRet = parseFloat((document.getElementById('invest-return') as HTMLInputElement).value) / 100;
    const years = parseInt((document.getElementById('years') as HTMLSelectElement).value);

    const downAmt = price * downPct;
    const loanAmt = price - downAmt;
    const monthlyRate = mortRate / 12;
    const n = 30 * 12;
    const monthlyPI = monthlyRate > 0
      ? loanAmt * (monthlyRate * Math.pow(1 + monthlyRate, n)) / (Math.pow(1 + monthlyRate, n) - 1)
      : loanAmt / n;

    let totalBuyCost = downAmt; // closing costs approx
    let totalRentCost = 0;
    let currentRent = rent;
    let homeValue = price;
    let balance = loanAmt;
    let investedDown = downAmt;

    for (let y = 1; y <= years; y++) {
      // Buying costs this year
      totalBuyCost += monthlyPI * 12 + homeValue * propTax + homeValue * maint;
      // Pay down balance
      for (let m = 0; m < 12; m++) {
        const interest = balance * monthlyRate;
        const principal = monthlyPI - interest;
        balance = Math.max(0, balance - principal);
      }
      homeValue *= (1 + appr);

      // Renting costs this year
      totalRentCost += currentRent * 12;
      currentRent *= (1 + rentInc);

      // Investment grows
      investedDown *= (1 + investRet);
    }

    const equity = homeValue - balance;
    const netBuyCost = totalBuyCost - equity + price * 0.06; // selling costs 6%
    const netRentCost = totalRentCost - (investedDown - downAmt);

    const diff = Math.abs(netBuyCost - netRentCost);
    const buyBetter = netBuyCost < netRentCost;

    document.getElementById('total-buy')!.textContent = fmt(netBuyCost);
    document.getElementById('total-rent')!.textContent = fmt(netRentCost);
    document.getElementById('years-label')!.textContent = years + ' years';

    const verdictBox = document.getElementById('verdict-box')!;
    verdictBox.className = `rounded-2xl p-5 text-center ${buyBetter ? 'bg-indigo-50 border border-indigo-200' : 'bg-green-50 border border-green-200'}`;
    document.getElementById('verdict-label')!.textContent = buyBetter ? 'Buying saves' : 'Renting saves';
    document.getElementById('verdict-label')!.className = `text-xs uppercase tracking-wide mb-1 font-semibold ${buyBetter ? 'text-indigo-600' : 'text-green-600'}`;
    document.getElementById('verdict')!.textContent = fmt(diff);
    document.getElementById('verdict')!.className = `text-2xl font-bold font-mono ${buyBetter ? 'text-indigo-800' : 'text-green-800'}`;
    document.getElementById('verdict-sub')!.textContent = `over ${years} years`;
    document.getElementById('verdict-sub')!.className = `text-xs mt-0.5 ${buyBetter ? 'text-indigo-400' : 'text-green-400'}`;

    document.getElementById('breakdown')!.innerHTML = [
      ['Home Value', fmt(homeValue)],
      ['Equity Built', fmt(equity)],
      ['Invested Down Payment', fmt(investedDown)],
      ['Opportunity Cost', fmt(investedDown - downAmt)],
    ].map(([l, v]) =>
      `<div class="bg-white border border-gray-100 rounded-xl p-3">
        <div class="text-xs text-gray-400 mb-0.5">${l}</div>
        <div class="font-mono font-semibold text-gray-900">${v}</div>
      </div>`
    ).join('');

    document.getElementById('rvb-results')!.classList.remove('hidden');
  }

  ['home-price','down-pct','mortgage-rate','appreciation','prop-tax','maintenance','rent','rent-increase','invest-return','years'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', calculate)
  );
  calculate();
</script>
