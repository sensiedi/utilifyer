---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Magic 8-Ball"
  description="Ask the Magic 8-Ball any yes/no question and receive a mystical answer. The classic fortune-telling toy, now digital. Shake for wisdom!"
  slug="magic-8-ball"
  category="Random & Fun"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Magic 8-Ball</h1>
  <p class="text-gray-500 mb-8">Ask a question and reveal your fate.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div>
      <label class="label">Your question</label>
      <input id="m8-question" type="text" class="input-field" placeholder="Will I get the promotion?" />
    </div>

    <button id="m8-ask" class="btn-primary w-full text-lg py-3">Ask the 8-Ball</button>

    <!-- 8-Ball visual -->
    <div class="flex flex-col items-center gap-4 py-4">
      <div id="m8-ball" class="w-48 h-48 rounded-full bg-gray-900 flex items-center justify-center shadow-2xl cursor-pointer select-none transition-transform hover:scale-105">
        <div id="m8-inner" class="w-28 h-28 rounded-full bg-gray-800 flex items-center justify-center border-2 border-gray-700">
          <div id="m8-triangle" class="w-20 h-20 flex items-center justify-center">
            <!-- Triangle SVG -->
            <svg viewBox="0 0 80 80" class="w-20 h-20">
              <polygon points="40,8 72,68 8,68" fill="#1e3a8a" opacity="0.8"/>
              <text id="m8-text" x="40" y="52" text-anchor="middle" fill="white" font-size="8" font-weight="bold" font-family="Arial">8</text>
            </svg>
          </div>
        </div>
      </div>
      <div id="m8-answer" class="hidden text-center">
        <p id="m8-response" class="text-xl font-bold text-gray-900"></p>
        <p id="m8-category" class="text-xs mt-1"></p>
      </div>
    </div>

    <!-- Answer history -->
    <div id="m8-history" class="space-y-1.5"></div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What are all the Magic 8-Ball answers?", a: "The original Magic 8-Ball has 20 answers: 10 positive (It is certain, It is decidedly so, Without a doubt, Yes definitely, You may rely on it, As I see it yes, Most likely, Outlook good, Yes, Signs point to yes), 5 neutral (Reply hazy try again, Ask again later, Better not tell you now, Cannot predict now, Concentrate and ask again), and 5 negative (Don't count on it, My reply is no, My sources say no, Outlook not so good, Very doubtful)." },
        { q: "Who invented the Magic 8-Ball?", a: "The Magic 8-Ball was invented by Abe Bookman of Alabe Crafts (Cincinnati, Ohio) in 1950. It was inspired by a spirit-writing device used by his mother's psychic friend. The original was called a 'Syco-Seer'. Mattel acquired the brand and the Magic 8-Ball became an iconic 1950s–60s toy. It's since sold over 1 million units per year and has appeared in countless movies and TV shows." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  interface Answer { text: string; type: 'positive' | 'neutral' | 'negative' }

  const ANSWERS: Answer[] = [
    { text: 'It is certain', type: 'positive' },
    { text: 'It is decidedly so', type: 'positive' },
    { text: 'Without a doubt', type: 'positive' },
    { text: 'Yes, definitely', type: 'positive' },
    { text: 'You may rely on it', type: 'positive' },
    { text: 'As I see it, yes', type: 'positive' },
    { text: 'Most likely', type: 'positive' },
    { text: 'Outlook good', type: 'positive' },
    { text: 'Yes', type: 'positive' },
    { text: 'Signs point to yes', type: 'positive' },
    { text: 'Reply hazy, try again', type: 'neutral' },
    { text: 'Ask again later', type: 'neutral' },
    { text: 'Better not tell you now', type: 'neutral' },
    { text: 'Cannot predict now', type: 'neutral' },
    { text: 'Concentrate and ask again', type: 'neutral' },
    { text: "Don't count on it", type: 'negative' },
    { text: 'My reply is no', type: 'negative' },
    { text: 'My sources say no', type: 'negative' },
    { text: 'Outlook not so good', type: 'negative' },
    { text: 'Very doubtful', type: 'negative' },
  ];

  const history: {q: string; a: string; type: string}[] = [];

  function ask() {
    const question = (document.getElementById('m8-question') as HTMLInputElement).value.trim();
    const answer = ANSWERS[Math.floor(Math.random() * ANSWERS.length)];

    const textEl = document.getElementById('m8-text')!;
    const responseEl = document.getElementById('m8-response')!;
    const categoryEl = document.getElementById('m8-category')!;
    const answerEl = document.getElementById('m8-answer')!;

    // Show answer in triangle
    textEl.textContent = answer.text.length > 20 ? answer.text.slice(0, 18) + '…' : answer.text;
    textEl.setAttribute('font-size', answer.text.length > 14 ? '6' : '7');

    const colorMap = { positive: '#22c55e', neutral: '#f59e0b', negative: '#ef4444' };
    const labelMap = { positive: '✅ Positive outlook', neutral: '🟡 Uncertain', negative: '❌ Negative outlook' };
    responseEl.textContent = answer.text;
    responseEl.style.color = colorMap[answer.type];
    categoryEl.textContent = labelMap[answer.type];
    categoryEl.className = `text-xs mt-1`;
    answerEl.classList.remove('hidden');

    if (question) {
      history.unshift({ q: question, a: answer.text, type: answer.type });
      if (history.length > 5) history.pop();
      const colorClass = { positive: 'text-green-600', neutral: 'text-yellow-600', negative: 'text-red-600' };
      document.getElementById('m8-history')!.innerHTML =
        history.length > 1
          ? `<p class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Previous questions</p>` +
            history.slice(1).map(h =>
              `<div class="flex justify-between items-start text-xs bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 gap-2">
                <span class="text-gray-600 truncate flex-1">${h.q}</span>
                <span class="font-medium ${colorClass[h.type as keyof typeof colorClass]} shrink-0">${h.a}</span>
              </div>`
            ).join('')
          : '';
    }
  }

  document.getElementById('m8-ask')!.addEventListener('click', ask);
  document.getElementById('m8-ball')!.addEventListener('click', ask);
  document.getElementById('m8-question')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') ask();
  });
</script>
