---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Mortgage Calculator"
  description="Calculate your monthly mortgage payment, total interest paid, and view a full amortization schedule. Supports extra payments."
  slug="mortgage-calculator"
  category="Finance"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Mortgage Calculator</h1>
  <p class="text-gray-500 mb-8">Calculate your monthly payment and total cost of a home loan.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Home Price ($)</label>
        <input id="home-price" type="number" value="400000" class="input-field" />
      </div>
      <div>
        <label class="label">Down Payment ($)</label>
        <input id="down-payment" type="number" value="80000" class="input-field" />
      </div>
      <div>
        <label class="label">Loan Term (years)</label>
        <select id="loan-term" class="input-field">
          <option value="30" selected>30 years</option>
          <option value="20">20 years</option>
          <option value="15">15 years</option>
          <option value="10">10 years</option>
        </select>
      </div>
      <div>
        <label class="label">Annual Interest Rate (%)</label>
        <input id="interest-rate" type="number" value="6.5" step="0.01" class="input-field" />
      </div>
    </div>

    <!-- Optional extras -->
    <details class="group">
      <summary class="text-sm font-medium text-indigo-600 cursor-pointer list-none flex items-center gap-1 hover:text-indigo-800">
        <span class="group-open:rotate-90 transition-transform inline-block">▶</span>
        Add taxes, insurance & PMI (optional)
      </summary>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
        <div>
          <label class="label">Property Tax ($/yr)</label>
          <input id="prop-tax" type="number" placeholder="e.g. 4000" class="input-field" />
        </div>
        <div>
          <label class="label">Home Insurance ($/yr)</label>
          <input id="insurance" type="number" placeholder="e.g. 1200" class="input-field" />
        </div>
        <div>
          <label class="label">PMI ($/mo)</label>
          <input id="pmi" type="number" placeholder="e.g. 100" class="input-field" />
        </div>
      </div>
    </details>

    <div>
      <label class="label">Extra Monthly Payment ($) <span class="text-gray-400 font-normal">— see how much faster you pay off</span></label>
      <input id="extra-payment" type="number" placeholder="0" class="input-field" />
    </div>

    <button id="calc-btn" class="btn-primary w-full">Calculate</button>

    <div id="result" class="hidden space-y-4">
      <!-- Main monthly payment -->
      <div class="result-box">
        <p class="text-sm text-indigo-700 font-medium mb-1">Monthly Payment (P&I)</p>
        <p id="monthly-payment" class="text-4xl font-bold text-indigo-900"></p>
        <div id="total-monthly-row" class="hidden mt-2 text-sm text-indigo-700">
          Total with taxes & insurance: <span id="total-monthly" class="font-bold"></span>
        </div>
      </div>

      <!-- Summary stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
        {[
          { id: 'r-loan-amount', label: 'Loan Amount' },
          { id: 'r-total-interest', label: 'Total Interest' },
          { id: 'r-total-cost', label: 'Total Cost' },
          { id: 'r-payoff-date', label: 'Payoff Date' },
        ].map(({ id, label }) => (
          <div class="bg-white border border-indigo-100 rounded-xl p-3">
            <p id={id} class="text-lg font-bold text-indigo-700"></p>
            <p class="text-xs text-gray-500 mt-1">{label}</p>
          </div>
        ))}
      </div>

      <!-- Extra payment savings -->
      <div id="extra-savings" class="hidden bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <p class="font-semibold mb-1">💰 Extra Payment Savings</p>
        <p id="extra-savings-text"></p>
      </div>

      <!-- Pie chart breakdown -->
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-5">
        <p class="text-sm font-semibold text-gray-700 mb-4">Payment Breakdown</p>
        <div class="flex items-center gap-6">
          <canvas id="pie-chart" width="120" height="120" class="flex-shrink-0"></canvas>
          <div class="space-y-2 text-sm flex-1">
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-indigo-500 inline-block"></span>Principal</span>
              <span id="legend-principal" class="font-semibold text-gray-800"></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-rose-400 inline-block"></span>Interest</span>
              <span id="legend-interest" class="font-semibold text-gray-800"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Amortization table toggle -->
      <details class="group">
        <summary class="text-sm font-medium text-indigo-600 cursor-pointer list-none flex items-center gap-1 hover:text-indigo-800">
          <span class="group-open:rotate-90 transition-transform inline-block">▶</span>
          View full amortization schedule
        </summary>
        <div class="mt-4 overflow-x-auto rounded-xl border border-gray-200 max-h-80">
          <table class="w-full text-xs">
            <thead class="bg-gray-50 sticky top-0">
              <tr class="text-gray-500 uppercase">
                <th class="px-3 py-2 text-left">Year</th>
                <th class="px-3 py-2 text-right">Principal</th>
                <th class="px-3 py-2 text-right">Interest</th>
                <th class="px-3 py-2 text-right">Balance</th>
              </tr>
            </thead>
            <tbody id="amort-body" class="divide-y divide-gray-100"></tbody>
          </table>
        </div>
      </details>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-3">How Mortgage Payments Are Calculated</h2>
    <p class="text-sm text-gray-600 mb-2">Monthly mortgage payments use the standard amortization formula:</p>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 font-mono text-sm text-gray-700">
      M = P × [r(1+r)ⁿ] / [(1+r)ⁿ − 1]
    </div>
    <p class="text-sm text-gray-500 mt-2">Where M = monthly payment, P = principal loan amount, r = monthly interest rate, n = number of payments.</p>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is included in a monthly mortgage payment?", a: "A basic mortgage payment covers principal and interest (P&I). You can also include property taxes, homeowner's insurance, and PMI (private mortgage insurance if your down payment is less than 20%) using the optional fields above." },
        { q: "How does a larger down payment affect my payment?", a: "A larger down payment reduces your loan amount, which lowers both your monthly payment and total interest paid. Putting down 20% also eliminates the need for PMI." },
        { q: "What is PMI?", a: "PMI (Private Mortgage Insurance) is required by most lenders when your down payment is less than 20% of the home price. It typically costs 0.5%–1.5% of the loan amount per year." },
        { q: "How much does an extra monthly payment save?", a: "Even small extra payments dramatically reduce your total interest paid and shorten your loan term. Use the 'Extra Monthly Payment' field to see your specific savings." },
        { q: "Should I choose a 15 or 30 year mortgage?", a: "A 15-year mortgage has higher monthly payments but significantly less total interest paid. A 30-year mortgage has lower monthly payments giving more flexibility. The best choice depends on your monthly budget and financial goals." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const fmt = (n: number) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  function calculate() {
    const homePrice = parseFloat($('home-price').value) || 0;
    const downPayment = parseFloat($('down-payment').value) || 0;
    const termYears = parseInt(($('loan-term') as any as HTMLSelectElement).value);
    const annualRate = parseFloat($('interest-rate').value) || 0;
    const propTax = parseFloat($('prop-tax').value) || 0;
    const insurance = parseFloat($('insurance').value) || 0;
    const pmi = parseFloat($('pmi').value) || 0;
    const extraPayment = parseFloat($('extra-payment').value) || 0;

    const principal = homePrice - downPayment;
    if (principal <= 0 || annualRate <= 0) return;

    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    const basePayment = principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

    // Total with extras
    const totalMonthly = basePayment + propTax / 12 + insurance / 12 + pmi;
    const totalInterest = basePayment * n - principal;
    const totalCost = principal + totalInterest;

    // Payoff date
    const payoffDate = new Date();
    payoffDate.setMonth(payoffDate.getMonth() + n);
    const payoffStr = payoffDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

    $('monthly-payment').textContent = fmt(basePayment);
    $('r-loan-amount').textContent = fmt(principal);
    $('r-total-interest').textContent = fmt(totalInterest);
    $('r-total-cost').textContent = fmt(totalCost);
    $('r-payoff-date').textContent = payoffStr;
    $('legend-principal').textContent = fmt(principal);
    $('legend-interest').textContent = fmt(totalInterest);

    if (propTax || insurance || pmi) {
      $('total-monthly').textContent = fmt(totalMonthly);
      document.getElementById('total-monthly-row')!.classList.remove('hidden');
    } else {
      document.getElementById('total-monthly-row')!.classList.add('hidden');
    }

    // Extra payment savings
    if (extraPayment > 0) {
      let bal = principal, month = 0, totalInt = 0;
      while (bal > 0) {
        const intPart = bal * r;
        const princPart = Math.min(basePayment + extraPayment - intPart, bal);
        bal -= princPart;
        totalInt += intPart;
        month++;
        if (month > n * 2) break;
      }
      const savedInterest = totalInterest - totalInt;
      const savedMonths = n - month;
      document.getElementById('extra-savings-text')!.textContent =
        `You save ${fmt(savedInterest)} in interest and pay off ${Math.round(savedMonths / 12 * 10) / 10} years earlier.`;
      document.getElementById('extra-savings')!.classList.remove('hidden');
    } else {
      document.getElementById('extra-savings')!.classList.add('hidden');
    }

    // Pie chart
    drawPie(principal, totalInterest);

    // Amortization schedule (yearly)
    let balance = principal;
    const rows: string[] = [];
    for (let year = 1; year <= termYears; year++) {
      let yearPrinc = 0, yearInt = 0;
      for (let m = 0; m < 12; m++) {
        const intPart = balance * r;
        const princPart = Math.min(basePayment - intPart, balance);
        yearInt += intPart;
        yearPrinc += princPart;
        balance = Math.max(balance - princPart, 0);
      }
      rows.push(`<tr class="bg-white hover:bg-gray-50">
        <td class="px-3 py-2 text-gray-700">${year}</td>
        <td class="px-3 py-2 text-right text-gray-700">${fmt(yearPrinc)}</td>
        <td class="px-3 py-2 text-right text-gray-700">${fmt(yearInt)}</td>
        <td class="px-3 py-2 text-right font-medium text-gray-800">${fmt(Math.max(balance, 0))}</td>
      </tr>`);
    }
    document.getElementById('amort-body')!.innerHTML = rows.join('');
    document.getElementById('result')!.classList.remove('hidden');
  }

  function drawPie(principal: number, interest: number) {
    const canvas = document.getElementById('pie-chart') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const total = principal + interest;
    const principalAngle = (principal / total) * 2 * Math.PI;
    const cx = 60, cy = 60, r = 55;

    ctx.clearRect(0, 0, 120, 120);
    // Interest slice
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, 0, 2 * Math.PI);
    ctx.fillStyle = '#fb7185';
    ctx.fill();
    // Principal slice
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, -Math.PI / 2, -Math.PI / 2 + principalAngle);
    ctx.fillStyle = '#6366f1';
    ctx.fill();
  }

  document.getElementById('calc-btn')?.addEventListener('click', calculate);
  calculate();
</script>
