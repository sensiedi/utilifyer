---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Speed Limit Converter"
  description="Convert between mph and km/h for driving speeds. See speed limits for major countries and how they compare to home. Essential for international driving."
  slug="speed-limit-converter"
  category="Travel & Geography"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Speed Limit Converter</h1>
  <p class="text-gray-500 mb-8">Convert between mph and km/h — essential when driving abroad.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">mph</label>
        <input id="sl-mph" type="number" value="60" min="0" max="300" class="input-field font-mono text-xl" />
      </div>
      <div>
        <label class="label">km/h</label>
        <input id="sl-kmh" type="number" value="96.6" min="0" max="500" class="input-field font-mono text-xl" />
      </div>
    </div>

    <div id="sl-context" class="bg-indigo-50 border border-indigo-200 rounded-xl p-4">
      <div id="sl-context-text" class="text-indigo-800 text-sm font-medium"></div>
    </div>

    <!-- Common speed references -->
    <div>
      <p class="label mb-2">Common Speed Limits — Click to Convert</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        {[
          { label: '20 mph', mph: 20 },
          { label: '25 mph', mph: 25 },
          { label: '30 mph', mph: 30 },
          { label: '40 mph', mph: 40 },
          { label: '50 mph', mph: 50 },
          { label: '55 mph', mph: 55 },
          { label: '60 mph', mph: 60 },
          { label: '70 mph', mph: 70 },
          { label: '30 km/h', kmh: 30 },
          { label: '50 km/h', kmh: 50 },
          { label: '80 km/h', kmh: 80 },
          { label: '100 km/h', kmh: 100 },
          { label: '110 km/h', kmh: 110 },
          { label: '120 km/h', kmh: 120 },
          { label: '130 km/h', kmh: 130 },
          { label: '140 km/h', kmh: 140 },
        ].map(({ label, mph, kmh }) => (
          <button
            class="sl-preset text-sm border border-gray-200 rounded-lg px-3 py-2 hover:border-indigo-300 hover:bg-indigo-50 transition-colors font-mono text-gray-700"
            data-mph={mph} data-kmh={kmh}
          >{label}</button>
        ))}
      </div>
    </div>

    <!-- Country speed limits table -->
    <div>
      <p class="label mb-2">Speed Limits by Country</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="bg-gray-50 text-left">
            <th class="px-3 py-2 font-medium text-gray-600">Country</th>
            <th class="px-3 py-2 font-medium text-gray-600">Urban</th>
            <th class="px-3 py-2 font-medium text-gray-600">Rural</th>
            <th class="px-3 py-2 font-medium text-gray-600">Motorway</th>
            <th class="px-3 py-2 font-medium text-gray-600">Unit</th>
          </tr></thead>
          <tbody class="divide-y divide-gray-100">
            {[
              ['USA', '25–35', '55–65', '65–80', 'mph'],
              ['Canada', '50', '80–100', '100–110', 'km/h'],
              ['UK', '30', '60', '70', 'mph'],
              ['Germany', '50', '100', 'No limit*', 'km/h'],
              ['France', '50', '80', '130', 'km/h'],
              ['Spain', '50', '90', '120', 'km/h'],
              ['Italy', '50', '90', '130', 'km/h'],
              ['Australia', '50', '100', '110', 'km/h'],
              ['Japan', '40–60', '60', '100–120', 'km/h'],
              ['Mexico', '40–60', '80–90', '110', 'km/h'],
              ['Brazil', '40–60', '100', '120', 'km/h'],
              ['UAE', '60', '100–120', '140', 'km/h'],
              ['South Africa', '60', '100', '120', 'km/h'],
              ['India', '30–50', '80', '100–120', 'km/h'],
              ['China', '30–50', '70', '120', 'km/h'],
            ].map(([country, urban, rural, mway, unit]) => (
              <tr class="hover:bg-gray-50">
                <td class="px-3 py-2 font-medium text-gray-800">{country}</td>
                <td class="px-3 py-2 font-mono text-gray-600">{urban}</td>
                <td class="px-3 py-2 font-mono text-gray-600">{rural}</td>
                <td class="px-3 py-2 font-mono text-gray-600">{mway}</td>
                <td class="px-3 py-2 text-gray-500">{unit}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="text-xs text-gray-400 mt-1 px-1">*Germany Autobahn: recommended 130 km/h; unlimited sections exist but are being reduced.</p>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How do I convert mph to km/h?", a: "Multiply mph by 1.60934 to get km/h. A quick mental shortcut: multiply by 1.6 (close enough for everyday use). For example, 60 mph × 1.6 = 96 km/h (actual: 96.56). For km/h to mph, multiply by 0.6214, or use the rough shortcut of dividing by 1.6." },
        { q: "Which countries use mph?", a: "Only three countries officially use miles per hour for road signs: the United States, the United Kingdom, and (in some contexts) Myanmar. Almost every other country uses kilometers per hour (km/h). Canada uses km/h but many Canadians think in mph due to proximity to the USA." },
        { q: "Is the German Autobahn really unlimited speed?", a: "Some sections of the German Autobahn have no statutory speed limit ('freie Fahrt'), but these sections are shrinking. About 30% of the Autobahn now has permanent limits, and more have temporary limits. The recommended (advisory) speed on unlimited sections is 130 km/h (81 mph). Driving faster than the advisory speed can affect liability in accidents." },
        { q: "What is the fastest legal speed limit in the world?", a: "The UAE has some roads with 160 km/h (99 mph) limits. Poland has some motorways at 140 km/h. Germany's unlimited Autobahn sections allow any speed. In the USA, some rural Texas highways allow 85 mph (137 km/h). The Isle of Man has no national speed limit on non-built-up roads." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const mphEl = document.getElementById('sl-mph') as HTMLInputElement;
  const kmhEl = document.getElementById('sl-kmh') as HTMLInputElement;
  let updating = false;

  function getContext(mph: number): string {
    if (mph <= 0) return '';
    if (mph < 10) return 'Walking pace in a school/hospital zone.';
    if (mph < 20) return 'Residential street — 20 mph / 30 km/h zone typical in Europe.';
    if (mph < 30) return 'Urban street — standard city speed limit in many countries (30 mph UK, 50 km/h metric).';
    if (mph < 45) return 'Secondary road or suburban arterial.';
    if (mph < 60) return 'Rural road or undivided highway.';
    if (mph < 70) return 'Freeway / motorway — typical US interstate limit.';
    if (mph < 80) return 'Motorway limit — common in Europe (120–130 km/h).';
    if (mph < 90) return 'High-speed motorway — top limit in UAE and some countries.';
    return 'Exceeds most legal speed limits. For reference only.';
  }

  function updateFromMph() {
    if (updating) return;
    updating = true;
    const mph = parseFloat(mphEl.value);
    if (!isNaN(mph)) {
      const kmh = mph * 1.60934;
      kmhEl.value = kmh.toFixed(1);
      document.getElementById('sl-context-text')!.textContent =
        `${mph} mph = ${kmh.toFixed(1)} km/h — ${getContext(mph)}`;
    }
    updating = false;
  }

  function updateFromKmh() {
    if (updating) return;
    updating = true;
    const kmh = parseFloat(kmhEl.value);
    if (!isNaN(kmh)) {
      const mph = kmh / 1.60934;
      mphEl.value = mph.toFixed(1);
      document.getElementById('sl-context-text')!.textContent =
        `${kmh} km/h = ${mph.toFixed(1)} mph — ${getContext(mph)}`;
    }
    updating = false;
  }

  mphEl.addEventListener('input', updateFromMph);
  kmhEl.addEventListener('input', updateFromKmh);

  document.querySelectorAll('.sl-preset').forEach(el => {
    el.addEventListener('click', () => {
      const mph = (el as HTMLElement).dataset.mph;
      const kmh = (el as HTMLElement).dataset.kmh;
      if (mph) { mphEl.value = mph; updateFromMph(); }
      else if (kmh) { kmhEl.value = kmh; updateFromKmh(); }
    });
  });

  updateFromMph();
</script>
