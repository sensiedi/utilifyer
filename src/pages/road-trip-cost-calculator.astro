---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Road Trip Cost Calculator"
  description="Calculate the total fuel cost for a road trip. Enter distance, fuel efficiency, and gas price to estimate total cost in MPG or L/100km."
  slug="road-trip-cost-calculator"
  category="Automotive"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Road Trip Cost Calculator</h1>
  <p class="text-gray-500 mb-8">Plan your road trip budget — calculate fuel costs, split between passengers, and compare vehicle options.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-6">

    <!-- Units -->
    <div class="flex gap-2">
      <button class="rt-unit text-sm border rounded-xl px-4 py-2 transition-colors" data-unit="imperial">Miles / MPG / USD per gallon</button>
      <button class="rt-unit text-sm border rounded-xl px-4 py-2 transition-colors" data-unit="metric">km / L/100km / price per liter</button>
    </div>

    <!-- Main inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="label" id="rt-dist-label">Total Distance (miles)</label>
        <input id="rt-dist" type="number" class="input-field" placeholder="500" min="0">
      </div>
      <div>
        <label class="label" id="rt-eff-label">Fuel Economy (MPG)</label>
        <input id="rt-eff" type="number" class="input-field" placeholder="28" min="0" step="0.1">
      </div>
      <div>
        <label class="label" id="rt-price-label">Gas Price ($/gallon)</label>
        <input id="rt-price" type="number" class="input-field" placeholder="3.50" min="0" step="0.01">
      </div>
      <div>
        <label class="label">Passengers</label>
        <input id="rt-passengers" type="number" class="input-field" placeholder="2" value="2" min="1" max="20">
      </div>
    </div>

    <button id="rt-calc" class="btn-primary w-full sm:w-auto">Calculate Trip Cost</button>

    <div id="rt-result" class="hidden space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4">
          <p class="text-3xl font-bold text-indigo-700" id="rt-total-cost"></p>
          <p class="text-xs text-gray-500 mt-1">Total Fuel Cost</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <p class="text-3xl font-bold text-green-700" id="rt-per-person"></p>
          <p class="text-xs text-gray-500 mt-1">Per Person</p>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
          <p class="text-3xl font-bold text-amber-700" id="rt-fuel-used"></p>
          <p class="text-xs text-gray-500 mt-1" id="rt-fuel-label">Gallons Used</p>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
          <p class="text-3xl font-bold text-gray-700" id="rt-cpp"></p>
          <p class="text-xs text-gray-500 mt-1" id="rt-cpp-label">Cost per Mile</p>
        </div>
      </div>
    </div>

    <!-- Compare vehicles -->
    <div class="border-t border-gray-100 pt-5">
      <p class="text-sm font-semibold text-gray-700 mb-3">Compare Vehicle Options</p>
      <p class="text-xs text-gray-500 mb-3">Using the distance and gas price you entered above.</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-xs text-gray-500 border-b border-gray-100">
              <th class="text-left py-2 pr-4">Vehicle</th>
              <th class="text-right py-2 pr-4" id="cmp-eff-header">MPG</th>
              <th class="text-right py-2">Total Fuel Cost</th>
            </tr>
          </thead>
          <tbody id="rt-compare" class="divide-y divide-gray-50 text-gray-700"></tbody>
        </table>
      </div>
    </div>

    <!-- Add stops -->
    <div class="border-t border-gray-100 pt-5">
      <p class="text-sm font-semibold text-gray-700 mb-1">Multi-Stop Trip</p>
      <p class="text-xs text-gray-500 mb-3">Add legs with different distances or gas prices (e.g., state border price changes).</p>
      <div id="rt-stops" class="space-y-2"></div>
      <button id="rt-add-stop" class="mt-2 text-sm border border-gray-200 rounded-xl px-4 py-2 hover:border-indigo-300 text-gray-600">+ Add Leg</button>
      <div id="rt-stops-total" class="hidden mt-3 bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm font-semibold text-gray-800"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How accurate is this fuel cost estimate?", a: "The estimate is accurate for steady highway driving at posted speeds. Real-world fuel use can vary 15–25% from EPA ratings based on: driving speed (fuel economy drops significantly above 65 mph — each 5 mph over costs roughly 7–14% more), AC use (+5–25% usage), load weight (more passengers = more fuel), terrain (mountains vs flat), and stop-and-go traffic. For a conservative estimate, reduce your MPG by 10–15%." },
        { q: "Does driving faster use significantly more fuel?", a: "Yes, significantly. Aerodynamic drag increases with the square of speed — doubling speed quadruples drag. The Department of Energy estimates you pay about 7–14% more per gallon for every 5 mph over 50 mph. At 75 mph, a car that gets 30 MPG at 60 mph might get only 23–25 MPG. Highway cruising at 60–65 mph is typically the sweet spot for fuel efficiency on most modern cars." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  type Unit = 'imperial' | 'metric';
  let unit: Unit = 'imperial';

  const VEHICLES_IMP = [
    { name: 'Compact sedan (e.g. Civic)', mpg: 33 },
    { name: 'Midsize sedan (e.g. Camry)', mpg: 29 },
    { name: 'Hybrid (e.g. Prius)', mpg: 57 },
    { name: 'Midsize SUV (e.g. RAV4)', mpg: 28 },
    { name: 'Full-size pickup truck', mpg: 20 },
    { name: 'Large SUV (e.g. Tahoe)', mpg: 18 },
    { name: 'Minivan', mpg: 22 },
  ];

  function updateLabels() {
    if (unit === 'imperial') {
      document.getElementById('rt-dist-label')!.textContent = 'Total Distance (miles)';
      document.getElementById('rt-eff-label')!.textContent = 'Fuel Economy (MPG)';
      document.getElementById('rt-price-label')!.textContent = 'Gas Price ($/gallon)';
      document.getElementById('rt-fuel-label')!.textContent = 'Gallons Used';
      document.getElementById('rt-cpp-label')!.textContent = 'Cost per Mile';
      document.getElementById('cmp-eff-header')!.textContent = 'MPG';
    } else {
      document.getElementById('rt-dist-label')!.textContent = 'Total Distance (km)';
      document.getElementById('rt-eff-label')!.textContent = 'Fuel Economy (L/100km)';
      document.getElementById('rt-price-label')!.textContent = 'Fuel Price ($/liter)';
      document.getElementById('rt-fuel-label')!.textContent = 'Liters Used';
      document.getElementById('rt-cpp-label')!.textContent = 'Cost per km';
      document.getElementById('cmp-eff-header')!.textContent = 'L/100km';
    }
  }

  document.querySelectorAll('.rt-unit').forEach(btn => {
    btn.addEventListener('click', () => {
      unit = (btn as HTMLElement).dataset.unit as Unit;
      document.querySelectorAll('.rt-unit').forEach(b => {
        const active = (b as HTMLElement).dataset.unit === unit;
        b.classList.toggle('border-indigo-400', active);
        b.classList.toggle('bg-indigo-50', active);
        b.classList.toggle('text-indigo-700', active);
        b.classList.toggle('border-gray-200', !active);
        b.classList.toggle('text-gray-600', !active);
      });
      updateLabels();
      document.getElementById('rt-result')!.classList.add('hidden');
    });
  });

  document.querySelectorAll('.rt-unit')[0].classList.add('border-indigo-400', 'bg-indigo-50', 'text-indigo-700');
  document.querySelectorAll('.rt-unit')[1].classList.add('border-gray-200', 'text-gray-600');

  function calcCost(dist: number, eff: number, price: number): { fuel: number; cost: number } {
    if (unit === 'imperial') {
      const fuel = dist / eff;
      return { fuel, cost: fuel * price };
    } else {
      const fuel = (eff / 100) * dist;
      return { fuel, cost: fuel * price };
    }
  }

  document.getElementById('rt-calc')!.addEventListener('click', () => {
    const dist = parseFloat((document.getElementById('rt-dist') as HTMLInputElement).value);
    const eff = parseFloat((document.getElementById('rt-eff') as HTMLInputElement).value);
    const price = parseFloat((document.getElementById('rt-price') as HTMLInputElement).value);
    const passengers = parseInt((document.getElementById('rt-passengers') as HTMLInputElement).value) || 1;

    if (isNaN(dist) || isNaN(eff) || isNaN(price) || eff <= 0) return;

    const { fuel, cost } = calcCost(dist, eff, price);
    const cpp = cost / dist;

    document.getElementById('rt-total-cost')!.textContent = `$${cost.toFixed(2)}`;
    document.getElementById('rt-per-person')!.textContent = `$${(cost / passengers).toFixed(2)}`;
    document.getElementById('rt-fuel-used')!.textContent = fuel.toFixed(1);
    document.getElementById('rt-cpp')!.textContent = `$${cpp.toFixed(3)}`;
    document.getElementById('rt-result')!.classList.remove('hidden');

    // Compare table
    const rows = VEHICLES_IMP.map(v => {
      let vEff = v.mpg;
      let displayEff: string;
      if (unit === 'metric') {
        vEff = 235.21 / v.mpg; // convert to L/100km
        displayEff = `${vEff.toFixed(1)} L/100km`;
      } else {
        displayEff = `${v.mpg} MPG`;
      }
      const { cost: vCost } = calcCost(dist, vEff, price);
      const diff = vCost - cost;
      const diffStr = diff === 0 ? '' : ` <span class="${diff > 0 ? 'text-red-500' : 'text-green-600'}">(${diff > 0 ? '+' : ''}$${diff.toFixed(2)})</span>`;
      return `<tr>
        <td class="py-2 pr-4 text-gray-700">${v.name}</td>
        <td class="py-2 pr-4 text-right font-mono text-gray-600">${displayEff}</td>
        <td class="py-2 text-right font-mono font-bold text-gray-800">$${vCost.toFixed(2)}${diffStr}</td>
      </tr>`;
    });
    document.getElementById('rt-compare')!.innerHTML = rows.join('');
  });

  // Multi-stop
  let stopCount = 0;
  document.getElementById('rt-add-stop')!.addEventListener('click', () => {
    stopCount++;
    const id = stopCount;
    const div = document.createElement('div');
    div.className = 'grid grid-cols-3 gap-2 items-end';
    div.id = `stop-${id}`;
    const distLabel = unit === 'imperial' ? 'Distance (mi)' : 'Distance (km)';
    const priceLabel = unit === 'imperial' ? 'Gas ($/gal)' : 'Fuel ($/L)';
    div.innerHTML = `
      <div><label class="label">Leg ${id} — ${distLabel}</label>
        <input type="number" class="input-field stop-dist" placeholder="200" min="0"></div>
      <div><label class="label">${priceLabel}</label>
        <input type="number" class="input-field stop-price" placeholder="3.50" min="0" step="0.01"></div>
      <div class="flex gap-2">
        <button class="btn-primary flex-1" onclick="calcStops()">Calc</button>
        <button class="border border-red-200 text-red-500 rounded-xl px-3 hover:bg-red-50" onclick="document.getElementById('stop-${id}').remove();calcStops()">✕</button>
      </div>`;
    document.getElementById('rt-stops')!.appendChild(div);
  });

  (window as any).calcStops = function() {
    const eff = parseFloat((document.getElementById('rt-eff') as HTMLInputElement).value);
    if (isNaN(eff) || eff <= 0) return;
    const passengers = parseInt((document.getElementById('rt-passengers') as HTMLInputElement).value) || 1;
    let totalCost = 0;
    let totalDist = 0;
    document.querySelectorAll('#rt-stops > div').forEach(row => {
      const d = parseFloat((row.querySelector('.stop-dist') as HTMLInputElement).value);
      const p = parseFloat((row.querySelector('.stop-price') as HTMLInputElement).value);
      if (!isNaN(d) && !isNaN(p) && eff > 0) {
        const { cost } = calcCost(d, eff, p);
        totalCost += cost;
        totalDist += d;
      }
    });
    const el = document.getElementById('rt-stops-total')!;
    el.innerHTML = `Total: ${totalDist.toFixed(0)} ${unit === 'imperial' ? 'miles' : 'km'} — $${totalCost.toFixed(2)} fuel — $${(totalCost / passengers).toFixed(2)} per person`;
    el.classList.remove('hidden');
  };
</script>
