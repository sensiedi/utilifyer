    MTL: { name: 'Montreal', lat: 45.5017, lng: -73.5673, country: 'Canada' },
    YVR: { name: 'Vancouver', lat: 49.2827, lng: -123.1207, country: 'Canada' },
    MEX: { name: 'Mexico City', lat: 19.4326, lng: -99.1332, country: 'Mexico' },
    GRU: { name: 'São Paulo', lat: -23.5505, lng: -46.6333, country: 'Brazil' },
    RIO: { name: 'Rio de Janeiro', lat: -22.9068, lng: -43.1729, country: 'Brazil' },
    BOG: { name: 'Bogotá', lat: 4.7110, lng: -74.0721, country: 'Colombia' },
    SCL: { name: 'Santiago', lat: -33.4489, lng: -70.6693, country: 'Chile' },
    EZE: { name: 'Buenos Aires', lat: -34.6037, lng: -58.3816, country: 'Argentina' },
    LHR: { name: 'London', lat: 51.5074, lng: -0.1278, country: 'UK' },
    CDG: { name: 'Paris', lat: 48.8566, lng: 2.3522, country: 'France' },
    AMS: { name: 'Amsterdam', lat: 52.3676, lng: 4.9041, country: 'Netherlands' },
    BER: { name: 'Berlin', lat: 52.5200, lng: 13.4050, country: 'Germany' },
    FRA: { name: 'Frankfurt', lat: 50.1109, lng: 8.6821, country: 'Germany' },
    MAD: { name: 'Madrid', lat: 40.4168, lng: -3.7038, country: 'Spain' },
    BCN: { name: 'Barcelona', lat: 41.3851, lng: 2.1734, country: 'Spain' },
    FCO: { name: 'Rome', lat: 41.9028, lng: 12.4964, country: 'Italy' },
    MIL: { name: 'Milan', lat: 45.4654, lng: 9.1859, country: 'Italy' },
    ZRH: { name: 'Zurich', lat: 47.3769, lng: 8.5417, country: 'Switzerland' },
    VIE: { name: 'Vienna', lat: 48.2082, lng: 16.3738, country: 'Austria' },
    WAW: { name: 'Warsaw', lat: 52.2297, lng: 21.0122, country: 'Poland' },
    STO: { name: 'Stockholm', lat: 59.3293, lng: 18.0686, country: 'Sweden' },
    OSL: { name: 'Oslo', lat: 59.9139, lng: 10.7522, country: 'Norway' },
    CPH: { name: 'Copenhagen', lat: 55.6761, lng: 12.5683, country: 'Denmark' },
    HEL: { name: 'Helsinki', lat: 60.1699, lng: 24.9384, country: 'Finland' },
    IST: { name: 'Istanbul', lat: 41.0082, lng: 28.9784, country: 'Turkey' },
    MOS: { name: 'Moscow', lat: 55.7558, lng: 37.6173, country: 'Russia' },
    ATH: { name: 'Athens', lat: 37.9838, lng: 23.7275, country: 'Greece' },
    DXB: { name: 'Dubai', lat: 25.2048, lng: 55.2708, country: 'UAE' },
    DOH: { name: 'Doha', lat: 25.2854, lng: 51.5310, country: 'Qatar' },
    RUH: { name: 'Riyadh', lat: 24.7136, lng: 46.6753, country: 'Saudi Arabia' },
    CAI: { name: 'Cairo', lat: 30.0444, lng: 31.2357, country: 'Egypt' },
    JNB: { name: 'Johannesburg', lat: -26.2041, lng: 28.0473, country: 'South Africa' },
    NBO: { name: 'Nairobi', lat: -1.2921, lng: 36.8219, country: 'Kenya' },
    LOS: { name: 'Lagos', lat: 6.5244, lng: 3.3792, country: 'Nigeria' },
    DEL: { name: 'New Delhi', lat: 28.6139, lng: 77.2090, country: 'India' },
    BOM: { name: 'Mumbai', lat: 19.0760, lng: 72.8777, country: 'India' },
    BLR: { name: 'Bangalore', lat: 12.9716, lng: 77.5946, country: 'India' },
    KHI: { name: 'Karachi', lat: 24.8607, lng: 67.0011, country: 'Pakistan' },
    DAC: { name: 'Dhaka', lat: 23.8103, lng: 90.4125, country: 'Bangladesh' },
    KUL: { name: 'Kuala Lumpur', lat: 3.1390, lng: 101.6869, country: 'Malaysia' },
    SIN: { name: 'Singapore', lat: 1.3521, lng: 103.8198, country: 'Singapore' },
    BKK: { name: 'Bangkok', lat: 13.7563, lng: 100.5018, country: 'Thailand' },
    HCM: { name: 'Ho Chi Minh City', lat: 10.8231, lng: 106.6297, country: 'Vietnam' },
    HKG: { name: 'Hong Kong', lat: 22.3193, lng: 114.1694, country: 'China' },
    PEK: { name: 'Beijing', lat: 39.9042, lng: 116.4074, country: 'China' },
    PVG: { name: 'Shanghai', lat: 31.2304, lng: 121.4737, country: 'China' },
    NRT: { name: 'Tokyo', lat: 35.6762, lng: 139.6503, country: 'Japan' },
    OSK: { name: 'Osaka', lat: 34.6937, lng: 135.5023, country: 'Japan' },
    ICN: { name: 'Seoul', lat: 37.5665, lng: 126.9780, country: 'South Korea' },
    SYD: { name: 'Sydney', lat: -33.8688, lng: 151.2093, country: 'Australia' },
    MEL: { name: 'Melbourne', lat: -37.8136, lng: 144.9631, country: 'Australia' },
    AKL: { name: 'Auckland', lat: -36.8485, lng: 174.7633, country: 'New Zealand' },
  };

  function toRad(d: number) { return d * Math.PI / 180; }
  function haversine(a: City, b: City): number {
    const R = 6371;
    const dLat = toRad(b.lat - a.lat);
    const dLng = toRad(b.lng - a.lng);
    const h = Math.sin(dLat/2)**2 + Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) * Math.sin(dLng/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(h), Math.sqrt(1 - h));
  }

  const fromSel = document.getElementById('dc-from') as HTMLSelectElement;
  const toSel = document.getElementById('dc-to') as HTMLSelectElement;
  const sorted = Object.entries(CITIES).sort((a,b) => a[1].name.localeCompare(b[1].name));
  const opts = sorted.map(([k,v]) => `<option value="${k}">${v.name}, ${v.country}</option>`).join('');
  fromSel.innerHTML = toSel.innerHTML = opts;
  fromSel.value = 'NYC';
  toSel.value = 'LHR';

  function fmtTime(h: number): string {
    const hrs = Math.floor(h);
    const min = Math.round((h - hrs) * 60);
    return min === 0 ? `${hrs}h` : `${hrs}h ${min}m`;
  }

  function calculate() {
    const from = CITIES[fromSel.value];
    const to = CITIES[toSel.value];
    if (!from || !to || fromSel.value === toSel.value) return;

    const dist = haversine(from, to);
    const mi = dist * 0.621371;
    const driveFactor = dist < 500 ? 1.3 : dist < 2000 ? 1.25 : 1.2;
    const driveKm = dist * driveFactor;
    const driveHours = driveKm / 90;

    document.getElementById('dc-km')!.textContent = Math.round(dist).toLocaleString() + ' km';
    document.getElementById('dc-mi')!.textContent = Math.round(mi).toLocaleString() + ' mi';
    document.getElementById('dc-drive-km')!.textContent = Math.round(driveKm).toLocaleString() + ' km';
    document.getElementById('dc-drive-time')!.textContent = fmtTime(driveHours);

    let context = '';
    if (dist < 200) context = 'A short drive or quick train ride.';
    else if (dist < 800) context = 'A day trip by car or a short domestic flight.';
    else if (dist < 3000) context = 'A domestic or regional flight of a few hours.';
    else if (dist < 8000) context = 'A long-haul international flight.';
    else context = 'An ultra-long-haul flight — may require a stopover.';
    document.getElementById('dc-context')!.textContent = `${from.name} → ${to.name}: ${context}`;
    document.getElementById('dc-result')!.classList.remove('hidden');

    renderClosest(fromSel.value, from);
  }

  function renderClosest(key: string, from: City) {
    document.getElementById('dc-closest-label')!.textContent = from.name;
    const sorted2 = Object.entries(CITIES)
      .filter(([k]) => k !== key)
      .map(([k, v]) => ({ k, v, d: haversine(from, v) }))
      .sort((a,b) => a.d - b.d)
      .slice(0, 6);
    document.getElementById('dc-closest')!.innerHTML = sorted2.map(({ v, d }) =>
      `<div class="flex justify-between items-center bg-gray-50 border border-gray-100 rounded-lg px-3 py-2">
        <span class="font-medium text-gray-800">${v.name}</span>
        <span class="font-mono text-xs text-gray-500">${Math.round(d).toLocaleString()} km</span>
      </div>`
    ).join('');
  }

  ['dc-from','dc-to'].forEach(id => document.getElementById(id)?.addEventListener('change', calculate));
  calculate();
</script>
