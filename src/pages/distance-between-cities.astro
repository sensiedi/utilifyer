    PHX: { name: 'Phoenix', lat: 33.4484, lng: -112.0740, country: 'USA' },
    PHI: { name: 'Philadelphia', lat: 39.9526, lng: -75.1652, country: 'USA' },
    SAN: { name: 'San Antonio', lat: 29.4241, lng: -98.4936, country: 'USA' },
    SFO: { name: 'San Francisco', lat: 37.7749, lng: -122.4194, country: 'USA' },
    SEA: { name: 'Seattle', lat: 47.6062, lng: -122.3321, country: 'USA' },
