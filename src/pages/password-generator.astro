---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Password Generator"
  description="Generate strong, random, secure passwords. Customize length, include symbols, numbers, and uppercase letters."
  slug="password-generator"
  category="Developer"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Password Generator</h1>
  <p class="text-gray-500 mb-8">Generate strong, secure, random passwords instantly.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <!-- Password display -->
    <div class="relative">
      <div id="password-display" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-4 font-mono text-lg text-gray-800 tracking-widest min-h-[60px] break-all pr-24 select-all">
        Click Generate
      </div>
      <div class="absolute right-3 top-1/2 -translate-y-1/2 flex gap-2">
        <button id="copy-btn" class="p-2 rounded-lg hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" title="Copy">
          📋
        </button>
        <button id="refresh-btn" class="p-2 rounded-lg hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" title="Regenerate">
          🔄
        </button>
      </div>
    </div>

    <!-- Strength meter -->
    <div>
      <div class="flex justify-between text-xs mb-1">
        <span class="text-gray-500">Password Strength</span>
        <span id="strength-label" class="font-semibold"></span>
      </div>
      <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
        <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
      </div>
    </div>

    <!-- Options -->
    <div>
      <label class="label">Length: <span id="length-display" class="text-indigo-600 font-bold">16</span></label>
      <input id="length-slider" type="range" min="6" max="64" value="16" class="w-full accent-indigo-600" />
      <div class="flex justify-between text-xs text-gray-400 mt-1"><span>6</span><span>64</span></div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      {[
        { id: 'opt-upper', label: 'Uppercase (A–Z)', checked: true },
        { id: 'opt-lower', label: 'Lowercase (a–z)', checked: true },
        { id: 'opt-numbers', label: 'Numbers (0–9)', checked: true },
        { id: 'opt-symbols', label: 'Symbols (!@#$…)', checked: true },
        { id: 'opt-no-ambiguous', label: 'Exclude ambiguous (0,O,l,I)', checked: false },
        { id: 'opt-no-repeat', label: 'No duplicate characters', checked: false },
      ].map(({ id, label, checked }) => (
        <label class="flex items-center gap-3 cursor-pointer select-none p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
          <input type="checkbox" id={id} checked={checked} class="w-4 h-4 accent-indigo-600" />
          <span class="text-sm text-gray-700">{label}</span>
        </label>
      ))}
    </div>

    <button id="generate-btn" class="btn-primary w-full py-3 text-base">Generate Password</button>

    <!-- Bulk generate -->
    <details class="group">
      <summary class="text-sm font-medium text-indigo-600 cursor-pointer list-none flex items-center gap-1 hover:text-indigo-800">
        <span class="group-open:rotate-90 transition-transform inline-block">▶</span>
        Generate multiple passwords
      </summary>
      <div class="mt-3 space-y-3">
        <div class="flex gap-3">
          <input id="bulk-count" type="number" value="5" min="1" max="50" class="input-field" placeholder="Count" />
          <button id="bulk-btn" class="btn-secondary flex-shrink-0">Generate</button>
        </div>
        <div id="bulk-output" class="space-y-2 max-h-64 overflow-y-auto"></div>
      </div>
    </details>
  </div>

  <!-- Tips -->
  <div class="mt-6 bg-amber-50 border border-amber-200 rounded-2xl p-5">
    <h2 class="font-semibold text-amber-800 mb-3">🔒 Password Security Tips</h2>
    <ul class="text-sm text-amber-700 space-y-1.5">
      <li>• Use a unique password for every account — never reuse passwords</li>
      <li>• Store passwords in a password manager (Bitwarden, 1Password, etc.)</li>
      <li>• Longer passwords (16+ chars) are exponentially harder to crack than short complex ones</li>
      <li>• Enable two-factor authentication (2FA) whenever possible</li>
      <li>• Passwords generated here never leave your browser — no server involved</li>
    </ul>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "Is this password generator secure?", a: "Yes. Passwords are generated using the browser's built-in crypto.getRandomValues() API and are never sent to any server. The generation happens entirely on your device." },
        { q: "How long should my password be?", a: "We recommend at least 16 characters. A 16-character password with mixed characters has trillions of possible combinations, making brute-force attacks impractical." },
        { q: "Should I use symbols in my password?", a: "Symbols increase the character set size, which exponentially increases password strength. However, length matters more — a 20-character lowercase-only password is stronger than an 8-character password with symbols." },
        { q: "What are ambiguous characters?", a: "Characters like 0 (zero) and O (letter O), or l (lowercase L) and I (uppercase i) look very similar. Excluding them makes passwords easier to read and type manually." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const CHARS = {
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lower: 'abcdefghijklmnopqrstuvwxyz',
    numbers: '0123456789',
    symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?',
    ambiguous: '0O1lI',
  };

  function getOpt(id: string) { return (document.getElementById(id) as HTMLInputElement).checked; }

  function buildCharset(): string {
    let chars = '';
    if (getOpt('opt-upper')) chars += CHARS.upper;
    if (getOpt('opt-lower')) chars += CHARS.lower;
    if (getOpt('opt-numbers')) chars += CHARS.numbers;
    if (getOpt('opt-symbols')) chars += CHARS.symbols;
    if (getOpt('opt-no-ambiguous')) CHARS.ambiguous.split('').forEach(c => { chars = chars.replace(new RegExp(c.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), ''); });
    return chars || CHARS.lower;
  }

  function generateOne(length: number): string {
    const charset = buildCharset();
    const noRepeat = getOpt('opt-no-repeat');
    const arr = new Uint32Array(length * 2);
    crypto.getRandomValues(arr);
    const used = new Set<string>();
    const result: string[] = [];
    let i = 0;
    while (result.length < length && i < arr.length) {
      const char = charset[arr[i++] % charset.length];
      if (noRepeat && used.has(char)) continue;
      used.add(char);
      result.push(char);
    }
    return result.join('').padEnd(length, charset[0]);
  }

  function measureStrength(pwd: string): { score: number; label: string; color: string } {
    let score = 0;
    if (pwd.length >= 8) score++;
    if (pwd.length >= 12) score++;
    if (pwd.length >= 16) score++;
    if (/[A-Z]/.test(pwd)) score++;
    if (/[a-z]/.test(pwd)) score++;
    if (/[0-9]/.test(pwd)) score++;
    if (/[^A-Za-z0-9]/.test(pwd)) score++;
    if (score <= 2) return { score: 20, label: 'Weak', color: 'bg-red-500' };
    if (score <= 4) return { score: 50, label: 'Fair', color: 'bg-amber-400' };
    if (score <= 5) return { score: 75, label: 'Good', color: 'bg-yellow-400' };
    return { score: 100, label: 'Strong', color: 'bg-green-500' };
  }

  function generate() {
    const length = parseInt((document.getElementById('length-slider') as HTMLInputElement).value);
    const pwd = generateOne(length);
    const display = document.getElementById('password-display')!;
    display.textContent = pwd;
    const { score, label, color } = measureStrength(pwd);
    document.getElementById('strength-bar')!.className = `h-full rounded-full transition-all duration-300 ${color}`;
    document.getElementById('strength-bar')!.style.width = score + '%';
    document.getElementById('strength-label')!.textContent = label;
    document.getElementById('strength-label')!.className = `font-semibold ${color.replace('bg-', 'text-')}`;
  }

  document.getElementById('generate-btn')?.addEventListener('click', generate);
  document.getElementById('refresh-btn')?.addEventListener('click', generate);

  document.getElementById('length-slider')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    document.getElementById('length-display')!.textContent = val;
    generate();
  });

  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const pwd = document.getElementById('password-display')!.textContent || '';
    navigator.clipboard.writeText(pwd).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = '✅';
      setTimeout(() => btn.textContent = '📋', 1500);
    });
  });

  document.getElementById('bulk-btn')?.addEventListener('click', () => {
    const count = Math.min(parseInt((document.getElementById('bulk-count') as HTMLInputElement).value) || 5, 50);
    const length = parseInt((document.getElementById('length-slider') as HTMLInputElement).value);
    const output = document.getElementById('bulk-output')!;
    output.innerHTML = Array.from({ length: count }, () => {
      const pwd = generateOne(length);
      return `<div class="flex items-center justify-between bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 gap-2">
        <span class="font-mono text-sm text-gray-800 break-all">${pwd}</span>
        <button onclick="navigator.clipboard.writeText('${pwd}')" class="text-xs text-indigo-500 hover:text-indigo-700 flex-shrink-0">Copy</button>
      </div>`;
    }).join('');
  });

  generate();
</script>
