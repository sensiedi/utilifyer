---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Flight Time Calculator"
  description="Estimate flight time between major world cities. Calculate approximate travel time based on great-circle distance and typical cruising speed."
  slug="flight-time-calculator"
  category="Travel & Geography"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Flight Time Calculator</h1>
  <p class="text-gray-500 mb-8">Estimate flight duration between major cities based on great-circle distance.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">From City</label>
        <select id="ft-from" class="input-field"></select>
      </div>
      <div>
        <label class="label">To City</label>
        <select id="ft-to" class="input-field"></select>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Aircraft Type</label>
        <select id="ft-aircraft" class="input-field">
          <option value="narrow">Narrow-body (737/A320) — 840 km/h</option>
          <option value="wide" selected>Wide-body (777/A380) — 905 km/h</option>
          <option value="regional">Regional jet (CRJ/E175) — 780 km/h</option>
          <option value="supersonic">Concorde-class — 2100 km/h</option>
        </select>
      </div>
      <div>
        <label class="label">Boarding & Taxi Time</label>
        <select id="ft-buffer" class="input-field">
          <option value="0">No buffer (air time only)</option>
          <option value="30" selected>+30 min (domestic short-haul)</option>
          <option value="45">+45 min (domestic / medium-haul)</option>
          <option value="60">+60 min (international long-haul)</option>
        </select>
      </div>
    </div>

    <div id="ft-result" class="hidden space-y-3">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-3 text-center">
          <div class="text-xs text-indigo-500 mb-0.5">Flight Time</div>
          <div id="ft-time" class="text-2xl font-bold font-mono text-indigo-900">—</div>
        </div>
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 text-center">
          <div class="text-xs text-gray-400 mb-0.5">Distance</div>
          <div id="ft-dist-km" class="text-2xl font-bold font-mono text-gray-900">—</div>
        </div>
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 text-center">
          <div class="text-xs text-gray-400 mb-0.5">Distance (mi)</div>
          <div id="ft-dist-mi" class="text-2xl font-bold font-mono text-gray-900">—</div>
        </div>
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 text-center">
          <div class="text-xs text-gray-400 mb-0.5">Total w/Buffer</div>
          <div id="ft-total" class="text-2xl font-bold font-mono text-gray-900">—</div>
        </div>
      </div>
      <div id="ft-note" class="text-sm text-gray-500 bg-amber-50 border border-amber-200 rounded-xl p-3"></div>
    </div>

    <!-- Popular routes reference -->
    <div>
      <p class="label mb-2">Popular Long-Haul Routes</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="bg-gray-50 text-left">
            <th class="px-3 py-2 font-medium text-gray-600">Route</th>
            <th class="px-3 py-2 font-medium text-gray-600">Distance</th>
            <th class="px-3 py-2 font-medium text-gray-600">Approx. Time</th>
          </tr></thead>
          <tbody class="divide-y divide-gray-100">
            {[
              ['New York → London', '5,540 km / 3,440 mi', '7h'],
              ['Los Angeles → Tokyo', '8,815 km / 5,478 mi', '11h'],
              ['London → Sydney', '16,993 km / 10,560 mi', '22h+'],
              ['New York → Los Angeles', '3,983 km / 2,475 mi', '5.5h'],
              ['Dubai → London', '5,480 km / 3,405 mi', '7h'],
              ['Singapore → London', '10,841 km / 6,737 mi', '13h'],
              ['Frankfurt → Beijing', '7,815 km / 4,856 mi', '10h'],
              ['Paris → São Paulo', '9,373 km / 5,823 mi', '11.5h'],
            ].map(([route, dist, time]) => (
              <tr class="hover:bg-gray-50">
                <td class="px-3 py-2 font-medium text-gray-800">{route}</td>
                <td class="px-3 py-2 font-mono text-gray-600">{dist}</td>
                <td class="px-3 py-2 text-gray-500">{time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How is flight time calculated?", a: "Flight time is estimated by dividing the great-circle distance (shortest path on a sphere between two points) by the aircraft's cruising speed. Real flight times vary due to jet streams, routing around restricted airspace, weather diversions, and ATC constraints. Eastbound transatlantic flights are often 30–60 min shorter than westbound due to favorable jet stream." },
        { q: "What is the great-circle route?", a: "The great-circle route is the shortest path between two points on a sphere. On a flat map (Mercator projection), this looks curved, but it's actually the shortest distance. Aircraft follow great-circle routes (or close approximations considering winds and airspace) to minimize fuel and time." },
        { q: "Why do some flights have connecting stops?", a: "Direct routes aren't always available due to aircraft range limits, bilateral air agreements, or lack of demand. The Boeing 777-200LR has a range of ~17,400 km, making routes like Auckland–Dubai possible nonstop. Older aircraft (737s) have ~5,700 km range and cannot fly transoceanic routes." },
        { q: "What is the longest commercial flight?", a: "As of 2024, Singapore Airlines SQ24 (Singapore to New York JFK) is the world's longest commercial flight at approximately 15,344 km (9,535 mi), taking about 18.5 hours westbound and 17.5 hours eastbound. It uses the Airbus A350-900ULR (Ultra Long Range)." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  interface City {
    name: string;
    lat: number;
    lng: number;
    country: string;
  }

  const CITIES: Record<string, City> = {
    NYC:  { name: 'New York (JFK)', lat: 40.6413, lng: -73.7781, country: 'USA' },
    LAX:  { name: 'Los Angeles', lat: 33.9425, lng: -118.408, country: 'USA' },
    CHI:  { name: 'Chicago (ORD)', lat: 41.9742, lng: -87.9073, country: 'USA' },
    MIA:  { name: 'Miami', lat: 25.7959, lng: -80.2870, country: 'USA' },
    SFO:  { name: 'San Francisco', lat: 37.6213, lng: -122.379, country: 'USA' },
    SEA:  { name: 'Seattle', lat: 47.4502, lng: -122.309, country: 'USA' },
    YYZ:  { name: 'Toronto', lat: 43.6777, lng: -79.6248, country: 'Canada' },
    YVR:  { name: 'Vancouver', lat: 49.1967, lng: -123.184, country: 'Canada' },
    LHR:  { name: 'London (Heathrow)', lat: 51.4700, lng: -0.4543, country: 'UK' },
    CDG:  { name: 'Paris', lat: 49.0097, lng: 2.5479, country: 'France' },
    AMS:  { name: 'Amsterdam', lat: 52.3086, lng: 4.7639, country: 'Netherlands' },
    FRA:  { name: 'Frankfurt', lat: 50.0379, lng: 8.5622, country: 'Germany' },
    MAD:  { name: 'Madrid', lat: 40.4839, lng: -3.5680, country: 'Spain' },
    FCO:  { name: 'Rome', lat: 41.8003, lng: 12.2389, country: 'Italy' },
    ZRH:  { name: 'Zurich', lat: 47.4647, lng: 8.5492, country: 'Switzerland' },
    IST:  { name: 'Istanbul', lat: 41.2608, lng: 28.7418, country: 'Turkey' },
    DXB:  { name: 'Dubai', lat: 25.2532, lng: 55.3657, country: 'UAE' },
    DOH:  { name: 'Doha', lat: 25.2731, lng: 51.6080, country: 'Qatar' },
    SIN:  { name: 'Singapore', lat: 1.3644, lng: 103.9915, country: 'Singapore' },
    HKG:  { name: 'Hong Kong', lat: 22.3080, lng: 113.9185, country: 'China' },
    NRT:  { name: 'Tokyo (Narita)', lat: 35.7647, lng: 140.3864, country: 'Japan' },
    ICN:  { name: 'Seoul', lat: 37.4602, lng: 126.4407, country: 'South Korea' },
    PEK:  { name: 'Beijing', lat: 40.0799, lng: 116.6031, country: 'China' },
    PVG:  { name: 'Shanghai', lat: 31.1443, lng: 121.8083, country: 'China' },
    BKK:  { name: 'Bangkok', lat: 13.9132, lng: 100.6067, country: 'Thailand' },
    KUL:  { name: 'Kuala Lumpur', lat: 2.7456, lng: 101.7099, country: 'Malaysia' },
    SYD:  { name: 'Sydney', lat: -33.9461, lng: 151.1772, country: 'Australia' },
    MEL:  { name: 'Melbourne', lat: -37.6690, lng: 144.8410, country: 'Australia' },
    AKL:  { name: 'Auckland', lat: -37.0082, lng: 174.7850, country: 'New Zealand' },
    JNB:  { name: 'Johannesburg', lat: -26.1367, lng: 28.2411, country: 'South Africa' },
    NBO:  { name: 'Nairobi', lat: -1.3192, lng: 36.9275, country: 'Kenya' },
    CAI:  { name: 'Cairo', lat: 30.1219, lng: 31.4056, country: 'Egypt' },
    GRU:  { name: 'São Paulo', lat: -23.4356, lng: -46.4731, country: 'Brazil' },
    BOG:  { name: 'Bogotá', lat: 4.7016, lng: -74.1469, country: 'Colombia' },
    MEX:  { name: 'Mexico City', lat: 19.4361, lng: -99.0719, country: 'Mexico' },
    DEL:  { name: 'New Delhi', lat: 28.5562, lng: 77.1000, country: 'India' },
    BOM:  { name: 'Mumbai', lat: 19.0896, lng: 72.8656, country: 'India' },
    MOS:  { name: 'Moscow', lat: 55.9726, lng: 37.4146, country: 'Russia' },
  };

  const SPEEDS: Record<string, number> = { narrow: 840, wide: 905, regional: 780, supersonic: 2100 };

  const fromSel = document.getElementById('ft-from') as HTMLSelectElement;
  const toSel = document.getElementById('ft-to') as HTMLSelectElement;
  const opts = Object.entries(CITIES).sort((a,b) => a[1].name.localeCompare(b[1].name))
    .map(([k, v]) => `<option value="${k}">${v.name}, ${v.country}</option>`).join('');
  fromSel.innerHTML = toSel.innerHTML = opts;
  fromSel.value = 'NYC';
  toSel.value = 'LHR';

  function toRad(d: number) { return d * Math.PI / 180; }

  function greatCircle(a: City, b: City): number {
    const R = 6371;
    const dLat = toRad(b.lat - a.lat);
    const dLng = toRad(b.lng - a.lng);
    const h = Math.sin(dLat/2)**2 + Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) * Math.sin(dLng/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(h), Math.sqrt(1 - h));
  }

  function fmtTime(hours: number): string {
    const h = Math.floor(hours);
    const m = Math.round((hours - h) * 60);
    return m === 0 ? `${h}h` : `${h}h ${m}m`;
  }

  function calculate() {
    const from = CITIES[fromSel.value];
    const to = CITIES[toSel.value];
    if (!from || !to || fromSel.value === toSel.value) return;

    const dist = greatCircle(from, to);
    const speed = SPEEDS[(document.getElementById('ft-aircraft') as HTMLSelectElement).value];
    const buffer = parseInt((document.getElementById('ft-buffer') as HTMLSelectElement).value);

    const airHours = dist / speed;
    const totalHours = airHours + buffer / 60;

    document.getElementById('ft-time')!.textContent = fmtTime(airHours);
    document.getElementById('ft-dist-km')!.textContent = Math.round(dist).toLocaleString() + ' km';
    document.getElementById('ft-dist-mi')!.textContent = Math.round(dist * 0.621371).toLocaleString() + ' mi';
    document.getElementById('ft-total')!.textContent = fmtTime(totalHours);

    let note = `Great-circle distance from ${from.name} to ${to.name}. `;
    if (dist > 12000) note += 'This ultra-long-haul flight may require a stopover on most aircraft types.';
    else if (dist > 8000) note += 'Long-haul route — typically flown nonstop on wide-body aircraft.';
    else if (dist > 4000) note += 'Medium to long-haul route. Actual times vary ±30 min by routing and winds.';
    else note += 'Short to medium-haul route. Actual time may vary by routing and headwinds/tailwinds.';
    document.getElementById('ft-note')!.textContent = note;
    document.getElementById('ft-result')!.classList.remove('hidden');
  }

  ['ft-from','ft-to','ft-aircraft','ft-buffer'].forEach(id =>
    document.getElementById(id)?.addEventListener('change', calculate)
  );

  calculate();
</script>
