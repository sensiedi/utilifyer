---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="CSS Border Radius Generator"
  description="Generate CSS border-radius values visually. Create circles, pills, asymmetric shapes, and custom curved corners with live preview and CSS code output."
  slug="border-radius-generator"
  category="Color & Design"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">CSS Border Radius Generator</h1>
  <p class="text-gray-500 mb-8">Create custom border-radius shapes visually with live preview.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Controls -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
            <input type="checkbox" id="br-link" checked class="accent-indigo-600" />
            Uniform (all corners equal)
          </label>
        </div>

        <div id="br-uniform" class="space-y-3">
          <div>
            <div class="flex justify-between mb-1">
              <label class="label">All Corners</label>
              <span id="br-all-val" class="text-sm font-mono text-gray-600">24px</span>
            </div>
            <input type="range" id="br-all" min="0" max="150" value="24" class="w-full" />
          </div>
        </div>

        <div id="br-individual" class="hidden space-y-3">
          {[
            { id: 'br-tl', label: 'Top Left', val: 24 },
            { id: 'br-tr', label: 'Top Right', val: 24 },
            { id: 'br-br-r', label: 'Bottom Right', val: 24 },
            { id: 'br-bl', label: 'Bottom Left', val: 24 },
          ].map(({ id, label, val }) => (
            <div>
              <div class="flex justify-between mb-1">
                <label class="label">{label}</label>
                <span id={`${id}-val`} class="text-sm font-mono text-gray-600">{val}px</span>
              </div>
              <input type="range" id={id} min="0" max="150" value={val} class="corner-slider w-full" />
            </div>
          ))}
        </div>

        <div>
          <label class="label">Unit</label>
          <div class="flex gap-2">
            {['px','%','em','rem'].map(u => (
              <button class="unit-btn text-xs border border-gray-200 rounded-lg px-3 py-1.5 hover:border-indigo-300 transition-colors" data-unit={u}>{u}</button>
            ))}
          </div>
        </div>

        <!-- Presets -->
        <div>
          <p class="label mb-2">Presets</p>
          <div class="grid grid-cols-4 gap-2">
            {[
              { name: 'None', values: [0,0,0,0] },
              { name: 'Small', values: [4,4,4,4] },
              { name: 'Medium', values: [12,12,12,12] },
              { name: 'Large', values: [24,24,24,24] },
              { name: 'XL', values: [48,48,48,48] },
              { name: 'Pill', values: [100,100,100,100] },
              { name: 'Blob 1', values: [30,70,70,30] },
              { name: 'Blob 2', values: [60,10,60,10] },
              { name: 'Chat', values: [24,24,4,24] },
              { name: 'Leaf', values: [100,0,100,0] },
              { name: 'Top', values: [50,50,0,0] },
              { name: 'Bottom', values: [0,0,50,50] },
            ].map(({ name, values }) => (
              <button class="preset-br text-xs border border-gray-200 rounded-lg px-2 py-1.5 hover:border-indigo-300 hover:bg-indigo-50 transition-colors" data-values={values.join(',')}>
                {name}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Preview -->
      <div>
        <p class="label mb-3">Preview</p>
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-8 flex items-center justify-center" style="min-height:240px">
          <div id="br-preview" class="w-40 h-40 bg-gradient-to-br from-indigo-400 to-purple-500 transition-all shadow-lg"></div>
        </div>
      </div>
    </div>

    <!-- CSS Output -->
    <div>
      <div class="flex justify-between items-center mb-2">
        <p class="label">CSS Code</p>
        <button id="br-copy" class="text-xs text-indigo-600 hover:text-indigo-800">Copy</button>
      </div>
      <pre id="br-output" class="bg-gray-900 text-green-300 rounded-xl p-4 text-sm font-mono overflow-x-auto whitespace-pre"></pre>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How does border-radius shorthand work?", a: "border-radius with 4 values sets: top-left, top-right, bottom-right, bottom-left (clockwise from top-left). With 3 values: top-left, top-right & bottom-left, bottom-right. With 2 values: top-left & bottom-right, top-right & bottom-left. With 1 value: all corners." },
        { q: "How do I create a circle?", a: "Set border-radius: 50% on an element with equal width and height. The percentage is relative to the element's dimensions. border-radius: 50% on a 100px×100px div creates a perfect circle." },
        { q: "Can I use different horizontal and vertical radii?", a: "Yes — the / syntax sets independent horizontal and vertical radii: border-radius: 50px / 25px creates an elliptical corner. The full form is: border-radius: horizontal-tl horizontal-tr horizontal-br horizontal-bl / vertical-tl vertical-tr vertical-br vertical-bl." },
        { q: "What is border-radius in em vs px?", a: "px values are absolute and don't scale with font size. em values are relative to the element's font-size — useful for components that should scale proportionally. rem is relative to the root font size. % is relative to the border-box dimensions." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  let tl = 24, tr = 24, br = 24, bl = 24;
  let unit = 'px';
  let uniform = true;

  function update() {
    const val = (v: number) => `${v}${unit}`;
    const css = (tl === tr && tr === br && br === bl)
      ? `border-radius: ${val(tl)};`
      : `border-radius: ${val(tl)} ${val(tr)} ${val(br)} ${val(bl)};`;
    document.getElementById('br-preview')!.style.borderRadius = `${tl}${unit} ${tr}${unit} ${br}${unit} ${bl}${unit}`;
    document.getElementById('br-output')!.textContent = css;

    if (uniform) {
      document.getElementById('br-all-val')!.textContent = val(tl);
    } else {
      document.getElementById('br-tl-val')!.textContent = val(tl);
      document.getElementById('br-tr-val')!.textContent = val(tr);
      document.getElementById('br-br-r-val')!.textContent = val(br);
      document.getElementById('br-bl-val')!.textContent = val(bl);
    }
  }

  document.getElementById('br-link')?.addEventListener('change', (e) => {
    uniform = (e.target as HTMLInputElement).checked;
    document.getElementById('br-uniform')!.classList.toggle('hidden', !uniform);
    document.getElementById('br-individual')!.classList.toggle('hidden', uniform);
    update();
  });

  document.getElementById('br-all')?.addEventListener('input', (e) => {
    const v = parseInt((e.target as HTMLInputElement).value);
    tl = tr = br = bl = v;
    update();
  });

  document.querySelectorAll('.corner-slider').forEach(el => {
    el.addEventListener('input', (e) => {
      const v = parseInt((e.target as HTMLInputElement).value);
      const id = (e.target as HTMLElement).id;
      if (id === 'br-tl') tl = v;
      else if (id === 'br-tr') tr = v;
      else if (id === 'br-br-r') br = v;
      else if (id === 'br-bl') bl = v;
      update();
    });
  });

  document.querySelectorAll('.unit-btn').forEach(el => {
    el.addEventListener('click', () => {
      unit = (el as HTMLElement).dataset.unit!;
      document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('border-indigo-400','bg-indigo-50'));
      el.classList.add('border-indigo-400','bg-indigo-50');
      update();
    });
  });

  document.querySelectorAll('.preset-br').forEach(el => {
    el.addEventListener('click', () => {
      const [a,b,c,d] = (el as HTMLElement).dataset.values!.split(',').map(Number);
      tl = a; tr = b; br = c; bl = d;
      if (uniform) {
        (document.getElementById('br-all') as HTMLInputElement).value = String(a);
      } else {
        (document.getElementById('br-tl') as HTMLInputElement).value = String(tl);
        (document.getElementById('br-tr') as HTMLInputElement).value = String(tr);
        (document.getElementById('br-br-r') as HTMLInputElement).value = String(br);
        (document.getElementById('br-bl') as HTMLInputElement).value = String(bl);
      }
      update();
    });
  });

  document.getElementById('br-copy')?.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('br-output')!.textContent || '').then(() => {
      const btn = document.getElementById('br-copy')!;
      btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Init first unit button
  document.querySelector('.unit-btn')?.classList.add('border-indigo-400','bg-indigo-50');
  update();
</script>
