---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Wheel Spinner"
  description="Spin a customizable decision wheel. Add your own options, spin to get a random result. Perfect for decisions, classroom games, and choosing randomly."
  slug="wheel-spinner"
  category="Random & Fun"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Wheel Spinner</h1>
  <p class="text-gray-500 mb-8">Add your options and spin the wheel for a random pick.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Controls -->
      <div class="space-y-4">
        <div>
          <label class="label">Options (one per line)</label>
          <textarea id="ws-items" rows="8" class="input-field font-mono text-sm resize-none" placeholder="Option A&#10;Option B&#10;Option C"></textarea>
        </div>
        <button id="ws-spin" class="btn-primary w-full text-lg py-3">Spin!</button>
        <div id="ws-winner" class="hidden bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-center">
          <p class="text-xs text-indigo-500 mb-1">🎉 Winner!</p>
          <p id="ws-winner-text" class="text-2xl font-bold text-indigo-900"></p>
        </div>
        <div id="ws-history" class="space-y-1"></div>
      </div>

      <!-- Wheel canvas -->
      <div class="flex flex-col items-center gap-4">
        <div class="relative">
          <canvas id="ws-canvas" width="300" height="300" class="rounded-full border-4 border-gray-200 shadow-md"></canvas>
          <!-- Pointer -->
          <div class="absolute top-1/2 -right-3 -translate-y-1/2 w-0 h-0" style="border-top:12px solid transparent;border-bottom:12px solid transparent;border-right:20px solid #4f46e5;"></div>
        </div>
        <p class="text-xs text-gray-400">Click "Spin!" to rotate the wheel</p>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "Is the wheel spin truly random?", a: "Yes — the winning segment is determined by Math.random() before the animation starts. The wheel spins for a visually consistent duration, but the outcome is already determined at the moment you click Spin. The animation ends at the randomly pre-selected segment. Adding more options decreases each option's probability proportionally." },
        { q: "Can I weight certain options to be more likely?", a: "This wheel gives equal probability to each option. To give an option more weight, add it multiple times in the list. For example, if you want 'Pizza' to be twice as likely as other options, add 'Pizza' on two separate lines. This doubles its share of the wheel." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const canvas = document.getElementById('ws-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const COLORS = ['#6366f1','#8b5cf6','#ec4899','#f59e0b','#10b981','#3b82f6','#ef4444','#14b8a6','#f97316','#84cc16'];
  let currentAngle = 0;
  let spinning = false;
  const history: string[] = [];

  function getItems(): string[] {
    return (document.getElementById('ws-items') as HTMLTextAreaElement).value
      .split('\n').map(l => l.trim()).filter(Boolean);
  }

  function drawWheel(angle: number) {
    const items = getItems();
    if (!items.length) {
      ctx.clearRect(0, 0, 300, 300);
      ctx.fillStyle = '#e5e7eb';
      ctx.beginPath(); ctx.arc(150, 150, 148, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#9ca3af';
      ctx.font = '14px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('Add options above', 150, 150);
      return;
    }
    const n = items.length;
    const arc = (Math.PI * 2) / n;
    ctx.clearRect(0, 0, 300, 300);

    for (let i = 0; i < n; i++) {
      const start = angle + arc * i;
      ctx.beginPath();
      ctx.moveTo(150, 150);
      ctx.arc(150, 150, 148, start, start + arc);
      ctx.closePath();
      ctx.fillStyle = COLORS[i % COLORS.length];
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 2;
      ctx.stroke();

      // Label
      ctx.save();
      ctx.translate(150, 150);
      ctx.rotate(start + arc / 2);
      ctx.textAlign = 'right';
      ctx.fillStyle = '#fff';
      ctx.font = `bold ${Math.min(14, 200 / n)}px Arial`;
      ctx.textBaseline = 'middle';
      const label = items[i].length > 14 ? items[i].slice(0, 13) + '…' : items[i];
      ctx.fillText(label, 138, 0);
      ctx.restore();
    }

    // Center circle
    ctx.beginPath(); ctx.arc(150, 150, 20, 0, Math.PI * 2);
    ctx.fillStyle = '#fff'; ctx.fill();
    ctx.strokeStyle = '#e5e7eb'; ctx.lineWidth = 2; ctx.stroke();
  }

  function getWinner(angle: number): string {
    const items = getItems();
    if (!items.length) return '';
    const n = items.length;
    const arc = (Math.PI * 2) / n;
    // Pointer is at the right (angle = 0 = right side)
    let norm = ((-angle) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
    const idx = Math.floor(norm / arc) % n;
    return items[idx];
  }

  document.getElementById('ws-spin')!.addEventListener('click', () => {
    if (spinning || !getItems().length) return;
    spinning = true;
    document.getElementById('ws-winner')!.classList.add('hidden');

    const items = getItems();
    const n = items.length;
    const arc = (Math.PI * 2) / n;
    // Pick winner first
    const winnerIdx = Math.floor(Math.random() * n);
    // Calculate target angle so winner idx is at pointer (right side = angle 0)
    const targetAngle = -(arc * winnerIdx + arc / 2) + (Math.PI * 12 + Math.random() * Math.PI * 4); // multiple spins + land on winner

    const start = currentAngle;
    const end = start + targetAngle;
    const duration = 3000 + Math.random() * 1000;
    const startTime = performance.now();

    function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    function animate(now: number) {
      const elapsed = now - startTime;
      const t = Math.min(elapsed / duration, 1);
      currentAngle = start + (end - start) * easeOut(t);
      drawWheel(currentAngle);
      if (t < 1) {
        requestAnimationFrame(animate);
      } else {
        spinning = false;
        const winner = items[winnerIdx];
        document.getElementById('ws-winner-text')!.textContent = winner;
        document.getElementById('ws-winner')!.classList.remove('hidden');
        history.unshift(winner);
        if (history.length > 5) history.pop();
        document.getElementById('ws-history')!.innerHTML = history.length > 1
          ? `<p class="text-xs text-gray-400 mb-1">Recent picks:</p>` +
            history.slice(1).map(h => `<span class="text-xs text-gray-500 bg-gray-50 border border-gray-100 rounded px-2 py-0.5">${h}</span>`).join(' ')
          : '';
      }
    }

    requestAnimationFrame(animate);
  });

  (document.getElementById('ws-items') as HTMLTextAreaElement).addEventListener('input', () => drawWheel(currentAngle));

  (document.getElementById('ws-items') as HTMLTextAreaElement).value =
    'Pizza\nSushi\nBurgers\nTacos\nPasta\nIndian';
  drawWheel(currentAngle);
</script>
