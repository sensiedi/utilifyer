---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Area Converter"
  description="Convert between square meters, square feet, acres, hectares, square kilometers, square miles, and more area units instantly."
  slug="area-converter"
  category="Converters"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Area Converter</h1>
  <p class="text-gray-500 mb-8">Convert between metric, imperial, and land area units instantly.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Value</label>
        <input id="area-value" type="number" placeholder="Enter a value" class="input-field text-lg" />
      </div>
      <div>
        <label class="label">From Unit</label>
        <select id="area-from" class="input-field">
          <option value="m2">Square Meter (m²)</option>
          <option value="km2">Square Kilometer (km²)</option>
          <option value="cm2">Square Centimeter (cm²)</option>
          <option value="mm2">Square Millimeter (mm²)</option>
          <option value="ha">Hectare (ha)</option>
          <option value="ft2">Square Foot (ft²)</option>
          <option value="in2">Square Inch (in²)</option>
          <option value="yd2">Square Yard (yd²)</option>
          <option value="mi2">Square Mile (mi²)</option>
          <option value="ac">Acre</option>
        </select>
      </div>
    </div>

    <div id="area-results" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Quick Reference</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-gray-600">
        {[
          ['1 hectare', '10,000 m² / 2.471 acres'],
          ['1 acre', '4,047 m² / 0.405 ha'],
          ['1 km²', '100 ha / 247.1 acres'],
          ['1 mi²', '640 acres / 259 ha'],
          ['1 ft²', '0.0929 m²'],
          ['1 m²', '10.7639 ft²'],
        ].map(([a, b]) => (
          <div class="flex justify-between bg-white border border-gray-100 rounded px-3 py-1.5">
            <span class="font-medium text-gray-700">{a}</span>
            <span class="text-gray-500">{b}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How many square feet are in an acre?", a: "One acre equals exactly 43,560 square feet. An acre is also equal to 4,047 square meters or 0.4047 hectares. The acre was historically defined as the amount of land plowable by one man with one ox in one day." },
        { q: "What is a hectare?", a: "A hectare (ha) is a metric unit equal to 10,000 m² (100m × 100m) or approximately 2.471 acres. It is the standard unit for measuring land area in most countries, used in agriculture and real estate." },
        { q: "How do you convert square feet to square meters?", a: "Multiply square feet by 0.0929 to get square meters. Or divide square feet by 10.764. For example, 1,000 ft² × 0.0929 = 92.9 m²." },
        { q: "How many acres in a square mile?", a: "There are exactly 640 acres in one square mile. This is the basis for the US Public Land Survey System, where a township is 6 miles × 6 miles = 36 square miles = 23,040 acres." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const TO_M2: Record<string, number> = {
    m2: 1, km2: 1e6, cm2: 0.0001, mm2: 1e-6,
    ha: 10000, ft2: 0.09290304, in2: 0.00064516,
    yd2: 0.83612736, mi2: 2589988.110336, ac: 4046.8564224,
  };
  const LABELS: Record<string, string> = {
    m2: 'Square Meter', km2: 'Square Kilometer', cm2: 'Square Centimeter', mm2: 'Square Millimeter',
    ha: 'Hectare', ft2: 'Square Foot', in2: 'Square Inch',
    yd2: 'Square Yard', mi2: 'Square Mile', ac: 'Acre',
  };
  const UNITS: Record<string, string> = {
    m2: 'm²', km2: 'km²', cm2: 'cm²', mm2: 'mm²',
    ha: 'ha', ft2: 'ft²', in2: 'in²', yd2: 'yd²', mi2: 'mi²', ac: 'ac',
  };

  function fmt(n: number): string {
    if (n === 0) return '0';
    if (Math.abs(n) >= 1e12 || (Math.abs(n) < 1e-6 && n !== 0)) return n.toExponential(4);
    return parseFloat(n.toPrecision(8)).toString();
  }

  function convert() {
    const val = parseFloat((document.getElementById('area-value') as HTMLInputElement).value);
    const from = (document.getElementById('area-from') as HTMLSelectElement).value;
    const container = document.getElementById('area-results')!;
    if (isNaN(val)) { container.innerHTML = ''; return; }
    const m2 = val * TO_M2[from];
    container.innerHTML = Object.entries(TO_M2).map(([unit, factor]) => {
      const result = m2 / factor;
      const active = unit === from ? 'border-indigo-300 bg-indigo-50' : 'border-gray-100 bg-gray-50';
      return `<div class="flex justify-between items-center border ${active} rounded-xl px-4 py-2.5">
        <span class="text-sm text-gray-500">${LABELS[unit]}</span>
        <span class="font-mono text-sm font-medium text-gray-800 select-all">${fmt(result)} ${UNITS[unit]}</span>
      </div>`;
    }).join('');
  }

  document.getElementById('area-value')?.addEventListener('input', convert);
  document.getElementById('area-from')?.addEventListener('change', convert);
</script>
