---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Regex Tester"
  description="Test regular expressions against any text. See all matches highlighted in real time. Supports flags (global, case-insensitive, multiline)."
  slug="regex-tester"
  category="Developer"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Regex Tester</h1>
  <p class="text-gray-500 mb-8">Test regular expressions with live match highlighting and capture group details.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-4">

    <!-- Pattern input -->
    <div>
      <label class="label">Regular Expression</label>
      <div class="flex gap-2">
        <div class="relative flex-1">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-mono text-lg">/</span>
          <input id="regex-pattern" type="text" placeholder="e.g. \b\w+@\w+\.\w+\b" class="input-field pl-7 pr-16 font-mono" />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-mono text-lg">/</span>
        </div>
        <div class="flex gap-1">
          {['g','i','m','s'].map(flag => (
            <button data-flag={flag} class="flag-btn w-8 h-10 rounded-lg border border-gray-200 text-sm font-mono font-bold text-gray-400 hover:border-indigo-300 hover:text-indigo-600 transition-colors">{flag}</button>
          ))}
        </div>
      </div>
      <div id="regex-error" class="mt-1 text-xs text-red-600 hidden"></div>
    </div>

    <!-- Test string -->
    <div>
      <label class="label">Test String</label>
      <textarea id="regex-input" rows={6} placeholder="Enter text to test against…" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y text-sm font-mono"></textarea>
    </div>

    <!-- Match stats -->
    <div id="match-stats" class="hidden flex flex-wrap gap-3 text-sm">
      <span id="match-count" class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full font-semibold"></span>
      <span id="match-flags" class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full font-mono text-xs self-center"></span>
    </div>

    <!-- Highlighted output -->
    <div id="highlight-section" class="hidden">
      <label class="label">Matches Highlighted</label>
      <div id="highlight-output" class="border border-gray-200 rounded-xl p-4 font-mono text-sm leading-relaxed whitespace-pre-wrap break-all bg-gray-50 min-h-[60px]"></div>
    </div>

    <!-- Match list -->
    <div id="matches-section" class="hidden">
      <label class="label">Match Details</label>
      <div id="matches-list" class="space-y-2 max-h-64 overflow-y-auto"></div>
    </div>

    <!-- Quick patterns -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Common Patterns</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs">
        {[
          ['Email address', '\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b'],
          ['URL (http/https)', 'https?://[\\w.-]+(?:\\.[\\w.-]+)+[\\w\\-._~:/?#[\\]@!$&\'()*+,;=%]*'],
          ['Phone (US)', '\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}'],
          ['IPv4 address', '\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b'],
          ['Hex color', '#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})\\b'],
          ['Date (YYYY-MM-DD)', '\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])'],
          ['ZIP code (US)', '\\b\\d{5}(?:-\\d{4})?\\b'],
          ['HTML tag', '<([a-z][a-z0-9]*)(?:\\s[^>]*)?\\s*/?>'],
        ].map(([label, pattern]) => (
          <button data-pattern={pattern} class="text-left bg-white border border-gray-200 hover:border-indigo-300 rounded-lg px-3 py-2 transition-colors group">
            <span class="font-medium text-gray-700 group-hover:text-indigo-700 block">{label}</span>
            <span class="font-mono text-gray-400 text-xs truncate block">{pattern}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What are regex flags?", a: "Flags modify matching behavior. g (global) finds all matches, not just the first. i (case-insensitive) treats A and a as the same. m (multiline) makes ^ and $ match line starts/ends instead of string start/end. s (dotAll) makes . match newlines too." },
        { q: "What is the difference between . and \\w in regex?", a: ". matches any single character except newline (with dotAll flag, including newline). \\w matches word characters: letters, digits, and underscore — equivalent to [A-Za-z0-9_]. \\W is the opposite (non-word characters)." },
        { q: "What are capture groups?", a: "Parentheses create capture groups: (\\d+) captures one or more digits. Groups are numbered from left to right starting at 1. Named groups use (?<name>pattern). Groups let you extract specific parts of a match and reuse them in replacements." },
        { q: "What does + vs * vs ? mean?", a: "+ means one or more (\\d+ matches '1' or '123'). * means zero or more. ? means zero or one (makes the preceding element optional). {n} means exactly n times. {n,m} means between n and m times." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const activeFlags = new Set<string>(['g', 'i']);

  document.querySelectorAll('.flag-btn').forEach(btn => {
    const flag = (btn as HTMLElement).dataset.flag!;
    if (activeFlags.has(flag)) btn.classList.add('border-indigo-400', 'text-indigo-700', 'bg-indigo-50');
    btn.addEventListener('click', () => {
      if (activeFlags.has(flag)) {
        activeFlags.delete(flag);
        btn.classList.remove('border-indigo-400', 'text-indigo-700', 'bg-indigo-50');
      } else {
        activeFlags.add(flag);
        btn.classList.add('border-indigo-400', 'text-indigo-700', 'bg-indigo-50');
      }
      runTest();
    });
  });

  document.querySelectorAll('[data-pattern]').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('regex-pattern') as HTMLInputElement).value = (btn as HTMLElement).dataset.pattern!;
      runTest();
    });
  });

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function runTest() {
    const pattern = (document.getElementById('regex-pattern') as HTMLInputElement).value;
    const text = (document.getElementById('regex-input') as HTMLTextAreaElement).value;
    const errBox = document.getElementById('regex-error')!;
    const stats = document.getElementById('match-stats')!;
    const highlightSection = document.getElementById('highlight-section')!;
    const matchesSection = document.getElementById('matches-section')!;
    errBox.classList.add('hidden');

    if (!pattern) {
      stats.classList.add('hidden'); highlightSection.classList.add('hidden'); matchesSection.classList.add('hidden'); return;
    }

    let regex: RegExp;
    try {
      regex = new RegExp(pattern, Array.from(activeFlags).join(''));
    } catch (e: any) {
      errBox.textContent = e.message; errBox.classList.remove('hidden');
      stats.classList.add('hidden'); highlightSection.classList.add('hidden'); matchesSection.classList.add('hidden'); return;
    }

    if (!text) { stats.classList.add('hidden'); highlightSection.classList.add('hidden'); matchesSection.classList.add('hidden'); return; }

    const matches: RegExpExecArray[] = [];
    if (activeFlags.has('g')) {
      let m: RegExpExecArray | null;
      regex.lastIndex = 0;
      while ((m = regex.exec(text)) !== null) {
        matches.push(m);
        if (m[0].length === 0) { regex.lastIndex++; if (regex.lastIndex > text.length) break; }
      }
    } else {
      const m = regex.exec(text);
      if (m) matches.push(m);
    }

    document.getElementById('match-count')!.textContent = `${matches.length} match${matches.length !== 1 ? 'es' : ''}`;
    document.getElementById('match-flags')!.textContent = `/${pattern}/${Array.from(activeFlags).join('')}`;
    stats.classList.remove('hidden');

    // Highlighted output
    if (matches.length > 0) {
      let result = '';
      let last = 0;
      matches.forEach(m => {
        result += escapeHtml(text.slice(last, m.index));
        result += `<mark class="bg-yellow-200 text-yellow-900 rounded px-0.5">${escapeHtml(m[0])}</mark>`;
        last = m.index + m[0].length;
      });
      result += escapeHtml(text.slice(last));
      document.getElementById('highlight-output')!.innerHTML = result;
      highlightSection.classList.remove('hidden');

      document.getElementById('matches-list')!.innerHTML = matches.map((m, i) => {
        const groups = m.slice(1).map((g, j) =>
          `<div class="text-xs text-gray-500">Group ${j+1}: <span class="font-mono text-indigo-600">${g ?? '<undefined>'}</span></div>`
        ).join('');
        return `<div class="bg-gray-50 border border-gray-100 rounded-xl px-3 py-2">
          <div class="flex justify-between text-xs text-gray-400 mb-1">
            <span>Match ${i+1}</span><span>Index: ${m.index}–${m.index + m[0].length}</span>
          </div>
          <div class="font-mono text-sm text-gray-800 font-semibold select-all">${escapeHtml(m[0]) || '(empty)'}</div>
          ${groups}
        </div>`;
      }).join('');
      matchesSection.classList.remove('hidden');
    } else {
      highlightSection.classList.add('hidden');
      matchesSection.classList.add('hidden');
    }
  }

  document.getElementById('regex-pattern')?.addEventListener('input', runTest);
  document.getElementById('regex-input')?.addEventListener('input', runTest);

  (document.getElementById('regex-input') as HTMLTextAreaElement).value =
    'Contact us at hello@example.com or support@utilifyer.com\nPhone: (555) 123-4567 or 555.987.6543\nVisit https://utilifyer.com for more tools.';
  (document.getElementById('regex-pattern') as HTMLInputElement).value = '\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b';
  runTest();
</script>
