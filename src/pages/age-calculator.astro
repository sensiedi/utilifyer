---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Age Calculator"
  description="Calculate your exact age in years, months, days, hours, and minutes from your date of birth."
  slug="age-calculator"
  category="Date & Time"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Age Calculator</h1>
  <p class="text-gray-500 mb-8">Find your exact age down to the day, hour, and minute.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Date of Birth</label>
        <input id="dob" type="date" class="input-field" />
      </div>
      <div>
        <label class="label">Age at Date <span class="text-gray-400 font-normal">(defaults to today)</span></label>
        <input id="target-date" type="date" class="input-field" />
      </div>
    </div>
    <button id="calc-btn" class="btn-primary w-full">Calculate Age</button>

    <div id="result" class="hidden">
      <div class="result-box">
        <p class="text-sm text-indigo-700 font-medium mb-3">Your Age</p>
        <p id="main-result" class="text-3xl font-bold text-indigo-900"></p>
        <div class="grid grid-cols-3 gap-3 mt-5">
          <div class="bg-white rounded-lg border border-indigo-100 p-3 text-center">
            <p id="total-months" class="text-xl font-bold text-indigo-700"></p>
            <p class="text-xs text-gray-500 mt-1">Total Months</p>
          </div>
          <div class="bg-white rounded-lg border border-indigo-100 p-3 text-center">
            <p id="total-weeks" class="text-xl font-bold text-indigo-700"></p>
            <p class="text-xs text-gray-500 mt-1">Total Weeks</p>
          </div>
          <div class="bg-white rounded-lg border border-indigo-100 p-3 text-center">
            <p id="total-days" class="text-xl font-bold text-indigo-700"></p>
            <p class="text-xs text-gray-500 mt-1">Total Days</p>
          </div>
        </div>
      </div>
      <div class="mt-4 bg-gray-50 border border-gray-200 rounded-xl p-4">
        <p class="text-sm font-medium text-gray-700 mb-2">Next Birthday</p>
        <p id="next-birthday" class="text-sm text-gray-600"></p>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-3">How It Works</h2>
    <p class="text-sm text-gray-600">
      The calculator finds the difference between your date of birth and the target date (today by default).
      It accounts for leap years, varying month lengths, and provides the exact breakdown in years, months,
      days, total weeks, and total days.
    </p>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How is my exact age calculated?", a: "Your age is calculated by finding the difference between your date of birth and today's date, accounting for all leap years and varying month lengths." },
        { q: "Can I calculate my age on a specific date in the past or future?", a: "Yes. Change the 'Age at Date' field to any date — past or future — and the calculator will give your exact age on that day." },
        { q: "What is my age in total days?", a: "The calculator shows your total days lived in the breakdown section after calculating." },
        { q: "When is my next birthday?", a: "The result section shows how many days remain until your next birthday." }
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const dobInput = document.getElementById('dob') as HTMLInputElement;
  const targetInput = document.getElementById('target-date') as HTMLInputElement;

  // Default target to today
  const today = new Date();
  targetInput.value = today.toISOString().split('T')[0];

  document.getElementById('calc-btn')?.addEventListener('click', () => {
    if (!dobInput.value) return;

    const dob = new Date(dobInput.value);
    const target = targetInput.value ? new Date(targetInput.value) : today;

    if (dob > target) {
      alert('Date of birth cannot be after the target date.');
      return;
    }

    let years = target.getFullYear() - dob.getFullYear();
    let months = target.getMonth() - dob.getMonth();
    let days = target.getDate() - dob.getDate();

    if (days < 0) {
      months--;
      const prevMonth = new Date(target.getFullYear(), target.getMonth(), 0);
      days += prevMonth.getDate();
    }
    if (months < 0) {
      years--;
      months += 12;
    }

    const totalDays = Math.floor((target.getTime() - dob.getTime()) / (1000 * 60 * 60 * 24));
    const totalWeeks = Math.floor(totalDays / 7);
    const totalMonths = years * 12 + months;

    // Next birthday
    let nextBday = new Date(target.getFullYear(), dob.getMonth(), dob.getDate());
    if (nextBday <= target) nextBday.setFullYear(nextBday.getFullYear() + 1);
    const daysToNext = Math.ceil((nextBday.getTime() - target.getTime()) / (1000 * 60 * 60 * 24));
    const nextBdayStr = nextBday.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

    document.getElementById('main-result')!.textContent =
      `${years} years, ${months} months, ${days} days`;
    document.getElementById('total-months')!.textContent = totalMonths.toLocaleString();
    document.getElementById('total-weeks')!.textContent = totalWeeks.toLocaleString();
    document.getElementById('total-days')!.textContent = totalDays.toLocaleString();
    document.getElementById('next-birthday')!.textContent =
      `${nextBdayStr} — ${daysToNext} day${daysToNext !== 1 ? 's' : ''} away`;

    document.getElementById('result')!.classList.remove('hidden');
  });
</script>
