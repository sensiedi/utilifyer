---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="CSS Box Shadow Generator"
  description="Generate CSS box-shadow code visually with live preview. Adjust offset, blur, spread, color, and opacity. Add multiple shadows and copy the CSS."
  slug="box-shadow-generator"
  category="Color & Design"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">CSS Box Shadow Generator</h1>
  <p class="text-gray-500 mb-8">Create multi-layered CSS box shadows visually with live preview.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Left: Controls -->
      <div class="space-y-4">
        <div class="flex justify-between items-center">
          <p class="label">Shadow Layers</p>
          <button id="bs-add" class="text-sm text-indigo-600 hover:text-indigo-800">+ Add layer</button>
        </div>
        <div id="bs-layers" class="space-y-3"></div>
      </div>

      <!-- Right: Preview -->
      <div>
        <p class="label mb-3">Preview</p>
        <div class="rounded-2xl border border-gray-100 bg-gray-50 p-8 flex items-center justify-center" style="min-height:200px">
          <div id="bs-preview" class="w-32 h-32 rounded-2xl bg-white transition-all"></div>
        </div>
        <div class="mt-3">
          <p class="text-xs text-gray-400 mb-1">Background</p>
          <div class="flex gap-2">
            {['#f9fafb','#6366f1','#111827','#fef3c7'].map(c => (
              <div class="bg-swatch w-8 h-8 rounded-lg cursor-pointer border-2 border-transparent hover:border-gray-400 transition-colors" style={`background:${c}`} data-bg={c}></div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- CSS Output -->
    <div>
      <div class="flex justify-between items-center mb-2">
        <p class="label">CSS Code</p>
        <button id="bs-copy" class="text-xs text-indigo-600 hover:text-indigo-800">Copy</button>
      </div>
      <pre id="bs-output" class="bg-gray-900 text-green-300 rounded-xl p-4 text-sm font-mono overflow-x-auto whitespace-pre"></pre>
    </div>

    <!-- Presets -->
    <div>
      <p class="label mb-2">Presets</p>
      <div class="flex flex-wrap gap-2" id="bs-presets"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What are the box-shadow parameters?", a: "box-shadow takes: offset-x offset-y blur-radius spread-radius color. You can add 'inset' at the start for inner shadows. Multiple shadows are comma-separated. Example: box-shadow: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -2px rgba(0,0,0,.1);" },
        { q: "What is the difference between blur and spread?", a: "Blur radius controls the softness of the shadow edge — 0 is a hard edge, higher values are more diffuse. Spread radius expands or contracts the shadow before blur is applied — positive values make the shadow larger than the element, negative values shrink it." },
        { q: "What is an inset shadow?", a: "An inset shadow appears inside the element rather than outside. It's useful for creating pressed/sunken button effects, inner glow effects, and embossed textures. It still respects border-radius. Use negative offset values to position the shadow on any side." },
        { q: "How do I create smooth elevation/depth effects?", a: "Layer multiple shadows: a larger, softer shadow for ambient occlusion and a smaller, harder shadow for direct light. Example for elevation 2: '0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24)'. Google's Material Design uses this technique systematically across its elevation levels." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  interface Shadow { x: number; y: number; blur: number; spread: number; color: string; alpha: number; inset: boolean; }

  let shadows: Shadow[] = [
    { x: 0, y: 4, blur: 16, spread: -2, color: '#000000', alpha: 15, inset: false },
    { x: 0, y: 2, blur: 6, spread: -2, color: '#000000', alpha: 10, inset: false },
  ];

  const PRESETS = [
    { name: 'Subtle', shadows: [{ x:0, y:1, blur:3, spread:0, color:'#000000', alpha:12, inset:false }] },
    { name: 'Soft', shadows: [{ x:0, y:4, blur:16, spread:-2, color:'#000000', alpha:15, inset:false }, { x:0, y:2, blur:6, spread:-2, color:'#000000', alpha:10, inset:false }] },
    { name: 'Medium', shadows: [{ x:0, y:10, blur:15, spread:-3, color:'#000000', alpha:10, inset:false }, { x:0, y:4, blur:6, spread:-4, color:'#000000', alpha:10, inset:false }] },
    { name: 'Hard', shadows: [{ x:4, y:4, blur:0, spread:0, color:'#000000', alpha:100, inset:false }] },
    { name: 'Inset', shadows: [{ x:0, y:2, blur:6, spread:0, color:'#000000', alpha:20, inset:true }] },
    { name: 'Glow', shadows: [{ x:0, y:0, blur:20, spread:4, color:'#6366f1', alpha:40, inset:false }] },
    { name: 'Elevated', shadows: [{ x:0, y:20, blur:25, spread:-5, color:'#000000', alpha:10, inset:false }, { x:0, y:8, blur:10, spread:-6, color:'#000000', alpha:10, inset:false }] },
    { name: 'Neumorph', shadows: [{ x:-6, y:-6, blur:12, spread:0, color:'#ffffff', alpha:80, inset:false }, { x:6, y:6, blur:12, spread:0, color:'#000000', alpha:10, inset:false }] },
  ];

  function toRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${(alpha/100).toFixed(2)})`;
  }

  function generate() {
    const parts = shadows.map(s =>
      `${s.inset ? 'inset ' : ''}${s.x}px ${s.y}px ${s.blur}px ${s.spread}px ${toRgba(s.color, s.alpha)}`
    );
    const value = parts.join(', ');
    document.getElementById('bs-preview')!.style.boxShadow = value;
    document.getElementById('bs-output')!.textContent = `box-shadow: ${value};`;
  }

  function slider(id: string, label: string, val: number, min: number, max: number, i: number, field: keyof Shadow): string {
    return `<div class="flex items-center gap-2">
      <span class="text-xs text-gray-400 w-12 flex-shrink-0">${label}</span>
      <input type="range" class="sl flex-1" data-i="${i}" data-field="${field}" min="${min}" max="${max}" value="${val}" />
      <input type="number" class="sl-num border border-gray-200 rounded px-1.5 py-0.5 w-14 text-xs font-mono text-center" data-i="${i}" data-field="${field}" min="${min}" max="${max}" value="${val}" />
    </div>`;
  }

  function renderLayers() {
    const container = document.getElementById('bs-layers')!;
    container.innerHTML = shadows.map((s, i) => `
      <div class="border border-gray-200 rounded-xl p-3 space-y-2 bg-gray-50">
        <div class="flex items-center justify-between mb-1">
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 rounded border border-gray-300" style="background:${toRgba(s.color, s.alpha)}"></div>
            <span class="text-xs font-medium text-gray-600">Layer ${i+1}${s.inset ? ' (inset)' : ''}</span>
          </div>
          <div class="flex items-center gap-2">
            <label class="flex items-center gap-1 text-xs text-gray-500 cursor-pointer">
              <input type="checkbox" class="inset-chk accent-indigo-600" data-i="${i}" ${s.inset ? 'checked' : ''} /> inset
            </label>
            ${shadows.length > 1 ? `<button class="layer-remove text-gray-400 hover:text-red-500 text-xs" data-i="${i}">✕</button>` : ''}
          </div>
        </div>
        ${slider('x','X',s.x,-50,50,i,'x')}
        ${slider('y','Y',s.y,-50,50,i,'y')}
        ${slider('bl','Blur',s.blur,0,100,i,'blur')}
        ${slider('sp','Spread',s.spread,-50,50,i,'spread')}
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-400 w-12 flex-shrink-0">Color</span>
          <input type="color" class="color-pick w-8 h-7 rounded cursor-pointer border border-gray-200 p-0.5" data-i="${i}" value="${s.color}" />
          <input type="range" class="sl flex-1" data-i="${i}" data-field="alpha" min="0" max="100" value="${s.alpha}" />
          <span class="text-xs font-mono text-gray-500 w-10 text-right alpha-val">${s.alpha}%</span>
        </div>
      </div>
    `).join('');

    container.querySelectorAll('.sl').forEach(el => {
      el.addEventListener('input', (e) => {
        const i = parseInt((e.target as HTMLElement).dataset.i!);
        const field = (e.target as HTMLElement).dataset.field as keyof Shadow;
        (shadows[i] as any)[field] = parseFloat((e.target as HTMLInputElement).value);
        renderLayers();
        generate();
      });
    });
    container.querySelectorAll('.sl-num').forEach(el => {
      el.addEventListener('input', (e) => {
        const i = parseInt((e.target as HTMLElement).dataset.i!);
        const field = (e.target as HTMLElement).dataset.field as keyof Shadow;
        (shadows[i] as any)[field] = parseFloat((e.target as HTMLInputElement).value) || 0;
        generate();
      });
    });
    container.querySelectorAll('.color-pick').forEach(el => {
      el.addEventListener('input', (e) => {
        const i = parseInt((e.target as HTMLElement).dataset.i!);
        shadows[i].color = (e.target as HTMLInputElement).value;
        renderLayers();
        generate();
      });
    });
    container.querySelectorAll('.inset-chk').forEach(el => {
      el.addEventListener('change', (e) => {
        const i = parseInt((e.target as HTMLElement).dataset.i!);
        shadows[i].inset = (e.target as HTMLInputElement).checked;
        renderLayers();
        generate();
      });
    });
    container.querySelectorAll('.layer-remove').forEach(el => {
      el.addEventListener('click', (e) => {
        const i = parseInt((e.target as HTMLElement).dataset.i!);
        shadows.splice(i, 1);
        renderLayers();
        generate();
      });
    });
  }

  document.getElementById('bs-add')?.addEventListener('click', () => {
    shadows.push({ x: 0, y: 4, blur: 10, spread: 0, color: '#000000', alpha: 15, inset: false });
    renderLayers();
    generate();
  });

  document.getElementById('bs-copy')?.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('bs-output')!.textContent || '').then(() => {
      const btn = document.getElementById('bs-copy')!;
      btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  document.querySelectorAll('.bg-swatch').forEach(el => {
    el.addEventListener('click', () => {
      const bg = (el as HTMLElement).dataset.bg!;
      document.querySelector('.rounded-2xl .bg-gray-50')!.setAttribute('style', `background:${bg};min-height:200px`);
    });
  });

  const presetsEl = document.getElementById('bs-presets')!;
  presetsEl.innerHTML = PRESETS.map((p, i) =>
    `<button class="preset-btn text-xs border border-gray-200 rounded-lg px-3 py-1.5 hover:border-indigo-300 hover:bg-indigo-50 transition-colors" data-i="${i}">${p.name}</button>`
  ).join('');
  presetsEl.querySelectorAll('.preset-btn').forEach(el => {
    el.addEventListener('click', () => {
      const i = parseInt((el as HTMLElement).dataset.i!);
      shadows = PRESETS[i].shadows.map(s => ({ ...s }));
      renderLayers();
      generate();
    });
  });

  renderLayers();
  generate();
</script>
