---
import '../../styles/global.css';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  const categories = [...new Set(tools.map(t => t.category))];
  return categories.map(cat => ({
    params: { slug: cat.toLowerCase().replace(/ & /g, '-and-').replace(/ /g, '-') },
    props: { category: cat },
  }));
}

interface Props { category: string }
const { category } = Astro.props;

const catTools = tools
  .filter(t => t.category === category && t.status === 'live')
  .sort((a, b) => a.priority - b.priority);

const allCategories = [...new Set(tools.map(t => t.category))].sort();

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  'Finance': 'Calculators for loans, mortgages, investments, tax, and everyday money decisions.',
  'Health': 'Health calculators for BMI, calorie needs, body fat, hydration, and fitness planning.',
  'Math': 'Mathematical calculators for percentages, statistics, geometry, fractions, and more.',
  'Unit Converters': 'Convert between any units — length, weight, temperature, volume, speed, and more.',
  'Developer': 'Developer tools for encoding, hashing, formatting, color conversion, and code utilities.',
  'Date & Time': 'Tools for working with dates, times, timezones, countdowns, and calendar calculations.',
  'Color & Design': 'Color pickers, palette generators, contrast checkers, and design utilities.',
  'Text & Writing': 'Text tools for word counting, case conversion, character limits, and writing analysis.',
  'SEO & Marketing': 'SEO and marketing tools for meta tags, UTM builders, keyword density, and more.',
  'Real Estate': 'Real estate calculators for mortgages, rent vs buy, ROI, property tax, and more.',
  'Travel & Geography': 'Travel tools for currency conversion, flight times, packing lists, and country info.',
  'Food & Cooking': 'Cooking calculators for unit conversion, recipe scaling, nutrition, and meal planning.',
  'Random & Fun': 'Random generators, games, and fun tools — spin a wheel, flip a coin, play trivia.',
  'Automotive': 'Automotive tools for tire sizing, fuel cost, depreciation, VIN decoding, and more.',
};

const description = CATEGORY_DESCRIPTIONS[category]
  ?? `Free online ${category} tools and calculators.`;

const canonicalUrl = `https://utilifyer.com/category/${Astro.params.slug}`;
const ogImage = 'https://utilifyer.com/og-default.png';

const CATEGORY_ICONS: Record<string, string> = {
  'Finance': '💰', 'Health': '❤️', 'Math': '🧮', 'Unit Converters': '⚖️',
  'Developer': '💻', 'Date & Time': '🕐', 'Color & Design': '🎨',
  'Text & Writing': '✍️', 'SEO & Marketing': '📈', 'Real Estate': '🏠',
  'Travel & Geography': '✈️', 'Food & Cooking': '🍳', 'Random & Fun': '🎲',
  'Automotive': '🚗',
};
const icon = CATEGORY_ICONS[category] ?? '🛠️';

function getCatIcon(cat: string): string {
  return CATEGORY_ICONS[cat] ?? '🛠️';
}
function catSlug(cat: string): string {
  return cat.toLowerCase().replace(/ & /g, '-and-').replace(/ /g, '-');
}
function catToolCount(cat: string): number {
  return tools.filter(t => t.category === cat && t.status === 'live').length;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{category} Tools — Free Online {category} Calculators | Utilifyer</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${category} Tools — Utilifyer`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Utilifyer" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": `${category} Tools`,
      "description": description,
      "url": canonicalUrl,
    })} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-T0KTKQ4MGQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T0KTKQ4MGQ');
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-gray-50">

    <!-- Drawer backdrop -->
    <div id="nav-backdrop" class="fixed inset-0 bg-black/40 z-[60] hidden" aria-hidden="true"></div>

    <!-- Navigation drawer -->
    <div id="nav-drawer" class="fixed top-0 left-0 h-full w-72 bg-white z-[70] shadow-2xl -translate-x-full transition-transform duration-300 flex flex-col">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-indigo-600">
          <span>🛠️</span> Utilifyer
        </a>
        <button id="nav-close" class="text-gray-400 hover:text-gray-700 text-2xl leading-none transition-colors">✕</button>
      </div>
      <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 mb-2">Categories</p>
        {allCategories.map(cat => (
          <a
            href={`/category/${catSlug(cat)}`}
            class={`flex items-center gap-2 px-3 py-2 rounded-xl text-sm transition-colors ${category === cat ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-indigo-50 hover:text-indigo-700'}`}
          >
            {cat}
          </a>
        ))}
      </nav>
      <div class="px-3 py-4 border-t border-gray-100 space-y-0.5">
        <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 hover:text-indigo-600 transition-colors">All Tools</a>
        <a href="/about" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 hover:text-indigo-600 transition-colors">About</a>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-indigo-600 hover:text-indigo-700 transition-colors">
          <span class="text-2xl">🛠️</span>
          Utilifyer
        </a>
        <div class="flex items-center gap-3">
          <a href="/" class="text-sm text-gray-500 hover:text-indigo-600 transition-colors hidden sm:block">← All Tools</a>
          <button id="nav-open" class="flex items-center gap-2 text-sm border border-gray-200 rounded-xl px-3 py-1.5 text-gray-600 hover:border-indigo-300 hover:text-indigo-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            Categories
          </button>
        </div>
      </div>
    </header>

    <!-- Breadcrumb -->
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 py-2 text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
        <span>›</span>
        <span class="text-gray-800 font-medium">{category}</span>
      </div>
    </div>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-indigo-600 to-indigo-800 text-white py-12 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-3">
          <span class="text-5xl">{icon}</span>
          <h1 class="text-3xl sm:text-4xl font-bold">{category}</h1>
        </div>
        <p class="text-indigo-200 text-lg max-w-2xl">{description}</p>
        <p class="text-indigo-300 text-sm mt-2">{catTools.length} free tool{catTools.length !== 1 ? 's' : ''}</p>
      </div>
    </section>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-10">

      <!-- Tool grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {catTools.map(tool => (
          <a href={`/${tool.slug}`} class="tool-card flex items-start gap-4 no-underline group">
            <span class="text-3xl shrink-0">{tool.icon}</span>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">{tool.title}</div>
              <div class="text-sm text-gray-500 mt-1 line-clamp-2">{tool.description}</div>
            </div>
          </a>
        ))}
      </div>

      <!-- Other categories -->
      <div class="mt-14">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Browse Other Categories</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {allCategories.filter(c => c !== category).map(cat => (
            <a
              href={`/category/${catSlug(cat)}`}
              class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-indigo-300 hover:bg-indigo-50 transition-colors no-underline"
            >
              <span class="text-xl">{getCatIcon(cat)}</span>
              <div>
                <div class="text-sm font-medium text-gray-800">{cat}</div>
                <div class="text-xs text-gray-400">{catToolCount(cat)} tools</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-12">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
          <div class="flex items-center gap-2 font-semibold text-gray-700"><span>🛠️</span> Utilifyer</div>
          <nav class="flex items-center gap-4">
            <a href="/" class="hover:text-indigo-600 transition-colors">All Tools</a>
            <a href="/about" class="hover:text-indigo-600 transition-colors">About</a>
            <a href="/privacy-policy" class="hover:text-indigo-600 transition-colors">Privacy</a>
            <a href="/terms-of-service" class="hover:text-indigo-600 transition-colors">Terms</a>
            <a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a>
          </nav>
          <p class="text-xs text-gray-400">© {new Date().getFullYear()} Utilifyer. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const drawer = document.getElementById('nav-drawer')!;
      const backdrop = document.getElementById('nav-backdrop')!;
      const openBtn = document.getElementById('nav-open')!;
      const closeBtn = document.getElementById('nav-close')!;

      function openDrawer() {
        backdrop.classList.remove('hidden');
        requestAnimationFrame(() => drawer.classList.remove('-translate-x-full'));
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.add('-translate-x-full');
        setTimeout(() => backdrop.classList.add('hidden'), 300);
        document.body.style.overflow = '';
      }

      openBtn.addEventListener('click', openDrawer);
      closeBtn.addEventListener('click', closeDrawer);
      backdrop.addEventListener('click', closeDrawer);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });
    </script>

  </body>
</html>
