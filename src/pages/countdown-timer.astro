---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Countdown Timer"
  description="Count down to any future date or event. See days, hours, minutes, and seconds remaining."
  slug="countdown-timer"
  category="Date & Time"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Countdown Timer</h1>
  <p class="text-gray-500 mb-8">Count down to any event or date.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Event Name</label>
        <input id="event-name" type="text" placeholder="e.g. My Birthday" class="input-field" />
      </div>
      <div>
        <label class="label">Target Date & Time</label>
        <input id="target-datetime" type="datetime-local" class="input-field" />
      </div>
    </div>
    <button id="start-btn" class="btn-primary w-full">Start Countdown</button>

    <!-- Countdown display -->
    <div id="countdown-display" class="hidden">
      <p id="event-title" class="text-center text-lg font-semibold text-gray-700 mb-5"></p>
      <div class="grid grid-cols-4 gap-3 text-center">
        {[
          { id: 'cd-days', label: 'Days' },
          { id: 'cd-hours', label: 'Hours' },
          { id: 'cd-minutes', label: 'Minutes' },
          { id: 'cd-seconds', label: 'Seconds' },
        ].map(({ id, label }) => (
          <div class="bg-indigo-600 rounded-2xl p-4 text-white">
            <p id={id} class="text-4xl sm:text-5xl font-bold tabular-nums">00</p>
            <p class="text-xs text-indigo-200 mt-1 uppercase tracking-wide">{label}</p>
          </div>
        ))}
      </div>
      <p id="total-seconds" class="text-center text-xs text-gray-400 mt-3"></p>
      <div id="expired-msg" class="hidden text-center py-6">
        <p class="text-4xl mb-3">🎉</p>
        <p class="text-2xl font-bold text-indigo-700">The event has arrived!</p>
      </div>
    </div>
  </div>

  <!-- Quick events -->
  <div class="mt-6 bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
    <h2 class="font-semibold text-gray-800 text-sm mb-3">Quick Events</h2>
    <div class="flex flex-wrap gap-2">
      {[
        { label: '🎄 Christmas', month: 12, day: 25 },
        { label: '🎆 New Year', month: 1, day: 1, nextYear: true },
        { label: '🎃 Halloween', month: 10, day: 31 },
        { label: '💝 Valentine\'s Day', month: 2, day: 14 },
        { label: '🎇 New Year\'s Eve', month: 12, day: 31 },
      ].map(({ label, month, day, nextYear }) => (
        <button
          class="quick-event px-3 py-1.5 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
          data-label={label}
          data-month={month}
          data-day={day}
          data-next-year={nextYear ? 'true' : 'false'}
        >
          {label}
        </button>
      ))}
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "Does the countdown update in real time?", a: "Yes, the countdown updates every second automatically once started." },
        { q: "What happens when the countdown reaches zero?", a: "A celebration message appears and the timer stops. You can start a new countdown at any time." },
        { q: "Can I count down to a specific time, not just a date?", a: "Yes. The date and time picker lets you set both a date and an exact time down to the minute." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  let interval: ReturnType<typeof setInterval> | null = null;
  const pad = (n: number) => String(Math.floor(n)).padStart(2, '0');

  function startCountdown(targetDate: Date, name: string) {
    if (interval) clearInterval(interval);
    document.getElementById('event-title')!.textContent = name || 'Countdown';
    document.getElementById('countdown-display')!.classList.remove('hidden');
    document.getElementById('expired-msg')!.classList.add('hidden');
    document.querySelectorAll('#cd-days,#cd-hours,#cd-minutes,#cd-seconds').forEach(el => (el as HTMLElement).parentElement?.classList.remove('bg-green-500'));

    interval = setInterval(() => {
      const diff = targetDate.getTime() - Date.now();
      if (diff <= 0) {
        clearInterval(interval!);
        ['cd-days','cd-hours','cd-minutes','cd-seconds'].forEach(id => document.getElementById(id)!.textContent = '00');
        document.getElementById('expired-msg')!.classList.remove('hidden');
        document.getElementById('total-seconds')!.textContent = '';
        return;
      }
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      document.getElementById('cd-days')!.textContent = String(days);
      document.getElementById('cd-hours')!.textContent = pad(hours);
      document.getElementById('cd-minutes')!.textContent = pad(minutes);
      document.getElementById('cd-seconds')!.textContent = pad(seconds);
      const totalSec = Math.floor(diff / 1000);
      document.getElementById('total-seconds')!.textContent = `${totalSec.toLocaleString()} total seconds remaining`;
    }, 1000);
  }

  document.getElementById('start-btn')?.addEventListener('click', () => {
    const dt = (document.getElementById('target-datetime') as HTMLInputElement).value;
    const name = (document.getElementById('event-name') as HTMLInputElement).value;
    if (!dt) return;
    startCountdown(new Date(dt), name);
  });

  document.querySelectorAll<HTMLButtonElement>('.quick-event').forEach(btn => {
    btn.addEventListener('click', () => {
      const now = new Date();
      let year = now.getFullYear();
      const month = parseInt(btn.dataset.month!) - 1;
      const day = parseInt(btn.dataset.day!);
      let target = new Date(year, month, day, 0, 0, 0);
      if (target <= now || btn.dataset.nextYear === 'true') target.setFullYear(year + 1);
      const name = btn.dataset.label!;
      (document.getElementById('event-name') as HTMLInputElement).value = name;
      const local = new Date(target.getTime() - target.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
      (document.getElementById('target-datetime') as HTMLInputElement).value = local;
      startCountdown(target, name);
    });
  });
</script>
