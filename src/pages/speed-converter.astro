---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Speed Converter"
  description="Convert between km/h, mph, m/s, knots, Mach number, and feet per second instantly. Perfect for travel, aviation, and physics."
  slug="speed-converter"
  category="Converters"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Speed Converter</h1>
  <p class="text-gray-500 mb-8">Convert between km/h, mph, m/s, knots, Mach, and more.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label">Value</label>
        <input id="spd-value" type="number" placeholder="Enter a value" class="input-field text-lg" />
      </div>
      <div>
        <label class="label">From Unit</label>
        <select id="spd-from" class="input-field">
          <option value="kmh">Kilometers per hour (km/h)</option>
          <option value="mph">Miles per hour (mph)</option>
          <option value="ms">Meters per second (m/s)</option>
          <option value="knot">Knot (kn)</option>
          <option value="fps">Feet per second (fps)</option>
          <option value="mach">Mach (at sea level)</option>
          <option value="c">Speed of light (c)</option>
        </select>
      </div>
    </div>

    <div id="spd-results" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>

    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Common Speed References</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-gray-600">
        {[
          ['Walking pace', '≈ 5 km/h (3.1 mph)'],
          ['Cycling average', '≈ 25 km/h (15.5 mph)'],
          ['Speed limit (highway)', '≈ 100–130 km/h'],
          ['Commercial aircraft', '≈ 900 km/h (Mach 0.85)'],
          ['Sound (sea level)', '≈ 1,235 km/h (767 mph)'],
          ['Speed of light', '≈ 1.08 billion km/h'],
        ].map(([a, b]) => (
          <div class="flex justify-between bg-white border border-gray-100 rounded px-3 py-1.5">
            <span class="font-medium text-gray-700">{a}</span>
            <span class="text-gray-500">{b}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How do you convert km/h to mph?", a: "Multiply km/h by 0.621371. For example, 100 km/h × 0.621371 = 62.14 mph. To go the other way, multiply mph by 1.60934." },
        { q: "What is a knot in speed?", a: "A knot (kn) is one nautical mile per hour, equal to 1.852 km/h or 1.151 mph. It is used in maritime and aviation navigation worldwide." },
        { q: "What is Mach 1?", a: "Mach 1 is the speed of sound, which varies by altitude and temperature. At sea level and 15°C, Mach 1 ≈ 1,235 km/h (767 mph or 340 m/s). At cruising altitude, the speed of sound is lower (~1,062 km/h)." },
        { q: "How fast is the speed of light?", a: "Light travels at exactly 299,792,458 m/s in a vacuum — approximately 1.08 billion km/h or 670 million mph. It is the universal speed limit according to special relativity." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const TO_MS: Record<string, number> = {
    kmh: 1/3.6, mph: 0.44704, ms: 1, knot: 0.514444,
    fps: 0.3048, mach: 340.29, c: 299792458,
  };
  const LABELS: Record<string, string> = {
    kmh: 'km/h', mph: 'mph', ms: 'm/s', knot: 'Knots',
    fps: 'ft/s', mach: 'Mach', c: 'Speed of light',
  };
  const UNITS: Record<string, string> = {
    kmh: 'km/h', mph: 'mph', ms: 'm/s', knot: 'kn',
    fps: 'fps', mach: 'Mach', c: 'c',
  };

  function fmt(n: number): string {
    if (n === 0) return '0';
    if (Math.abs(n) >= 1e9 || (Math.abs(n) < 1e-8 && n !== 0)) return n.toExponential(6);
    return parseFloat(n.toPrecision(8)).toString();
  }

  function convert() {
    const val = parseFloat((document.getElementById('spd-value') as HTMLInputElement).value);
    const from = (document.getElementById('spd-from') as HTMLSelectElement).value;
    const container = document.getElementById('spd-results')!;
    if (isNaN(val)) { container.innerHTML = ''; return; }
    const ms = val * TO_MS[from];
    container.innerHTML = Object.entries(TO_MS).map(([unit, factor]) => {
      const result = ms / factor;
      const active = unit === from ? 'border-indigo-300 bg-indigo-50' : 'border-gray-100 bg-gray-50';
      return `<div class="flex justify-between items-center border ${active} rounded-xl px-4 py-2.5">
        <span class="text-sm text-gray-500">${LABELS[unit]}</span>
        <span class="font-mono text-sm font-medium text-gray-800 select-all">${fmt(result)} ${UNITS[unit]}</span>
      </div>`;
    }).join('');
  }

  document.getElementById('spd-value')?.addEventListener('input', convert);
  document.getElementById('spd-from')?.addEventListener('change', convert);
</script>
