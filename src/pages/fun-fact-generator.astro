---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Fun Fact Generator"
  description="Discover surprising, weird, and fascinating facts about science, history, animals, and more. Generate random interesting facts to learn something new every day."
  slug="fun-fact-generator"
  category="Random & Fun"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Fun Fact Generator</h1>
  <p class="text-gray-500 mb-8">Discover surprising facts about science, history, animals, and more.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <!-- Category selector -->
    <div class="flex flex-wrap gap-2">
      {[
        { id: 'all', label: 'All Facts' },
        { id: 'science', label: 'Science' },
        { id: 'history', label: 'History' },
        { id: 'animals', label: 'Animals' },
        { id: 'space', label: 'Space' },
        { id: 'human', label: 'Human Body' },
        { id: 'weird', label: 'Weird & Wonderful' },
      ].map(({ id, label }) => (
        <button class="ff-cat text-sm border border-gray-200 rounded-xl px-3 py-1.5 hover:border-indigo-300 transition-colors text-gray-600" data-cat={id}>{label}</button>
      ))}
    </div>

    <button id="ff-next" class="btn-primary w-full text-lg py-3">Surprise Me!</button>

    <div id="ff-card" class="bg-indigo-50 border-2 border-indigo-200 rounded-2xl p-6 space-y-2">
      <div id="ff-category-label" class="text-xs text-indigo-400 uppercase tracking-wide font-semibold"></div>
      <p id="ff-fact" class="text-lg font-medium text-indigo-900 leading-relaxed"></p>
    </div>

    <div class="flex gap-2">
      <button id="ff-save" class="flex-1 text-sm border border-gray-200 rounded-xl px-4 py-2 hover:border-indigo-300 text-gray-600">⭐ Save this fact</button>
      <button id="ff-copy" class="flex-1 text-sm border border-gray-200 rounded-xl px-4 py-2 hover:border-indigo-300 text-gray-600">📋 Copy</button>
    </div>

    <div id="ff-saved" class="hidden space-y-2">
      <p class="text-sm font-semibold text-gray-700">Saved Facts</p>
      <div id="ff-saved-list" class="space-y-1.5"></div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What makes a fact 'interesting'?", a: "Psychologically, surprising facts activate dopamine — the brain's reward system — because they violate predictions. The most engaging facts combine surprise with significance (they connect to something you already care about) and are verifiable (you can confirm them). Counterintuitive facts (things that seem like they should be false but are true) are especially memorable because they create 'cognitive dissonance' that demands resolution." },
        { q: "How can I remember interesting facts I learn?", a: "Best techniques: (1) Tell the fact to someone else within 24 hours — teaching activates retrieval, which strengthens memory. (2) Connect it to something you already know (elaborative encoding). (3) Write it down — the act of writing strengthens encoding. (4) Create a vivid mental image. (5) Use spaced repetition apps (Anki) for systematic review. Passive reading without retrieval practice loses most information within a week." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  interface Fact { text: string; cat: string }

  const FACTS: Fact[] = [
    // Science
    { text: "A teaspoon of neutron star material would weigh about 10 million tons — roughly equal to all of humanity combined.", cat: 'science' },
    { text: "Lightning strikes Earth about 100 times per second — that's 8.6 million times per day.", cat: 'science' },
    { text: "Water can boil and freeze at the same time. It's called the 'triple point' and happens at exactly 0.01°C and 611.73 pascals of pressure.", cat: 'science' },
    { text: "The smell of rain (petrichor) is caused by a compound called geosmin, produced by soil bacteria called Actinomycetes.", cat: 'science' },
    { text: "There are more atoms in a grain of sand than there are grains of sand on all of Earth's beaches.", cat: 'science' },
    { text: "Hot water freezes faster than cold water under certain conditions. This is called the Mpemba effect, and physicists still debate why it happens.", cat: 'science' },
    { text: "A day on Venus is longer than a year on Venus. Venus takes 243 Earth days to rotate, but only 225 Earth days to orbit the Sun.", cat: 'science' },
    { text: "The Eiffel Tower can be 15 cm taller in summer because the iron expands with heat.", cat: 'science' },
    { text: "Diamonds and graphite are both made of pure carbon — the only difference is how the atoms are arranged.", cat: 'science' },
    { text: "Helium is the only element that was discovered in space (in the Sun's spectrum) before it was found on Earth.", cat: 'science' },
    // History
    { text: "Oxford University is older than the Aztec Empire. Teaching began at Oxford around 1096–1167; the Aztec Empire was founded in 1428.", cat: 'history' },
    { text: "Cleopatra lived closer in time to the Moon landing than to the construction of the Great Pyramid of Giza.", cat: 'history' },
    { text: "The fax machine was invented in 1843 — 23 years before the telephone.", cat: 'history' },
    { text: "Nintendo was founded in 1889. It started as a playing card company before pivoting to video games 90 years later.", cat: 'history' },
    { text: "The Great Wall of China is not visible from space with the naked eye. This is a persistent myth — the wall is only about 9 meters wide.", cat: 'history' },
    { text: "Ancient Romans used crushed mouse brains as toothpaste. They also used urine as mouthwash — the ammonia whitened teeth.", cat: 'history' },
    { text: "During WWII, the British tried to use trained pigeons to deliver messages and even tested 'Project Pigeon' — bombs guided by live pigeons inside.", cat: 'history' },
    { text: "The shortest war in history was the Anglo-Zanzibar War of 1896. It lasted between 38 and 45 minutes.", cat: 'history' },
    { text: "France was still executing people by guillotine when Star Wars came out in 1977. The last guillotine execution was September 10, 1977.", cat: 'history' },
    { text: "More people were alive in ancient China during the Han Dynasty (~60 million) than in the entire Roman Empire at its peak.", cat: 'history' },
    // Animals
    { text: "Octopuses have three hearts, nine brains (one main brain and one mini-brain per arm), and blue blood.", cat: 'animals' },
    { text: "A group of flamingos is called a flamboyance. A group of crows is called a murder. A group of owls is a parliament.", cat: 'animals' },
    { text: "Crows can recognize human faces and hold grudges for years. They've been documented warning other crows about specific dangerous humans.", cat: 'animals' },
    { text: "The mantis shrimp can punch with the force of a .22 caliber bullet and sees 16 types of color receptors (humans have 3).", cat: 'animals' },
    { text: "Clownfish (like Nemo) can change sex. All clownfish are born male. When the dominant female dies, the dominant male changes sex to replace her.", cat: 'animals' },
    { text: "Turritopsis dohrnii, the 'immortal jellyfish', can revert back to its juvenile form after reaching sexual maturity — potentially living forever.", cat: 'animals' },
    { text: "Elephants are the only mammals that can't jump. They also have the longest gestation period of any land mammal — 22 months.", cat: 'animals' },
    { text: "A shrimp's heart is in its head. More accurately, it's in the thorax — the fused head-chest region called the cephalothorax.", cat: 'animals' },
    { text: "Wombat poop is cube-shaped. They're the only animals that produce cube-shaped feces, which they use to mark territory on flat surfaces.", cat: 'animals' },
    { text: "Horses and cows can sleep standing up, but they must lie down for REM sleep. If they don't get REM sleep, they'll eventually collapse.", cat: 'animals' },
    // Space
    { text: "If the Sun were the size of a basketball, Earth would be the size of a grain of sand about 26 meters away.", cat: 'space' },
    { text: "The footprints left on the Moon will likely remain there for millions of years — there's no wind or weather to erase them.", cat: 'space' },
    { text: "There's a giant cloud of alcohol in space. Sagittarius B2 is a molecular cloud 26,000 light-years away containing about 10 billion billion billion liters of vinyl alcohol.", cat: 'space' },
    { text: "One day on Mercury is longer than a year on Mercury. A Mercurian day (one rotation) takes 58.7 Earth days; a year (orbit) takes 88 Earth days.", cat: 'space' },
    { text: "The Milky Way galaxy will collide with the Andromeda galaxy in about 4.5 billion years. The odds of individual stars colliding is extremely low due to the vast distances.", cat: 'space' },
    { text: "Space is completely silent. Sound requires a medium to travel through, and outer space is a near-perfect vacuum.", cat: 'space' },
    { text: "If you could drive to the Sun at 60 mph without stopping, it would take about 177 years.", cat: 'space' },
    { text: "Saturn is so light for its size that it would float on water — if you could find a bathtub big enough.", cat: 'space' },
    // Human Body
    { text: "Your body produces about 25 million new cells every second — more than the number of stars in the Milky Way created per century.", cat: 'human' },
    { text: "The human eye can detect a single photon of light in complete darkness — equivalent to seeing a candle flame from 48 km away.", cat: 'human' },
    { text: "Your bones are, gram for gram, stronger than steel. A cubic inch of bone can bear loads of up to 19,000 lbs.", cat: 'human' },
    { text: "The acid in your stomach is strong enough to dissolve zinc. Your stomach replaces its entire lining every 3–4 days to survive it.", cat: 'human' },
    { text: "You have about 37.2 trillion cells in your body. About 86 billion of those are neurons in your brain.", cat: 'human' },
    { text: "Humans are the only animals that blush. Charles Darwin called blushing 'the most peculiar and most human of all expressions.'", cat: 'human' },
    { text: "Your nose can detect over 1 trillion distinct scents. For decades, scientists thought humans could only detect ~10,000.", cat: 'human' },
    { text: "The human body contains enough fat to make about 7 bars of soap, enough carbon for 9,000 pencils, and enough iron to make a 3-inch nail.", cat: 'human' },
    // Weird & Wonderful
    { text: "A group of pugs is called a 'grumble'. A group of hedgehogs is an 'array' or a 'prickle'.", cat: 'weird' },
    { text: "There's a word for the smell of old books: 'bibliosmia'. The smell comes from the breakdown of chemical compounds in paper over time.", cat: 'weird' },
    { text: "The total length of blood vessels in the human body — arteries, veins, and capillaries — would stretch around Earth's equator about 2.5 times.", cat: 'weird' },
    { text: "If you removed all the empty space from the atoms in every human on Earth, all 8 billion of us would fit in a sugar cube.", cat: 'weird' },
    { text: "Bananas are technically berries, but strawberries aren't. Botanically, berries develop from a single flower with one ovary. Strawberries grow from a flower with multiple ovaries.", cat: 'weird' },
    { text: "The hashtag symbol (#) is called an octothorpe. The 'octo' refers to the eight endpoints of the symbol.", cat: 'weird' },
    { text: "LEGO is the world's largest tire manufacturer by number of units. They produce about 318 million tiny plastic tires per year.", cat: 'weird' },
    { text: "Honey never spoils. Archaeologists have found 3,000-year-old honey in Egyptian tombs that was still perfectly edible.", cat: 'weird' },
    { text: "The word 'salary' comes from the Latin 'salarium' — Roman soldiers were sometimes paid partly in salt, which was precious for preservation.", cat: 'weird' },
    { text: "The dot above a lowercase 'i' or 'j' is called a 'tittle'. The apostrophe over a letter to show it's been borrowed from another language is called a 'diacritic'.", cat: 'weird' },
  ];

  const CAT_LABELS: Record<string, string> = {
    science: '🔬 Science', history: '🏛️ History', animals: '🦁 Animals',
    space: '🚀 Space', human: '🧬 Human Body', weird: '🤯 Weird & Wonderful'
  };

  let category = 'all';
  const saved: Fact[] = [];
  let currentFact: Fact | null = null;

  function getPool(): Fact[] {
    return category === 'all' ? FACTS : FACTS.filter(f => f.cat === category);
  }

  function next() {
    const pool = getPool();
    currentFact = pool[Math.floor(Math.random() * pool.length)];
    document.getElementById('ff-category-label')!.textContent = CAT_LABELS[currentFact.cat] || currentFact.cat;
    document.getElementById('ff-fact')!.textContent = currentFact.text;
  }

  document.getElementById('ff-next')!.addEventListener('click', next);

  document.getElementById('ff-save')!.addEventListener('click', () => {
    if (!currentFact || saved.some(f => f.text === currentFact!.text)) return;
    saved.push(currentFact);
    document.getElementById('ff-saved')!.classList.remove('hidden');
    document.getElementById('ff-saved-list')!.innerHTML = saved.map(f =>
      `<div class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-2.5 text-sm text-gray-700">
        <span class="text-xs text-gray-400 block mb-0.5">${CAT_LABELS[f.cat]}</span>
        ${f.text}
      </div>`
    ).join('');
  });

  document.getElementById('ff-copy')!.addEventListener('click', () => {
    if (currentFact) navigator.clipboard.writeText(currentFact.text);
  });

  document.querySelectorAll('.ff-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      category = (btn as HTMLElement).dataset.cat || 'all';
      document.querySelectorAll('.ff-cat').forEach(b => {
        const active = (b as HTMLElement).dataset.cat === category;
        b.classList.toggle('border-indigo-400', active);
        b.classList.toggle('bg-indigo-50', active);
        b.classList.toggle('text-indigo-700', active);
      });
      next();
    });
  });

  document.querySelector('.ff-cat[data-cat="all"]')!.classList.add('border-indigo-400','bg-indigo-50','text-indigo-700');
  next();
</script>
