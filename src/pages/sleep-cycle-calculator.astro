---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Sleep Cycle Calculator"
  description="Find the best time to wake up or go to sleep based on 90-minute sleep cycles. Wake up feeling refreshed every morning."
  slug="sleep-cycle-calculator"
  category="Health"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Sleep Cycle Calculator</h1>
  <p class="text-gray-500 mb-8">Find the best times to wake up or fall asleep to avoid waking mid-cycle.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">

    <!-- Mode toggle -->
    <div class="flex border border-gray-200 rounded-xl overflow-hidden">
      <button data-mode="bedtime" class="mode-btn flex-1 py-2.5 text-sm font-medium bg-indigo-600 text-white transition-colors">I want to wake up at…</button>
      <button data-mode="wakeup" class="mode-btn flex-1 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">I'm going to bed at…</button>
    </div>

    <div id="opt-bedtime">
      <label class="label">Wake-up time</label>
      <input id="wakeup-time" type="time" value="07:00" class="input-field" />
    </div>
    <div id="opt-wakeup" class="hidden">
      <label class="label">Bedtime</label>
      <input id="bed-time" type="time" value="23:00" class="input-field" />
    </div>

    <div>
      <label class="label">Time to fall asleep (minutes)</label>
      <div class="flex gap-2 flex-wrap">
        {[5, 10, 14, 20, 30].map(m => (
          <button class="fallasleep-btn px-3 py-1.5 rounded-lg border text-sm font-medium transition-colors border-gray-200 text-gray-600 hover:border-indigo-400 hover:bg-indigo-50" data-min={m}>{m} min</button>
        ))}
      </div>
      <input id="fallasleep-min" type="number" value="14" class="input-field mt-2" />
    </div>

    <button id="calc-btn" class="btn-primary w-full">Calculate</button>

    <div id="result" class="hidden space-y-3">
      <p id="result-heading" class="text-sm font-semibold text-gray-700"></p>
      <div id="times-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-3"></div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 text-sm text-indigo-800">
        <p class="font-semibold mb-1">💡 Tips for better sleep</p>
        <ul class="space-y-1 text-indigo-700 text-xs">
          <li>• Aim for 5–6 complete cycles (7.5–9 hours) each night</li>
          <li>• Keep your wake-up time consistent, even on weekends</li>
          <li>• Avoid screens 30–60 minutes before bed</li>
          <li>• Keep your bedroom cool (65–68°F / 18–20°C)</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is a sleep cycle?", a: "A sleep cycle lasts approximately 90 minutes and includes light sleep, deep sleep, and REM (rapid eye movement) sleep stages. Most people complete 4–6 cycles per night. Waking at the end of a cycle feels more natural than waking mid-cycle." },
        { q: "Why do I feel worse after 8 hours of sleep than 7.5?", a: "Sleep occurs in 90-minute cycles. 8 hours = 5 full cycles + 30 minutes. That extra 30 minutes likely interrupts a cycle, leaving you groggy. 7.5 hours (5 full cycles) or 9 hours (6 full cycles) often feels better." },
        { q: "Does everyone have 90-minute sleep cycles?", a: "The 90-minute cycle is an average. Individual cycles range from 80 to 110 minutes. The calculator provides the best general guidance, but you may need to adjust by 15–20 minutes to match your personal rhythm." },
        { q: "What is the best amount of sleep?", a: "Most adults need 7–9 hours (4–6 complete cycles). Teenagers need 8–10 hours. Children need more. Consistently getting fewer than 6 hours is linked to increased risk of obesity, heart disease, and cognitive decline." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  let mode = 'bedtime';

  document.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode!;
      document.querySelectorAll('.mode-btn').forEach(b => { b.classList.toggle('bg-indigo-600', b === btn); b.classList.toggle('text-white', b === btn); b.classList.toggle('text-gray-600', b !== btn); });
      document.getElementById('opt-bedtime')!.classList.toggle('hidden', mode !== 'bedtime');
      document.getElementById('opt-wakeup')!.classList.toggle('hidden', mode !== 'wakeup');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.fallasleep-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('fallasleep-min') as HTMLInputElement).value = btn.dataset.min!;
      document.querySelectorAll('.fallasleep-btn').forEach(b => { b.classList.toggle('bg-indigo-100', b === btn); b.classList.toggle('border-indigo-400', b === btn); b.classList.toggle('text-indigo-600', b === btn); });
    });
  });

  function fmtTime(date: Date): string {
    return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
  }

  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const fallAsleepMin = parseInt((document.getElementById('fallasleep-min') as HTMLInputElement).value) || 14;
    const CYCLE = 90;

    if (mode === 'bedtime') {
      const [h, m] = (document.getElementById('wakeup-time') as HTMLInputElement).value.split(':').map(Number);
      const wakeup = new Date(); wakeup.setHours(h, m, 0, 0);
      const times = [];
      for (let cycles = 6; cycles >= 2; cycles--) {
        const totalMin = cycles * CYCLE + fallAsleepMin;
        const bed = new Date(wakeup.getTime() - totalMin * 60000);
        times.push({ bed, cycles, hours: (cycles * CYCLE / 60).toFixed(1) });
      }
      document.getElementById('result-heading')!.textContent = `Go to bed at one of these times to wake up refreshed at ${fmtTime(wakeup)}:`;
      document.getElementById('times-grid')!.innerHTML = times.map(t =>
        `<div class="text-center p-4 rounded-xl border ${t.cycles >= 5 ? 'bg-indigo-50 border-indigo-200' : 'bg-gray-50 border-gray-200'}">
          <p class="text-xl font-bold ${t.cycles >= 5 ? 'text-indigo-700' : 'text-gray-700'}">${fmtTime(t.bed)}</p>
          <p class="text-xs mt-1 ${t.cycles >= 5 ? 'text-indigo-500' : 'text-gray-500'}">${t.cycles} cycles · ${t.hours} hrs</p>
        </div>`
      ).join('');
    } else {
      const [h, m] = (document.getElementById('bed-time') as HTMLInputElement).value.split(':').map(Number);
      const bedtime = new Date(); bedtime.setHours(h, m, 0, 0);
      const asleepAt = new Date(bedtime.getTime() + fallAsleepMin * 60000);
      const times = [];
      for (let cycles = 2; cycles <= 6; cycles++) {
        const wake = new Date(asleepAt.getTime() + cycles * CYCLE * 60000);
        times.push({ wake, cycles, hours: (cycles * CYCLE / 60).toFixed(1) });
      }
      document.getElementById('result-heading')!.textContent = `If you fall asleep at ${fmtTime(asleepAt)}, these are your best wake-up times:`;
      document.getElementById('times-grid')!.innerHTML = times.map(t =>
        `<div class="text-center p-4 rounded-xl border ${t.cycles >= 5 ? 'bg-indigo-50 border-indigo-200' : 'bg-gray-50 border-gray-200'}">
          <p class="text-xl font-bold ${t.cycles >= 5 ? 'text-indigo-700' : 'text-gray-700'}">${fmtTime(t.wake)}</p>
          <p class="text-xs mt-1 ${t.cycles >= 5 ? 'text-indigo-500' : 'text-gray-500'}">${t.cycles} cycles · ${t.hours} hrs</p>
        </div>`
      ).join('');
    }

    document.getElementById('result')!.classList.remove('hidden');
  });
</script>
