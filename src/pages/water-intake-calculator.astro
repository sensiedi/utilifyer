---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Water Intake Calculator"
  description="Calculate your recommended daily water intake based on your body weight and activity level. Get personalized hydration goals in oz, ml, and cups."
  slug="water-intake-calculator"
  category="Health"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Water Intake Calculator</h1>
  <p class="text-gray-500 mb-8">Find out how much water you should drink each day based on your weight and activity.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div class="flex border border-gray-200 rounded-xl overflow-hidden w-fit">
      <button data-unit="imperial" class="unit-btn px-5 py-2 text-sm font-medium bg-indigo-600 text-white">Imperial (lbs)</button>
      <button data-unit="metric" class="unit-btn px-5 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50">Metric (kg)</button>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="label" id="weight-label">Weight (lbs)</label>
        <input id="weight" type="number" placeholder="e.g. 165" class="input-field" />
      </div>
      <div>
        <label class="label">Activity Level</label>
        <select id="activity" class="input-field">
          <option value="0">Sedentary (little/no exercise)</option>
          <option value="12" selected>Light (exercise 1–3 days/week)</option>
          <option value="20">Moderate (exercise 3–5 days/week)</option>
          <option value="32">Active (hard exercise 6–7 days/week)</option>
          <option value="40">Very Active (athlete / physical job)</option>
        </select>
      </div>
    </div>

    <div>
      <label class="label">Climate / Temperature</label>
      <select id="climate" class="input-field">
        <option value="0">Temperate (normal conditions)</option>
        <option value="16">Hot / Humid (summer, tropical)</option>
        <option value="-8">Cold / Dry (winter, AC)</option>
      </select>
    </div>

    <button id="calc-btn" class="btn-primary w-full">Calculate</button>

    <div id="result" class="hidden space-y-4">
      <div class="grid grid-cols-3 gap-3 text-center">
        <div class="result-box"><p id="r-oz" class="text-3xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Fluid Ounces / day</p></div>
        <div class="result-box"><p id="r-ml" class="text-3xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Milliliters / day</p></div>
        <div class="result-box"><p id="r-cups" class="text-3xl font-bold text-indigo-900"></p><p class="text-xs text-indigo-600 mt-1">Cups / day</p></div>
      </div>

      <div id="glasses-viz" class="flex flex-wrap gap-2 items-center p-4 bg-blue-50 border border-blue-100 rounded-xl"></div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm">
        <p class="font-semibold text-gray-700 mb-2">💧 Hydration Schedule</p>
        <div id="schedule" class="space-y-1 text-gray-600"></div>
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "How much water should I drink per day?", a: "The general rule is to drink 0.5–1 oz of water per pound of body weight daily. The classic '8 glasses a day' is a reasonable baseline but doesn't account for individual factors like weight, activity, and climate." },
        { q: "Does coffee and tea count toward my water intake?", a: "Yes, beverages containing water (coffee, tea, juice) contribute to your daily hydration. However, caffeinated drinks have a mild diuretic effect. Water, herbal tea, and water-rich foods (cucumber, watermelon) are the best sources." },
        { q: "What are signs of dehydration?", a: "Mild dehydration: thirst, dark yellow urine, fatigue, headache. Moderate: dizziness, dry mouth, decreased urine output. Severe: rapid heartbeat, confusion, fainting. Check your urine — pale yellow means well hydrated." },
        { q: "Can you drink too much water?", a: "Yes, but it's rare in healthy adults. Hyponatremia (water intoxication) occurs when you drink excessive amounts and dilute sodium levels. Endurance athletes in particular should balance water with electrolytes during long events." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  let unit = 'imperial';

  document.querySelectorAll<HTMLButtonElement>('.unit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      unit = btn.dataset.unit!;
      document.querySelectorAll('.unit-btn').forEach(b => { b.classList.toggle('bg-indigo-600', b === btn); b.classList.toggle('text-white', b === btn); b.classList.toggle('text-gray-600', b !== btn); });
      document.getElementById('weight-label')!.textContent = unit === 'imperial' ? 'Weight (lbs)' : 'Weight (kg)';
      (document.getElementById('weight') as HTMLInputElement).placeholder = unit === 'imperial' ? 'e.g. 165' : 'e.g. 75';
    });
  });

  document.getElementById('calc-btn')?.addEventListener('click', () => {
    let weight = parseFloat((document.getElementById('weight') as HTMLInputElement).value);
    if (isNaN(weight)) return;
    if (unit === 'metric') weight = weight * 2.20462;

    const activityOz = parseInt((document.getElementById('activity') as HTMLSelectElement).value);
    const climateOz = parseInt((document.getElementById('climate') as HTMLSelectElement).value);
    const baseOz = weight * 0.5;
    const totalOz = Math.round(baseOz + activityOz + climateOz);
    const ml = Math.round(totalOz * 29.5735);
    const cups = (totalOz / 8).toFixed(1);
    const glasses = Math.round(totalOz / 8);

    document.getElementById('r-oz')!.textContent = totalOz + ' oz';
    document.getElementById('r-ml')!.textContent = ml.toLocaleString() + ' ml';
    document.getElementById('r-cups')!.textContent = cups + ' cups';

    const viz = document.getElementById('glasses-viz')!;
    viz.innerHTML = Array.from({ length: glasses }, (_, i) =>
      `<span title="Glass ${i + 1}" class="text-2xl">💧</span>`
    ).join('') + `<span class="text-sm text-blue-600 ml-2">${glasses} glasses of water (8 oz each)</span>`;

    const schedule = [
      ['7:00 AM', 'After waking up', 2],
      ['9:00 AM', 'Mid-morning', 2],
      ['12:00 PM', 'Before lunch', 2],
      ['2:00 PM', 'Afternoon', 2],
      ['4:00 PM', 'Pre-workout / afternoon', 2],
      ['6:00 PM', 'With dinner', 2],
      ['8:00 PM', 'Evening', glasses - 12 > 0 ? glasses - 12 : 1],
    ];
    document.getElementById('schedule')!.innerHTML = schedule.slice(0, Math.ceil(glasses / 2)).map(([time, label, g]) =>
      `<div class="flex justify-between text-xs"><span class="text-gray-500">${time} — ${label}</span><span class="font-medium">${g} glass${(g as number) > 1 ? 'es' : ''}</span></div>`
    ).join('');

    document.getElementById('result')!.classList.remove('hidden');
  });
</script>
