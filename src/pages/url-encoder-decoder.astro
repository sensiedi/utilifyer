---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="URL Encoder / Decoder"
  description="Encode special characters in URLs or decode percent-encoded URLs. Supports full URL encoding and component encoding."
  slug="url-encoder-decoder"
  category="Developer"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">URL Encoder / Decoder</h1>
  <p class="text-gray-500 mb-8">Encode or decode URLs and URL components instantly.</p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-4">

    <div class="flex flex-wrap gap-2">
      <button id="btn-encode" class="btn-primary">Encode URL</button>
      <button id="btn-decode" class="btn-secondary">Decode URL</button>
      <button id="btn-swap" class="btn-secondary">⇄ Swap</button>
      <button id="btn-clear" class="btn-secondary">Clear</button>
      <div class="ml-auto flex items-center gap-2">
        <label class="text-sm text-gray-600">Mode:</label>
        <select id="enc-mode" class="input-field w-auto text-sm py-1.5">
          <option value="component">encodeURIComponent</option>
          <option value="full">encodeURI (full URL)</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label class="label">Input</label>
        <textarea id="url-input" rows={8} placeholder="https://example.com/search?q=hello world&lang=en" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y text-sm font-mono"></textarea>
      </div>
      <div>
        <div class="flex justify-between mb-1">
          <label class="label">Output</label>
          <button id="copy-output" class="text-xs text-indigo-600 hover:text-indigo-800">Copy</button>
        </div>
        <textarea id="url-output" rows={8} readonly class="w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 bg-gray-50 resize-y text-sm font-mono"></textarea>
      </div>
    </div>

    <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700"></div>

    <!-- Reference table -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-gray-700 mb-3">Common URL Encodings</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs font-mono">
        {[
          [' ', '%20'], ['!', '%21'], ['"', '%22'], ['#', '%23'],
          ['$', '%24'], ['&', '%26'], ["'", '%27'], ['(', '%28'],
          [')', '%29'], ['*', '%2A'], ['+', '%2B'], [',', '%2C'],
          ['/', '%2F'], [':', '%3A'], [';', '%3B'], ['=', '%3D'],
          ['?', '%3F'], ['@', '%40'], ['[', '%5B'], [']', '%5D'],
        ].map(([char, enc]) => (
          <div class="flex gap-2 bg-white border border-gray-200 rounded px-2 py-1">
            <span class="text-gray-500">{char}</span>
            <span class="text-gray-300">→</span>
            <span class="text-indigo-600">{enc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-xl overflow-hidden">
      {[
        { q: "What is URL encoding?", a: "URL encoding (percent encoding) replaces unsafe ASCII characters with a % followed by two hexadecimal digits. For example, a space becomes %20. This ensures URLs can be transmitted safely over the internet." },
        { q: "What is the difference between encodeURI and encodeURIComponent?", a: "encodeURI encodes a full URL, leaving reserved characters like /, ?, &, = untouched. encodeURIComponent encodes everything except letters, digits, and - _ . ! ~ * ' ( ), making it safe for encoding query string values." },
        { q: "Why does + appear in URLs?", a: "In HTML form submissions, spaces in query strings are sometimes encoded as + instead of %20. This is technically HTML form encoding (application/x-www-form-urlencoded), not strict URL encoding. Servers typically accept both." },
        { q: "What characters are safe in URLs?", a: "Unreserved characters that don't need encoding: A–Z, a–z, 0–9, hyphen (-), underscore (_), period (.), and tilde (~). All other characters should be percent-encoded when used in a URL query string." },
      ].map(({ q, a }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-gray-50 transition-colors">
            {q}<span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-gray-600">{a}</p>
        </details>
      ))}
    </div>
  </div>
</ToolLayout>

<script>
  const inp = document.getElementById('url-input') as HTMLTextAreaElement;
  const out = document.getElementById('url-output') as HTMLTextAreaElement;
  const errBox = document.getElementById('error-box')!;

  document.getElementById('btn-encode')?.addEventListener('click', () => {
    errBox.classList.add('hidden');
    try {
      const mode = (document.getElementById('enc-mode') as HTMLSelectElement).value;
      out.value = mode === 'full' ? encodeURI(inp.value) : encodeURIComponent(inp.value);
    } catch (e: any) { errBox.textContent = e.message; errBox.classList.remove('hidden'); }
  });

  document.getElementById('btn-decode')?.addEventListener('click', () => {
    errBox.classList.add('hidden');
    try {
      const mode = (document.getElementById('enc-mode') as HTMLSelectElement).value;
      out.value = mode === 'full' ? decodeURI(inp.value) : decodeURIComponent(inp.value);
    } catch (e: any) { errBox.textContent = 'Invalid URL encoding: ' + e.message; errBox.classList.remove('hidden'); }
  });

  document.getElementById('btn-swap')?.addEventListener('click', () => { const t = inp.value; inp.value = out.value; out.value = t; });
  document.getElementById('btn-clear')?.addEventListener('click', () => { inp.value = ''; out.value = ''; errBox.classList.add('hidden'); });

  document.getElementById('copy-output')?.addEventListener('click', () => {
    if (!out.value) return;
    navigator.clipboard.writeText(out.value).then(() => {
      const btn = document.getElementById('copy-output')!;
      btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });
</script>
