---
import '../styles/global.css';
import tools from '../data/tools.json';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  relatedSlugs?: string[];
}

const { title, description, slug, category, relatedSlugs = [] } = Astro.props;

const canonicalUrl = `https://utilifyer.com/${slug}`;
const ogImage = `https://utilifyer.com/og-default.png`;

const categories = [...new Set(tools.map(t => t.category))].sort();

const relatedTools = relatedSlugs.length > 0
  ? tools.filter(t => relatedSlugs.includes(t.slug))
  : tools.filter(t => t.category === category && t.slug !== slug).slice(0, 6);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": canonicalUrl,
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
});

const breadcrumbLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://utilifyer.com" },
    { "@type": "ListItem", "position": 2, "name": category, "item": `https://utilifyer.com/category/${category.toLowerCase().replace(/ /g, '-').replace(/&/g, 'and')}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
  ]
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Free Online Tool | Utilifyer</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} — Utilifyer`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Utilifyer" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Utilifyer`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />
    <script type="application/ld+json" set:html={breadcrumbLd} />

    <link rel="icon" href="/favicon.ico" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-T0KTKQ4MGQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T0KTKQ4MGQ');
    </script>
  </head>

  <body class="min-h-screen flex flex-col">

    <!-- Drawer backdrop -->
    <div id="nav-backdrop" class="fixed inset-0 bg-black/40 z-[60] hidden" aria-hidden="true"></div>

    <!-- Navigation drawer -->
    <div id="nav-drawer" class="fixed top-0 left-0 h-full w-72 bg-white z-[70] shadow-2xl -translate-x-full transition-transform duration-300 flex flex-col" aria-label="Navigation menu">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-indigo-600">
          <span>🛠️</span> Utilifyer
        </a>
        <button id="nav-close" class="text-gray-400 hover:text-gray-700 text-2xl leading-none transition-colors" aria-label="Close menu">✕</button>
      </div>
      <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 mb-2">Categories</p>
        {categories.map(cat => (
          <a
            href={`/category/${cat.toLowerCase().replace(/ /g, '-').replace(/&/g, 'and')}`}
            class={`flex items-center gap-2 px-3 py-2 rounded-xl text-sm transition-colors ${category === cat ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-indigo-50 hover:text-indigo-700'}`}
          >
            {cat}
          </a>
        ))}
      </nav>
      <div class="px-3 py-4 border-t border-gray-100 space-y-0.5">
        <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 hover:text-indigo-600 transition-colors">All Tools</a>
        <a href="/about" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 hover:text-indigo-600 transition-colors">About</a>
        <a href="/contact" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 hover:text-indigo-600 transition-colors">Contact</a>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-indigo-600 hover:text-indigo-700 transition-colors">
          <span class="text-2xl">🛠️</span>
          Utilifyer
        </a>
        <div class="flex items-center gap-3">
          <a href="/" class="text-sm text-gray-500 hover:text-indigo-600 transition-colors hidden sm:block">← All Tools</a>
          <button id="nav-open" class="flex items-center gap-2 text-sm border border-gray-200 rounded-xl px-3 py-1.5 text-gray-600 hover:border-indigo-300 hover:text-indigo-600 transition-colors" aria-label="Open navigation menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            Categories
          </button>
        </div>
      </div>
    </header>

    <!-- Breadcrumb -->
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 py-2 text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
        <span>›</span>
        <a href={`/category/${category.toLowerCase().replace(/ /g, '-').replace(/&/g, 'and')}`} class="hover:text-indigo-600 transition-colors">{category}</a>
        <span>›</span>
        <span class="text-gray-800 font-medium">{title}</span>
      </div>
    </div>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-8">

      <!-- AdSense Top Slot -->
      <div class="mb-6 flex justify-center">
        <!-- ADSENSE UNIT: leaderboard (728x90 / responsive) -->
        <div class="bg-gray-100 border border-dashed border-gray-300 rounded-lg h-24 w-full max-w-3xl flex items-center justify-center text-gray-400 text-sm">
          Ad Unit — Top
        </div>
      </div>

      <!-- Tool Content -->
      <div class="max-w-3xl mx-auto">
        <slot />
      </div>

      <!-- AdSense Middle Slot -->
      <div class="mt-10 mb-6 flex justify-center">
        <!-- ADSENSE UNIT: rectangle (300x250) -->
        <div class="bg-gray-100 border border-dashed border-gray-300 rounded-lg h-32 w-full max-w-3xl flex items-center justify-center text-gray-400 text-sm">
          Ad Unit — Middle
        </div>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <div class="max-w-3xl mx-auto mt-10">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Tools</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {relatedTools.map(tool => (
              <a href={`/${tool.slug}`} class="tool-card flex items-start gap-3 no-underline">
                <span class="text-xl">{tool.icon}</span>
                <div>
                  <div class="text-sm font-medium text-gray-800">{tool.title}</div>
                  <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{tool.description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-12">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <!-- AdSense Footer Slot -->
        <div class="mb-6 flex justify-center">
          <div class="bg-gray-100 border border-dashed border-gray-300 rounded-lg h-24 w-full max-w-3xl flex items-center justify-center text-gray-400 text-sm">
            Ad Unit — Footer
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
          <div class="flex items-center gap-2 font-semibold text-gray-700">
            <span>🛠️</span> Utilifyer
          </div>
          <nav class="flex items-center gap-4">
            <a href="/" class="hover:text-indigo-600 transition-colors">All Tools</a>
            <a href="/about" class="hover:text-indigo-600 transition-colors">About</a>
            <a href="/privacy-policy" class="hover:text-indigo-600 transition-colors">Privacy</a>
            <a href="/terms-of-service" class="hover:text-indigo-600 transition-colors">Terms</a>
            <a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a>
          </nav>
          <p class="text-xs text-gray-400">© {new Date().getFullYear()} Utilifyer. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const drawer = document.getElementById('nav-drawer')!;
      const backdrop = document.getElementById('nav-backdrop')!;
      const openBtn = document.getElementById('nav-open')!;
      const closeBtn = document.getElementById('nav-close')!;

      function openDrawer() {
        backdrop.classList.remove('hidden');
        requestAnimationFrame(() => drawer.classList.remove('-translate-x-full'));
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.add('-translate-x-full');
        setTimeout(() => backdrop.classList.add('hidden'), 300);
        document.body.style.overflow = '';
      }

      openBtn.addEventListener('click', openDrawer);
      closeBtn.addEventListener('click', closeDrawer);
      backdrop.addEventListener('click', closeDrawer);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });
    </script>

  </body>
</html>
